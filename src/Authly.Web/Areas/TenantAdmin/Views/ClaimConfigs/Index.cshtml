@model ClaimConfigInput
@{
    var apps = ViewData["Applications"] as IReadOnlyList<Application> ?? new List<Application>();
    var configs = ViewData["Configs"] as IReadOnlyList<ClaimConfig> ?? new List<ClaimConfig>();
}

<div>
    <h1 class="font-display text-xl font-bold">Custom token claims</h1>
</div>

<div class="card">
    <div class="card-body">
        <p class="text-muted-foreground text-sm mb-4">
            Add claims to issued tokens (§5.6). <strong>Static</strong> emits a fixed value;
            <strong>metadata</strong> maps a dotted path from the user's <code>user_metadata</code>/<code>app_metadata</code>
            (prefix with <code>app_metadata.</code> to target app metadata). For webhook-sourced claims, add a
            <a asp-area="TenantAdmin" asp-controller="PipelineHooks" asp-action="Index">pre-token pipeline hook</a>.
        </p>
        <form asp-area="TenantAdmin" asp-controller="ClaimConfigs" asp-action="Add" method="post" class="grid grid-cols-1 md:grid-cols-12 gap-2 items-end">
            <div class="md:col-span-3">
                <label class="label" asp-for="ClaimName">Claim name</label>
                <input class="input input-sm" asp-for="ClaimName" placeholder="department" />
            </div>
            <div class="md:col-span-2">
                <label class="label" asp-for="Type">Type</label>
                <select class="select select-sm" asp-for="Type">
                    <option value="@ClaimSourceType.Static">static</option>
                    <option value="@ClaimSourceType.Metadata">metadata</option>
                </select>
            </div>
            <div class="md:col-span-3">
                <label class="label" asp-for="Source">Value / path</label>
                <input class="input input-sm" asp-for="Source" placeholder="engineering or org.tier" />
            </div>
            <div class="md:col-span-2">
                <label class="label" asp-for="TokenType">Token</label>
                <select class="select select-sm" asp-for="TokenType">
                    <option value="@ClaimTokenType.Access">access</option>
                    <option value="@ClaimTokenType.Id">id</option>
                </select>
            </div>
            <div class="md:col-span-2">
                <label class="label" asp-for="ApplicationId">Application</label>
                <select class="select select-sm" asp-for="ApplicationId">
                    <option value="">All (tenant-wide)</option>
                    @foreach (var a in apps)
                    {
                        <option value="@a.Id">@a.Name</option>
                    }
                </select>
            </div>
            <div class="md:col-span-12">
                <button type="submit" class="btn btn-sm btn-primary">Add claim</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header"><h6 class="card-title">Configured claims</h6></div>
    @if (configs.Count == 0)
    {
        <div class="card-body">
            <p class="text-muted-foreground mb-0">No custom claims configured.</p>
        </div>
    }
    else
    {
        <div class="overflow-x-auto scroll-thin">
            <table class="table">
                <thead><tr><th>Claim</th><th>Type</th><th>Source</th><th>Token</th><th>Scope</th><th class="text-right"></th></tr></thead>
                <tbody>
                @foreach (var c in configs)
                {
                    var app = apps.FirstOrDefault(a => a.Id == c.ApplicationId);
                    <tr>
                        <td class="font-medium">@c.ClaimName</td>
                        <td>@c.Type.ToString().ToLowerInvariant()</td>
                        <td class="text-sm text-muted-foreground">@c.Source</td>
                        <td>@c.TokenType.ToString().ToLowerInvariant()</td>
                        <td>@(c.ApplicationId is null ? "tenant-wide" : app?.Name ?? "app")</td>
                        <td class="text-right">
                            <form asp-area="TenantAdmin" asp-controller="ClaimConfigs" asp-action="Delete" asp-route-id="@c.Id" method="post">
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
