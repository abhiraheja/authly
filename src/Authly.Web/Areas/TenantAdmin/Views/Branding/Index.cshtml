@model BrandingViewModel
@using Authly.Core.Enums
@{
    Layout = "_AdminLayout";
}

<div class="page-title-head">
    <h4>Branding &amp; custom domain</h4>
</div>

<div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 @(ViewData.ModelState.IsValid ? "d-none" : "")"></div>

<form asp-area="TenantAdmin" asp-controller="Branding" asp-action="Index" method="post">
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card mb-4">
                <div class="card-header">Login page appearance</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="LogoUrl" class="form-label"></label>
                        <input asp-for="LogoUrl" class="form-control" placeholder="https://cdn.yourcompany.com/logo.svg" />
                        <span asp-validation-for="LogoUrl" class="text-danger small"></span>
                        <div class="form-text">Shown on the hosted login/register/MFA pages. Falls back to your workspace name.</div>
                    </div>

                    <div class="row">
                        <div class="col-sm-6 mb-3">
                            <label asp-for="PrimaryColor" class="form-label"></label>
                            <div class="input-group">
                                <input type="color" class="form-control form-control-color" value="@Model.PrimaryColor"
                                       oninput="document.getElementById('PrimaryColor').value = this.value" />
                                <input asp-for="PrimaryColor" id="PrimaryColor" class="form-control" />
                            </div>
                            <span asp-validation-for="PrimaryColor" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6 mb-3">
                            <label asp-for="ButtonTextColor" class="form-label"></label>
                            <div class="input-group">
                                <input type="color" class="form-control form-control-color" value="@Model.ButtonTextColor"
                                       oninput="document.getElementById('ButtonTextColor').value = this.value" />
                                <input asp-for="ButtonTextColor" id="ButtonTextColor" class="form-control" />
                            </div>
                            <span asp-validation-for="ButtonTextColor" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FontFamily" class="form-label"></label>
                        <input asp-for="FontFamily" class="form-control" placeholder="Inter, system-ui, sans-serif" />
                        <div class="form-text">A CSS font-family stack. Leave blank for the default.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label d-block">Layout</label>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" asp-for="Layout" id="layoutCentered" value="@BrandingLayout.Centered" />
                            <label class="form-check-label" for="layoutCentered">Centered card</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" asp-for="Layout" id="layoutSplit" value="@BrandingLayout.Split" />
                            <label class="form-check-label" for="layoutSplit">Split (branded panel)</label>
                        </div>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" asp-for="DarkMode" role="switch" />
                        <label class="form-check-label" asp-for="DarkMode"></label>
                    </div>

                    <div class="mb-1">
                        <label asp-for="Tagline" class="form-label"></label>
                        <input asp-for="Tagline" class="form-control" placeholder="Welcome back to Acme" />
                        <div class="form-text">Shown beside the brand on the split layout.</div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">Custom domain</div>
                <div class="card-body">
                    <label asp-for="CustomDomain" class="form-label"></label>
                    <input asp-for="CustomDomain" class="form-control" placeholder="auth.yourcompany.com" />
                    <span asp-validation-for="CustomDomain" class="text-danger small"></span>
                    <div class="form-text">
                        Point a CNAME for this host at the platform, then enter it here. Your end-users will see
                        login pages on your own domain. Leave blank to remove.
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Save branding</button>
        </div>

        <div class="col-lg-5">
            <div class="card">
                <div class="card-header">Preview</div>
                <div class="card-body">
                    <div id="brandPreview" class="rounded p-4 text-center"
                         style="background: var(--bs-body-bg); border: 1px solid var(--bs-border-color);">
                        <div id="previewLogoWrap" class="mb-3 d-inline-flex align-items-center gap-2 fw-bold fs-5">
                            <span id="previewMark" class="d-inline-grid"
                                  style="place-items:center;width:36px;height:36px;border-radius:.55rem;background:@Model.PrimaryColor;color:#fff;">
                                <i data-lucide="shield-check"></i>
                            </span>
                            <span>Your workspace</span>
                        </div>
                        <p class="text-muted small mb-3">Sign in to your account.</p>
                        <button type="button" id="previewBtn" class="btn w-100"
                                style="background:@Model.PrimaryColor;color:@Model.ButtonTextColor;border:0;">Sign in</button>
                    </div>
                    <div class="form-text mt-2">An approximation; the live page also applies your font and layout.</div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<script>
    const primary = document.getElementById('PrimaryColor');
    const btnText = document.getElementById('ButtonTextColor');
    const previewBtn = document.getElementById('previewBtn');
    const previewMark = document.getElementById('previewMark');
    function sync() {
        previewBtn.style.background = primary.value;
        previewBtn.style.color = btnText.value;
        previewMark.style.background = primary.value;
    }
    primary.addEventListener('input', sync);
    btnText.addEventListener('input', sync);
</script>
}
