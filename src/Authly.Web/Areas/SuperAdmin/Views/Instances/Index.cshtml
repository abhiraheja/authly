@model IReadOnlyList<Authly.Core.Entities.SelfHostedInstance>
@{
    var newKey = ViewData["NewKey"] as string;
    var newKeyName = ViewData["NewKeyName"] as string;
}

<div class="page-title-head d-flex align-items-center justify-content-between">
    <h4>Self-hosted instances</h4>
</div>

<p class="text-muted small">
    Customer-operated deployments that push <strong>aggregate metrics only</strong> (version, counts, health)
    on a ~6h cycle. No user data, emails, tokens, or secrets ever leave a self-hosted instance.
</p>

@if (newKey is not null)
{
    <div class="alert alert-success">
        <div class="fw-semibold mb-1">Sync key issued for <code>@newKeyName</code></div>
        <p class="small mb-2">Copy it now — it is shown <strong>once</strong> and stored only as a hash. Set it on the instance as <code>SYNC_KEY</code>.</p>
        <code class="d-block p-2 bg-body-tertiary rounded user-select-all">@newKey</code>
    </div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">Registered instances</div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead><tr><th>Name</th><th>Version</th><th>Tenants</th><th>Users</th><th>Apps</th><th>Last seen</th></tr></thead>
                    <tbody>
                        @foreach (var i in Model)
                        {
                            <tr>
                                <td>@(i.Name ?? "(unnamed)")</td>
                                <td class="text-muted small">@(i.Version ?? "—")</td>
                                <td>@i.TenantCount</td>
                                <td>@i.UserCount</td>
                                <td>@i.AppCount</td>
                                <td class="text-muted small">
                                    @(i.LastSeenAt is { } seen ? $"{seen.UtcDateTime:yyyy-MM-dd HH:mm} UTC" : "never")
                                </td>
                            </tr>
                        }
                        @if (Model.Count == 0)
                        {
                            <tr><td colspan="6" class="text-center text-muted py-4">No instances registered.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">Register an instance</div>
            <div class="card-body">
                <form asp-area="SuperAdmin" asp-controller="Instances" asp-action="Register" method="post">
                    <div class="mb-3">
                        <label class="form-label">Name (optional)</label>
                        <input name="name" class="form-control" placeholder="acme-prod" />
                    </div>
                    <button type="submit" class="btn btn-primary">Issue sync key</button>
                </form>
            </div>
        </div>
    </div>
</div>
