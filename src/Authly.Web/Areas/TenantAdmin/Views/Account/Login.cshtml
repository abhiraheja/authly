@model TenantAdminLoginViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Admin sign in";
}

<h2 class="font-display text-2xl font-bold">Admin sign in</h2>
<p class="text-sm text-muted-foreground mt-1 mb-6">Sign in to manage your workspace.</p>

<form asp-area="TenantAdmin" asp-controller="Account" asp-action="Login" method="post" class="space-y-4">
    <input type="hidden" asp-for="ReturnUrl" />
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

    <div>
        <label asp-for="Email" class="label">Email</label>
        <input asp-for="Email" class="input" autocomplete="username" placeholder="admin@example.com" />
        <span asp-validation-for="Email" class="text-danger text-xs"></span>
    </div>

    <div>
        <label asp-for="Password" class="label">Password</label>
        <input asp-for="Password" class="input" autocomplete="current-password" placeholder="••••••••" />
        <span asp-validation-for="Password" class="text-danger text-xs"></span>
    </div>

    <button type="submit" class="btn btn-primary w-full">Sign in</button>
</form>

<p class="text-center text-sm text-muted-foreground mt-6">
    Don't have a workspace yet?
    <a class="text-primary hover:underline" asp-area="" asp-controller="Signup" asp-action="Index">Create one</a>
</p>
