@using Authly.Modules.Abac
@model AccessPolicyViewModel
@{
    ViewData["Title"] = Model.Id is null ? "New policy" : "Edit policy";
}

<div class="page-title-head mb-3">
    <h4 class="mb-0">@ViewData["Title"]</h4>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 @(ViewData.ModelState.IsValid ? "d-none" : "")"></div>
                <form asp-area="TenantAdmin" asp-controller="AccessPolicies" asp-action="Save" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <input asp-for="Description" class="form-control" />
                    </div>
                    <div class="row">
                        <div class="col-sm-4 mb-3">
                            <label asp-for="Effect" class="form-label"></label>
                            <select asp-for="Effect" asp-items="Html.GetEnumSelectList<PolicyEffect>()" class="form-select"></select>
                        </div>
                        <div class="col-sm-4 mb-3">
                            <label asp-for="Action" class="form-label"></label>
                            <input asp-for="Action" class="form-control" placeholder="document.read" />
                        </div>
                        <div class="col-sm-4 mb-3">
                            <label asp-for="ResourceType" class="form-label"></label>
                            <input asp-for="ResourceType" class="form-control" placeholder="document" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConditionsJson" class="form-label"></label>
                        <textarea asp-for="ConditionsJson" class="form-control font-monospace" rows="6"></textarea>
                        <div class="form-text">
                            Array of <code>{ "attribute": "subject.department", "operator": "equals", "value": "eng" }</code>.
                            Attributes are <code>subject.*</code>, <code>resource.*</code>, <code>environment.*</code>.
                            Operators: equals, notEquals, contains, in, greaterThan, lessThan, exists. All conditions must hold.
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-4 mb-3">
                            <label asp-for="Priority" class="form-label"></label>
                            <input asp-for="Priority" type="number" class="form-control" />
                        </div>
                        <div class="col-sm-8 mb-3 d-flex align-items-end">
                            <div class="form-check form-switch">
                                <input asp-for="Enabled" class="form-check-input" role="switch" />
                                <label asp-for="Enabled" class="form-check-label"></label>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <a asp-area="TenantAdmin" asp-controller="AccessPolicies" asp-action="Index" class="btn btn-soft-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
