@model IReadOnlyList<LoginHistory>

<div class="flex items-center justify-between gap-3">
    <div>
        <h1 class="font-display text-xl font-bold">Login activity</h1>
    </div>
</div>

<div class="card mt-4">
    <div class="overflow-x-auto scroll-thin">
        <table class="table">
            <thead>
                <tr>
                    <th>When</th>
                    <th>Result</th>
                    <th>Method</th>
                    <th>IP address</th>
                    <th>Device</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var h in Model)
                {
                    var badge = h.Result switch
                    {
                        "success" => "badge-success",
                        "blocked" => "badge-danger",
                        "failed" => "badge-warning",
                        _ => "badge-neutral"
                    };
                    <tr>
                        <td class="text-muted-foreground">@h.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC</td>
                        <td><span class="badge @badge">@h.Result</span></td>
                        <td class="text-muted-foreground">@(h.Method ?? "—")</td>
                        <td class="text-muted-foreground">@(h.IpAddress ?? "—")</td>
                        <td class="text-muted-foreground truncate" style="max-width:280px;">@(h.UserAgent ?? "—")</td>
                    </tr>
                }
                @if (Model.Count == 0)
                {
                    <tr><td colspan="5" class="text-center text-muted-foreground py-4">No login activity yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
