@model PhoneLoginViewModel
@inject Authly.Web.Infrastructure.Branding.CurrentBranding Branding
@{
    Layout = "_AuthLayout";
    var brand = await Branding.GetAsync();
    var headingClass = brand.HeadingSize switch
    {
        Authly.Core.Enums.HeadingSize.Small => "text-xl",
        Authly.Core.Enums.HeadingSize.Large => "text-3xl",
        _ => "text-2xl"
    };
}

<h2 class="font-display @headingClass font-bold">@brand.Heading</h2>
<p class="text-sm text-muted-foreground mt-1 mb-6">Enter your mobile number to receive a WhatsApp code, or use your password.</p>

@if (TempData["Error"] is string error)
{
    <div class="card card-body !py-2.5 mb-4 flex items-center gap-2 border-l-4 border-l-danger text-sm"><i data-lucide="alert-circle" class="size-4 text-coral"></i>@error</div>
}

<partial name="_PhoneLoginForm" model="@Model.ReturnUrl" />

<p class="text-center text-sm text-muted-foreground mt-6">
    <a class="text-primary hover:underline" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Model.ReturnUrl">Back to sign in</a>
</p>
