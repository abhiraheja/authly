@model SandboxLoginViewModel
@{
    var attempted = ViewBag.Outcome is string;
    var succeeded = ViewBag.Succeeded is true;
}

<div>
    <h1 class="font-display text-xl font-bold">Sandbox</h1>
    <p class="text-sm text-muted-foreground mt-0.5">Validate credentials and grab your integration endpoints. Test logins never create an admin session.</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mt-4">
    <div>
        <div class="card">
            <div class="card-header"><h2 class="card-title">Test login</h2></div>
            <div class="card-body space-y-4">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>
                <form asp-area="TenantAdmin" asp-controller="Sandbox" asp-action="Index" method="post" class="space-y-4">
                    <div>
                        <label asp-for="Email" class="label"></label>
                        <input asp-for="Email" class="input" autocomplete="off" />
                        <span asp-validation-for="Email" class="text-danger text-xs"></span>
                    </div>
                    <div>
                        <label asp-for="Password" class="label"></label>
                        <input asp-for="Password" class="input" autocomplete="off" />
                        <span asp-validation-for="Password" class="text-danger text-xs"></span>
                    </div>
                    <button type="submit" class="btn btn-primary">Run test login</button>
                </form>

                @if (attempted)
                {
                    <hr class="border-border" />
                    @if (succeeded)
                    {
                        <div class="card card-body !py-3 flex items-center gap-3 border-l-4 border-l-success">
                            <i data-lucide="check-circle-2" class="size-5 text-success shrink-0"></i>
                            <span class="text-sm">Authentication succeeded.</span>
                        </div>
                        <dl class="grid grid-cols-12 gap-y-2 text-sm">
                            <dt class="col-span-5">User ID</dt><dd class="col-span-7"><code>@ViewBag.UserId</code></dd>
                            <dt class="col-span-5">Email</dt><dd class="col-span-7">@ViewBag.UserEmail</dd>
                            <dt class="col-span-5">Email verified</dt><dd class="col-span-7">@ViewBag.EmailVerified</dd>
                            <dt class="col-span-5">Status</dt><dd class="col-span-7">@ViewBag.UserStatus</dd>
                            @if (ViewBag.SessionId is not null)
                            {
                                <dt class="col-span-5">Session</dt><dd class="col-span-7"><code>@ViewBag.SessionId</code></dd>
                            }
                        </dl>
                    }
                    else
                    {
                        <div class="card card-body !py-3 flex items-center gap-3 border-l-4 border-l-danger">
                            <i data-lucide="alert-circle" class="size-5 text-danger shrink-0"></i>
                            <span class="text-sm">Outcome: <strong>@ViewBag.Outcome</strong></span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <div>
        <div class="card">
            <div class="card-header"><h2 class="card-title">Integration endpoints</h2></div>
            <div class="card-body space-y-3">
                <p class="text-sm text-muted-foreground">Point your OIDC client at the discovery document; it advertises the rest.</p>
                <div>
                    <label class="label">Discovery</label>
                    <input class="input" value="@ViewBag.Discovery" readonly onclick="this.select()" />
                </div>
                <div>
                    <label class="label">Authorization</label>
                    <input class="input" value="@ViewBag.Authorize" readonly onclick="this.select()" />
                </div>
                <div>
                    <label class="label">Token</label>
                    <input class="input" value="@ViewBag.Token" readonly onclick="this.select()" />
                </div>
                <div>
                    <label class="label">UserInfo</label>
                    <input class="input" value="@ViewBag.UserInfo" readonly onclick="this.select()" />
                </div>
            </div>
        </div>
    </div>
</div>
