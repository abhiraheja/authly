@model IReadOnlyList<User>

<div class="page-title-head mb-3">
    <h4 class="mb-0">Users</h4>
</div>

<div class="card">
    <div class="card-body">
        @if (Model.Count == 0)
        {
            <p class="text-muted mb-0">No users in this workspace yet.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Email</th>
                            <th>Name</th>
                            <th>Status</th>
                            <th>Admin</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td class="fw-medium">@u.Email</td>
                            <td class="text-muted">@($"{u.FirstName} {u.LastName}".Trim() is { Length: > 0 } n ? n : "—")</td>
                            <td><span class="badge bg-soft-secondary">@u.Status</span></td>
                            <td>@(u.IsTenantAdmin ? "Yes" : "—")</td>
                            <td class="text-end">
                                <a class="btn btn-soft-secondary btn-sm"
                                   asp-area="TenantAdmin" asp-controller="Users" asp-action="Details" asp-route-id="@u.Id">
                                    Roles
                                </a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
