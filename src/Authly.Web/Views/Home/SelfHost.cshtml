@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Self-host";
    ViewData["NavActive"] = "selfhost";
    ViewData["Description"] = "Self-host Authly with Docker. Free and open source — no MAU limits, no licence keys, no phone-home. Install Docker, set a few env vars, and run.";
}

<!-- HERO -->
<section class="relative overflow-hidden border-b border-border">
    <div class="absolute left-1/2 top-0 -translate-x-1/2 h-64 w-[55rem] glow-blob pointer-events-none" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-3xl px-4 sm:px-6 py-20 text-center">
        <p class="eyebrow">Free &amp; open source</p>
        <h1 class="mt-2 font-display text-4xl md:text-5xl font-bold tracking-tight">Run Authly yourself.</h1>
        <p class="mx-auto mt-4 max-w-xl text-muted-foreground">
            No MAU caps, no auth tax, no licence keys, and <strong>no phone-home</strong> — Authly runs fully offline on your
            own infrastructure. You are the only operator; your data never leaves your database.
        </p>
        <div class="mt-7 flex flex-wrap justify-center gap-3">
            <a class="btn btn-primary btn-lg" href="@Authly.Web.SiteInfo.GitHubUrl" target="_blank" rel="noopener"><i data-lucide="github" class="size-4"></i> Get the source</a>
            <a class="btn btn-outline btn-lg" href="/docs/self-host"><i data-lucide="book-open" class="size-4"></i> Full docs</a>
        </div>
    </div>
</section>

<div class="mx-auto max-w-3xl px-4 sm:px-6 py-14 space-y-14">

    <!-- WHAT YOU NEED -->
    <section>
        <h2 class="font-display text-2xl font-bold tracking-tight">What you need</h2>
        <p class="mt-2 text-muted-foreground">Just one thing — <strong>Docker</strong>. PostgreSQL 16 and Redis 7 ship inside the Compose stack, so there's nothing else to install or provision.</p>
        <div class="mt-5 grid gap-3 sm:grid-cols-3">
            @foreach (var (icon, k, v) in new[]
            {
                ("box", "Docker Engine 24+", "or Docker Desktop"),
                ("database", "PostgreSQL 16", "bundled in compose"),
                ("zap", "Redis 7", "bundled in compose"),
            })
            {
                <div class="card card-body">
                    <i data-lucide="@icon" class="size-5 text-primary"></i>
                    <div class="mt-2 text-sm font-semibold">@k</div>
                    <div class="text-xs text-muted-foreground">@v</div>
                </div>
            }
        </div>
    </section>

    <!-- STEP 1: INSTALL DOCKER -->
    <section data-tabs-root>
        <div class="flex items-center gap-3">
            <span class="grid place-items-center size-8 rounded-full bg-primary text-primary-foreground text-sm font-semibold shrink-0">1</span>
            <h2 class="font-display text-2xl font-bold tracking-tight">Install Docker</h2>
        </div>
        <div class="mt-4 tabs" data-tabs>
            <button type="button" class="tab active" data-target="os-win">Windows</button>
            <button type="button" class="tab" data-target="os-mac">macOS</button>
            <button type="button" class="tab" data-target="os-linux">Linux</button>
        </div>
        <div class="mt-4">
            <div data-panel="os-win" class="space-y-3">
                <ol class="list-decimal pl-5 space-y-1.5 text-sm">
                    <li>Download <strong>Docker Desktop for Windows</strong> from <a class="text-primary hover:underline" href="https://docs.docker.com/desktop/install/windows-install/" target="_blank" rel="noopener">docker.com</a>.</li>
                    <li>Run the installer — it enables the <strong>WSL 2</strong> backend automatically (accept the prompt).</li>
                    <li>Reboot if asked, then launch Docker Desktop and wait for the whale icon to turn green.</li>
                    <li>Verify in PowerShell:</li>
                </ol>
                <div class="code-surface px-4 py-3 text-sm"><code>docker --version
docker compose version</code></div>
            </div>
            <div data-panel="os-mac" class="hidden space-y-3">
                <ol class="list-decimal pl-5 space-y-1.5 text-sm">
                    <li>Download <strong>Docker Desktop for Mac</strong> (choose Apple Silicon or Intel) from <a class="text-primary hover:underline" href="https://docs.docker.com/desktop/install/mac-install/" target="_blank" rel="noopener">docker.com</a>.</li>
                    <li>Drag <strong>Docker.app</strong> into Applications and launch it.</li>
                    <li>Verify in Terminal:</li>
                </ol>
                <div class="code-surface px-4 py-3 text-sm"><code>docker --version
docker compose version</code></div>
            </div>
            <div data-panel="os-linux" class="hidden space-y-3">
                <ol class="list-decimal pl-5 space-y-1.5 text-sm">
                    <li>Install Docker Engine + the Compose plugin with the convenience script (Ubuntu/Debian/Fedora):</li>
                </ol>
                <div class="code-surface px-4 py-3 text-sm"><code>curl -fsSL https://get.docker.com | sh
sudo usermod -aG docker $USER   <span class="tok-com"># then log out/in</span>
docker compose version</code></div>
                <p class="text-xs text-muted-foreground">Full distro-specific steps: <a class="text-primary hover:underline" href="https://docs.docker.com/engine/install/" target="_blank" rel="noopener">docs.docker.com/engine/install</a>.</p>
            </div>
        </div>
    </section>

    <!-- STEP 2: GET AUTHLY -->
    <section>
        <div class="flex items-center gap-3">
            <span class="grid place-items-center size-8 rounded-full bg-primary text-primary-foreground text-sm font-semibold shrink-0">2</span>
            <h2 class="font-display text-2xl font-bold tracking-tight">Get Authly</h2>
        </div>
        <p class="mt-3 text-sm text-muted-foreground">Clone the repository — it contains the <code>Dockerfile</code> and Compose files.</p>
        <div class="mt-3 code-surface px-4 py-3 text-sm"><code>git clone @(Authly.Web.SiteInfo.GitHubUrl).git
cd authly</code></div>
    </section>

    <!-- STEP 3: CONFIGURE -->
    <section>
        <div class="flex items-center gap-3">
            <span class="grid place-items-center size-8 rounded-full bg-primary text-primary-foreground text-sm font-semibold shrink-0">3</span>
            <h2 class="font-display text-2xl font-bold tracking-tight">Configure environment</h2>
        </div>
        <p class="mt-3 text-sm text-muted-foreground">For a quick local spin-up, <code>docker-compose.yml</code> ships with safe dev defaults — skip straight to step&nbsp;4. For a real deployment, use <code>docker-compose.self-host.yml</code> and supply these in a <code>.env</code> file next to it:</p>

        <div class="mt-4 card overflow-hidden">
            <div class="overflow-x-auto scroll-thin">
                <table class="table">
                    <thead><tr><th>Variable</th><th>Required</th><th>What it is</th></tr></thead>
                    <tbody>
                        <tr><td><code>ENCRYPTION_KEY</code></td><td><span class="badge badge-danger">Required</span></td><td>32-byte base64 key for AES-256-GCM secret encryption.</td></tr>
                        <tr><td><code>SUPERADMIN_EMAIL</code></td><td><span class="badge badge-danger">Required</span></td><td>First operator email seeded on boot.</td></tr>
                        <tr><td><code>SUPERADMIN_PASSWORD</code></td><td><span class="badge badge-danger">Required</span></td><td>First operator password — forced change on first login.</td></tr>
                        <tr><td><code>DATABASE_URL</code></td><td><span class="badge badge-neutral">Default</span></td><td>Postgres connection string (defaults to the bundled <code>postgres</code> service).</td></tr>
                        <tr><td><code>REDIS_URL</code></td><td><span class="badge badge-neutral">Default</span></td><td>Redis host:port (defaults to the bundled <code>redis</code> service).</td></tr>
                        <tr><td><code>POSTGRES_PASSWORD</code></td><td><span class="badge badge-neutral">Default</span></td><td>Password for the bundled Postgres (override in production).</td></tr>
                        <tr><td><code>RETENTION_AUDIT_DAYS</code></td><td><span class="badge badge-info">Optional</span></td><td>Audit-log retention (default 365).</td></tr>
                        <tr><td><code>RETENTION_LOGIN_HISTORY_DAYS</code></td><td><span class="badge badge-info">Optional</span></td><td>Login-history retention (default 90).</td></tr>
                        <tr><td><code>OTEL_EXPORTER_OTLP_ENDPOINT</code></td><td><span class="badge badge-info">Optional</span></td><td>OpenTelemetry collector endpoint (see observability overlay below).</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <p class="mt-4 text-sm font-medium">Generate a strong <code>ENCRYPTION_KEY</code>:</p>
        <div class="mt-2 code-surface px-4 py-3 text-sm"><code><span class="tok-com"># macOS / Linux</span>
openssl rand -base64 32

<span class="tok-com"># Any machine with .NET</span>
dotnet run --project - &lt;&lt;&lt; 'System.Console.WriteLine(System.Convert.ToBase64String(System.Security.Cryptography.RandomNumberGenerator.GetBytes(32)))'</code></div>

        <p class="mt-4 text-sm">Example <code>.env</code>:</p>
        <div class="mt-2 code-surface px-4 py-3 text-sm"><code>ENCRYPTION_KEY=<span class="tok-str">"&lt;paste the generated key&gt;"</span>
SUPERADMIN_EMAIL=<span class="tok-str">admin@yourco.com</span>
SUPERADMIN_PASSWORD=<span class="tok-str">"&lt;a strong password&gt;"</span>
POSTGRES_PASSWORD=<span class="tok-str">"&lt;a strong db password&gt;"</span></code></div>
    </section>

    <!-- STEP 4: RUN -->
    <section data-tabs-root>
        <div class="flex items-center gap-3">
            <span class="grid place-items-center size-8 rounded-full bg-primary text-primary-foreground text-sm font-semibold shrink-0">4</span>
            <h2 class="font-display text-2xl font-bold tracking-tight">Run it</h2>
        </div>
        <div class="mt-4 tabs" data-tabs>
            <button type="button" class="tab active" data-target="run-dev">Local / dev</button>
            <button type="button" class="tab" data-target="run-prod">Self-host (prod)</button>
        </div>
        <div class="mt-4">
            <div data-panel="run-dev" class="space-y-3">
                <p class="text-sm text-muted-foreground">Builds the image and starts app + Postgres + Redis. EF Core migrations apply automatically on first boot.</p>
                <div class="code-surface px-4 py-3 text-sm"><code>docker compose up --build -d
docker compose logs -f app        <span class="tok-com"># watch migrations + seed</span></code></div>
            </div>
            <div data-panel="run-prod" class="hidden space-y-3">
                <p class="text-sm text-muted-foreground">Uses the production overlay with your <code>.env</code> (Production environment, no dev secrets).</p>
                <div class="code-surface px-4 py-3 text-sm"><code>docker compose -f docker-compose.self-host.yml up -d
docker compose -f docker-compose.self-host.yml logs -f app</code></div>
            </div>
        </div>
        <p class="mt-3 text-sm text-muted-foreground">Put a reverse proxy (nginx / Caddy / Traefik) in front for TLS in production.</p>
    </section>

    <!-- STEP 5: FIRST RUN -->
    <section>
        <div class="flex items-center gap-3">
            <span class="grid place-items-center size-8 rounded-full bg-primary text-primary-foreground text-sm font-semibold shrink-0">5</span>
            <h2 class="font-display text-2xl font-bold tracking-tight">First run</h2>
        </div>
        <ol class="mt-3 list-decimal pl-5 space-y-1.5 text-sm">
            <li>Open <code class="text-primary">http://localhost:8080</code>.</li>
            <li>Sign in with your <code>SUPERADMIN_EMAIL</code> / <code>SUPERADMIN_PASSWORD</code> — you'll be forced to set a new password.</li>
            <li>Create your first workspace, register an application, and copy your Client ID/secret.</li>
            <li>Point your app's OIDC client at <code class="text-primary">http://localhost:8080/.well-known/openid-configuration</code>.</li>
        </ol>
        <div class="mt-4 card card-body !py-3 flex items-start gap-3 border-l-4 border-l-primary text-sm">
            <i data-lucide="heart-pulse" class="size-4 text-primary mt-0.5 shrink-0"></i>
            <div>
                <strong>Health checks.</strong> App at <code>http://localhost:8080</code> · background jobs at <code>/hangfire</code> ·
                <code>docker compose exec redis redis-cli ping</code> → <code>PONG</code> ·
                <code>docker compose exec postgres psql -U authly -d authly -c "\dt"</code>.
            </div>
        </div>
    </section>

    <!-- OBSERVABILITY -->
    <section>
        <h2 class="font-display text-2xl font-bold tracking-tight">Optional: observability stack</h2>
        <p class="mt-2 text-sm text-muted-foreground">An overlay file spins up Grafana, Prometheus, Loki, Tempo and an OpenTelemetry Collector so you can watch traces, metrics and logs locally. Observability is fully opt-in — nothing is exported until you configure it.</p>
        <div class="mt-3 code-surface px-4 py-3 text-sm"><code>docker compose -f docker-compose.yml -f docker-compose.observability.yml up -d</code></div>
        <div class="mt-3 grid gap-2 sm:grid-cols-2 text-sm">
            @foreach (var (svc, url) in new[] { ("Grafana", "http://localhost:3000"), ("Prometheus", "http://localhost:9090"), ("Loki", "http://localhost:3100"), ("OTLP collector", "localhost:4317 / 4318") })
            {
                <div class="flex items-center justify-between rounded-md border border-border bg-muted/30 px-3 py-2">
                    <span class="font-medium">@svc</span><code class="text-xs text-muted-foreground">@url</code>
                </div>
            }
        </div>
        <p class="mt-3 text-xs text-muted-foreground">Then enable exporting in <strong>Admin → Observability</strong> (OTLP or Azure Monitor). Config applies on restart.</p>
    </section>

    <!-- TEARDOWN -->
    <section>
        <h2 class="font-display text-2xl font-bold tracking-tight">Stop &amp; clean up</h2>
        <div class="mt-3 code-surface px-4 py-3 text-sm"><code>docker compose down            <span class="tok-com"># stop, keep the database</span>
docker compose down -v         <span class="tok-com"># stop and wipe the pgdata volume</span></code></div>
    </section>

    <!-- CTA -->
    <section class="text-center pt-2">
        <p class="text-sm text-muted-foreground">Built and maintained by <span class="font-medium text-foreground">@Authly.Web.SiteInfo.Author</span> · @Authly.Web.SiteInfo.License</p>
        <div class="mt-4 flex flex-wrap justify-center gap-3">
            <a class="btn btn-primary" href="@Authly.Web.SiteInfo.GitHubUrl" target="_blank" rel="noopener"><i data-lucide="github" class="size-4"></i> Star on GitHub</a>
            <a class="btn btn-outline" href="/docs/quickstart">Integrate your first app</a>
        </div>
    </section>
</div>
