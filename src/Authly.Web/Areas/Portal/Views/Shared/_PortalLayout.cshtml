@inject Authly.Web.Infrastructure.Branding.CurrentBranding Branding
@{
    var controller = (ViewContext.RouteData.Values["controller"] as string) ?? "";
    bool IsActive(string c) => string.Equals(controller, c, StringComparison.OrdinalIgnoreCase);
    string NavLink(string c) => IsActive(c)
        ? "menu-item bg-primary/10 text-primary font-medium"
        : "menu-item text-sidebar-foreground hover:bg-sidebar-accent";
    var brand = await Branding.GetAsync();
    var brandName = await Branding.GetDisplayNameAsync();
    var primaryChannels = brand.PrimaryColorRgb.Replace(",", "");
    var email = User?.Identity?.Name ?? "Account";
    var initial = string.IsNullOrEmpty(email) ? "A" : email.Substring(0, 1).ToUpper();
    var impersonatorEmail = User?.FindFirst(Authly.Web.Infrastructure.UserClaims.ImpersonatorEmail)?.Value;
    var isImpersonating = !string.IsNullOrEmpty(User?.FindFirst(Authly.Web.Infrastructure.UserClaims.ImpersonatorId)?.Value);
}
<!DOCTYPE html>
<html lang="en" class="@(brand.DarkMode ? "dark" : "")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · @brandName</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="~/css/saarvix.css" asp-append-version="true" />
    <style>
        :root, .dark { --primary: @primaryChannels; --ring: @primaryChannels; }
        body { font-family: @Html.Raw(brand.FontFamily); }
    </style>
</head>
<body class="min-h-screen">
<div class="flex min-h-screen">
    <aside id="sidenav"
           class="fixed inset-y-0 left-0 z-40 w-64 -translate-x-full lg:translate-x-0 transition-transform duration-200
                  bg-sidebar text-sidebar-foreground border-r border-sidebar-border flex flex-col scroll-thin overflow-y-auto">
        <a class="flex items-center gap-2.5 px-5 h-16 shrink-0 font-display text-[15px] font-bold text-foreground"
           asp-area="Portal" asp-controller="Profile" asp-action="Index">
            @if (brand.LogoUrl is not null)
            {
                <img src="@brand.LogoUrl" alt="@brandName" class="max-h-8" />
            }
            else
            {
                <span class="grid place-items-center size-8 rounded-lg bg-primary text-primary-foreground"><i data-lucide="shield-check" class="size-4"></i></span>
                <span>@brandName</span>
            }
        </a>
        <nav class="flex-1 px-3 pb-4 space-y-1">
            <p class="px-2.5 pb-1 text-[10px] font-semibold uppercase tracking-wider text-muted-foreground">Account</p>
            <a class="@NavLink("Profile")" asp-area="Portal" asp-controller="Profile" asp-action="Index"><i data-lucide="user-round" class="size-4"></i><span>Profile</span></a>
            <a class="@NavLink("Security")" asp-area="Portal" asp-controller="Security" asp-action="Index"><i data-lucide="shield-check" class="size-4"></i><span>Security</span></a>
            <a class="@NavLink("Passkeys")" asp-area="Portal" asp-controller="Passkeys" asp-action="Index"><i data-lucide="key-round" class="size-4"></i><span>Passkeys</span></a>
            <a class="@NavLink("Contact")" asp-area="Portal" asp-controller="Contact" asp-action="Index"><i data-lucide="at-sign" class="size-4"></i><span>Email &amp; phone</span></a>
            <a class="@NavLink("Recovery")" asp-area="Portal" asp-controller="Recovery" asp-action="Index"><i data-lucide="life-buoy" class="size-4"></i><span>Account recovery</span></a>
            <a class="@NavLink("Sessions")" asp-area="Portal" asp-controller="Sessions" asp-action="Index"><i data-lucide="monitor-smartphone" class="size-4"></i><span>Active sessions</span></a>
            <a class="@NavLink("Devices")" asp-area="Portal" asp-controller="Devices" asp-action="Index"><i data-lucide="laptop" class="size-4"></i><span>Devices</span></a>
            <a class="@NavLink("Activity")" asp-area="Portal" asp-controller="Activity" asp-action="Index"><i data-lucide="history" class="size-4"></i><span>Login activity</span></a>
            <a class="@NavLink("Privacy")" asp-area="Portal" asp-controller="Privacy" asp-action="Index"><i data-lucide="shield-user" class="size-4"></i><span>Privacy &amp; data</span></a>
            <a class="@NavLink("Consents")" asp-area="Portal" asp-controller="Consents" asp-action="Index"><i data-lucide="file-check" class="size-4"></i><span>Policies &amp; consents</span></a>
        </nav>
    </aside>

    <div id="sidenavBackdrop" class="fixed inset-0 z-30 bg-ink/40 backdrop-blur-sm hidden lg:hidden"></div>

    <div class="flex-1 flex flex-col min-w-0 lg:ml-64">
        <header class="sticky top-0 z-20 h-16 flex items-center gap-3 px-4 sm:px-6 border-b border-border glass">
            <button class="btn btn-ghost btn-icon lg:hidden" type="button" id="menuToggle" aria-label="Toggle menu">
                <i data-lucide="menu" class="size-5"></i>
            </button>
            <div class="ms-auto flex items-center gap-2">
                <div class="relative">
                    <button class="btn btn-ghost gap-2 px-2" type="button" data-dropdown="profileMenu">
                        <span class="avatar size-8 bg-primary text-xs">@initial</span>
                        <span class="hidden sm:inline text-sm">@email</span>
                        <i data-lucide="chevron-down" class="size-4 opacity-60"></i>
                    </button>
                    <div id="profileMenu" data-dropdown-menu class="menu hidden absolute right-0 mt-1 w-56">
                        <p class="px-2.5 py-1.5 text-xs text-muted-foreground">Signed in</p>
                        <div class="menu-sep"></div>
                        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                            <button type="submit" class="menu-item w-full text-danger"><i data-lucide="log-out" class="size-4"></i>Sign out</button>
                        </form>
                    </div>
                </div>
            </div>
        </header>

        @if (isImpersonating)
        {
            <div class="flex items-center justify-between flex-wrap gap-2 px-4 sm:px-6 py-2.5 bg-warning/15 text-sm border-b border-warning/30">
                <span class="flex items-center gap-2">
                    <i data-lucide="eye" class="size-4"></i>
                    You're viewing this account as <strong>@email</strong>@(string.IsNullOrEmpty(impersonatorEmail) ? "" : $" (impersonated by {impersonatorEmail})").
                </span>
                <form asp-area="" asp-controller="Account" asp-action="StopImpersonation" method="post" class="m-0">
                    <button type="submit" class="btn btn-sm btn-outline">Stop impersonating</button>
                </form>
            </div>
        }

        <main class="flex-1 p-4 sm:p-6">
            <div class="mx-auto max-w-5xl space-y-4">
                @if (TempData["Success"] is string ok)
                {
                    <div data-alert class="card card-body !py-3 flex items-center gap-3 border-l-4 border-l-success">
                        <i data-lucide="check-circle-2" class="size-5 text-success shrink-0"></i>
                        <span class="text-sm flex-1">@ok</span>
                        <button type="button" class="btn btn-ghost btn-icon btn-sm" data-dismiss aria-label="Dismiss"><i data-lucide="x" class="size-4"></i></button>
                    </div>
                }
                @if (TempData["Error"] is string err)
                {
                    <div data-alert class="card card-body !py-3 flex items-center gap-3 border-l-4 border-l-danger">
                        <i data-lucide="alert-circle" class="size-5 text-coral shrink-0"></i>
                        <span class="text-sm flex-1">@err</span>
                        <button type="button" class="btn btn-ghost btn-icon btn-sm" data-dismiss aria-label="Dismiss"><i data-lucide="x" class="size-4"></i></button>
                    </div>
                }
                @RenderBody()
            </div>
        </main>

        <footer class="px-6 py-4 text-xs text-muted-foreground border-t border-border">
            &copy; @DateTime.UtcNow.Year @brandName
        </footer>
    </div>
</div>

<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
<script src="~/js/saarvix-app.js" asp-append-version="true"></script>
<script>
    lucide.createIcons();
    (function () {
        const sidenav = document.getElementById("sidenav");
        const backdrop = document.getElementById("sidenavBackdrop");
        const toggle = () => { sidenav?.classList.toggle("-translate-x-full"); backdrop?.classList.toggle("hidden"); };
        document.getElementById("menuToggle")?.addEventListener("click", toggle);
        backdrop?.addEventListener("click", toggle);
    })();
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
