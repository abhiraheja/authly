@{
    Layout = "_AuthLayout";
    var isCancel = ViewData["IsCancel"] is true;
    var ok = isCancel ? ViewData["Cancelled"] is true : ViewData["Verified"] is true;
}

<div class="text-center">
    @if (ok && isCancel)
    {
        <span class="logo-mark mb-3"><i data-lucide="shield-x"></i></span>
        <h2 class="font-display text-2xl font-bold">Change cancelled</h2>
        <p class="text-sm text-muted-foreground mt-1 mb-6">The pending change to your contact details has been cancelled. Your account is unchanged.</p>
    }
    else if (ok)
    {
        <span class="logo-mark mb-3"><i data-lucide="check-circle"></i></span>
        <h2 class="font-display text-2xl font-bold">Contact confirmed</h2>
        <p class="text-sm text-muted-foreground mt-1 mb-6">Your new contact details have been applied to your account.</p>
    }
    else
    {
        <span class="logo-mark mb-3"><i data-lucide="alert-triangle"></i></span>
        <h2 class="font-display text-2xl font-bold">Link no longer valid</h2>
        <p class="text-sm text-muted-foreground mt-1 mb-6">This link is invalid, has expired, or was already used.</p>
    }
    <a asp-controller="Account" asp-action="Login" class="btn btn-outline w-full">Go to sign in</a>
</div>
