@inject Authly.Web.Infrastructure.Branding.CurrentBranding Branding
@{
    var brand = await Branding.GetAsync();
    var brandName = await Branding.GetDisplayNameAsync();
    var split = brand.Layout == Authly.Core.Enums.BrandingLayout.Split;
    var primaryChannels = brand.PrimaryColorRgb.Replace(",", "");
}
<!DOCTYPE html>
<html lang="en" class="@(brand.DarkMode ? "dark" : "")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · @brandName</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="~/css/saarvix.css" asp-append-version="true" />
    @* Per-tenant theming: override the SAARVIX primary/ring channels + font. *@
    <style>
        :root, .dark { --primary: @primaryChannels; --ring: @primaryChannels; }
        body { font-family: @Html.Raw(brand.FontFamily); }
    </style>
</head>
<body>
<div class="min-h-screen grid @(split ? "lg:grid-cols-2" : "")">
    @if (split)
    {
        <aside class="relative hidden lg:flex flex-col justify-between p-10 bg-gradient-to-br from-primary via-primary to-teal text-white overflow-hidden">
            <div class="absolute -top-20 -right-20 size-72 rounded-full bg-white/10 blur-2xl"></div>
            <div class="flex items-center gap-2.5 relative">
                @if (brand.LogoUrl is not null)
                {
                    <img src="@brand.LogoUrl" alt="@brandName" class="max-h-9" />
                }
                else
                {
                    <span class="grid size-10 place-items-center rounded-lg bg-white/15"><i data-lucide="shield-check" class="size-5"></i></span>
                    <span class="font-display text-xl font-bold tracking-tight">@brandName</span>
                }
            </div>
            @if (!string.IsNullOrEmpty(brand.Tagline))
            {
                <div class="relative">
                    <p class="font-display text-2xl font-bold leading-tight">@brand.Tagline</p>
                </div>
            }
        </aside>
    }
    <div class="flex items-center justify-center p-6 bg-background">
        <div class="w-full max-w-sm">
            <div class="flex items-center gap-2.5 mb-8 @(split ? "lg:hidden" : "")">
                @if (brand.LogoUrl is not null)
                {
                    <img src="@brand.LogoUrl" alt="@brandName" class="max-h-9" />
                }
                else
                {
                    <span class="grid size-9 place-items-center rounded-lg bg-primary text-primary-foreground"><i data-lucide="shield-check" class="size-5"></i></span>
                    <span class="font-display font-bold">@brandName</span>
                }
            </div>
            @RenderBody()
        </div>
    </div>
</div>
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
<script src="~/js/saarvix-app.js" asp-append-version="true"></script>
<script>lucide.createIcons();</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
