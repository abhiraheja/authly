@model UserLoginViewModel
@inject Authly.Web.Infrastructure.Branding.CurrentBranding Branding
@{
    Layout = "_AuthLayout";
    var socialOptions = ViewData["SocialOptions"] as IReadOnlyList<Authly.Modules.Social.SocialLoginOption>
        ?? new List<Authly.Modules.Social.SocialLoginOption>();
    var brand = await Branding.GetAsync();
    var headingClass = brand.HeadingSize switch
    {
        Authly.Core.Enums.HeadingSize.Small => "text-xl",
        Authly.Core.Enums.HeadingSize.Large => "text-3xl",
        _ => "text-2xl"
    };
}

<h2 class="font-display @headingClass font-bold">@brand.Heading</h2>
<p class="text-sm text-muted-foreground mt-1 mb-6">@brand.Subtitle</p>

@if (TempData["Success"] is string success)
{
    <div class="card card-body !py-2.5 mb-4 flex items-center gap-2 border-l-4 border-l-success text-sm"><i data-lucide="check-circle-2" class="size-4 text-success"></i>@success</div>
}
@if (TempData["Error"] is string error)
{
    <div class="card card-body !py-2.5 mb-4 flex items-center gap-2 border-l-4 border-l-danger text-sm"><i data-lucide="alert-circle" class="size-4 text-coral"></i>@error</div>
}

@if (socialOptions.Count > 0)
{
    <div class="space-y-2.5 mb-4">
        @foreach (var opt in socialOptions)
        {
            <a class="btn btn-outline w-full justify-center gap-2.5 font-semibold" asp-controller="Social" asp-action="Start"
               asp-route-provider="@opt.Provider" asp-route-returnUrl="@Model.ReturnUrl">
                <partial name="_SocialIcon" model="@opt.Provider" />
                Continue with @opt.DisplayName
            </a>
        }
    </div>
    <div class="my-4 flex items-center gap-3"><div class="h-px flex-1 bg-border"></div><span class="text-xs text-muted-foreground">or continue with email</span><div class="h-px flex-1 bg-border"></div></div>
}

<form asp-controller="Account" asp-action="Login" method="post" class="space-y-4">
    <input type="hidden" asp-for="ReturnUrl" />
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

    <div>
        <label asp-for="Email" class="label">Email</label>
        <input asp-for="Email" class="input" autocomplete="username" placeholder="you@example.com" />
        <span asp-validation-for="Email" class="text-danger text-xs"></span>
    </div>

    <div>
        <label asp-for="Password" class="label">Password</label>
        <div class="relative">
            <input asp-for="Password" id="passwordInput" class="input pr-10" autocomplete="current-password" placeholder="••••••••" />
            <button type="button" id="togglePassword" aria-label="Show password"
                    class="absolute right-2.5 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground">
                <i data-lucide="eye" class="size-4"></i>
            </button>
        </div>
        <span asp-validation-for="Password" class="text-danger text-xs"></span>
    </div>

    <div class="flex justify-end">
        <a asp-controller="Account" asp-action="ForgotPassword" asp-route-returnUrl="@Model.ReturnUrl" class="text-sm font-medium text-primary hover:underline">Forgot password?</a>
    </div>

    <partial name="_Captcha" />

    <button type="submit" class="btn btn-primary btn-lg w-full">Sign in</button>
</form>

<div class="my-4 flex items-center gap-3"><div class="h-px flex-1 bg-border"></div><span class="text-xs text-muted-foreground">or</span><div class="h-px flex-1 bg-border"></div></div>

@Html.AntiForgeryToken()
<div class="space-y-2">
    <button type="button" id="passkeyBtn" class="btn btn-outline w-full">
        <i data-lucide="key-round" class="size-4"></i> Sign in with a passkey
    </button>
    <a class="btn btn-outline w-full" asp-controller="Account" asp-action="MagicLink" asp-route-returnUrl="@Model.ReturnUrl">
        <i data-lucide="mail" class="size-4"></i> Email me a sign-in link
    </a>
</div>
<div id="passkeyError" class="text-danger text-xs text-center mt-2 hidden"></div>

<p class="text-center text-sm text-muted-foreground mt-6">
    Don't have an account? <a class="text-primary hover:underline" asp-controller="Account" asp-action="Register" asp-route-returnUrl="@Model.ReturnUrl">Create one</a>
</p>
<p class="text-center text-sm text-muted-foreground">
    <a class="text-primary hover:underline" asp-controller="Account" asp-action="RecoverRequest" asp-route-returnUrl="@Model.ReturnUrl">Can't access your account?</a>
</p>

@section Scripts {
<script src="~/js/authly-webauthn.js" asp-append-version="true"></script>
<script>
    document.getElementById('togglePassword')?.addEventListener('click', function () {
        const input = document.getElementById('passwordInput');
        const show = input.type === 'password';
        input.type = show ? 'text' : 'password';
        this.innerHTML = '<i data-lucide="' + (show ? 'eye-off' : 'eye') + '" class="size-4"></i>';
        this.setAttribute('aria-label', show ? 'Hide password' : 'Show password');
        lucide.createIcons();
    });

    document.getElementById('passkeyBtn')?.addEventListener('click', function () {
        const email = document.querySelector('[name="Email"]').value.trim();
        const err = document.getElementById('passkeyError');
        err.classList.add('hidden');
        if (!email) { err.textContent = 'Enter your email first, then use your passkey.'; err.classList.remove('hidden'); return; }
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const returnUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ReturnUrl));
        authlyPasskeyLogin(email, token, function (msg) { err.textContent = msg; err.classList.remove('hidden'); }, returnUrl);
    });
</script>
}
