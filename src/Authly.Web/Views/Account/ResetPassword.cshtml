@model ResetPasswordViewModel
@{
    Layout = "_AuthLayout";
}

@if (ViewData["InvalidToken"] is true)
{
    <div class="text-center">
        <span class="logo-mark mb-3"><i data-lucide="alert-triangle"></i></span>
        <h2 class="font-display text-2xl font-bold">Invalid reset link</h2>
        <p class="text-sm text-muted-foreground mt-1 mb-6">This link is missing or malformed. Request a new one.</p>
        <a asp-controller="Account" asp-action="ForgotPassword" class="btn btn-outline w-full">Request a new link</a>
    </div>
}
else
{
    <h2 class="font-display text-2xl font-bold">Reset password</h2>
    <p class="text-sm text-muted-foreground mt-1 mb-6">Choose a new password.</p>

    <form asp-controller="Account" asp-action="ResetPassword" method="post" class="space-y-4">
        <input type="hidden" asp-for="Token" />
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

        <div>
            <label asp-for="NewPassword" class="label">New password</label>
            <input asp-for="NewPassword" class="input" autocomplete="new-password" placeholder="••••••••" />
            <span asp-validation-for="NewPassword" class="text-danger text-xs"></span>
        </div>

        <div>
            <label asp-for="ConfirmPassword" class="label">Confirm password</label>
            <input asp-for="ConfirmPassword" class="input" autocomplete="new-password" placeholder="••••••••" />
            <span asp-validation-for="ConfirmPassword" class="text-danger text-xs"></span>
        </div>

        <button type="submit" class="btn btn-primary w-full">Reset password</button>
    </form>
}
