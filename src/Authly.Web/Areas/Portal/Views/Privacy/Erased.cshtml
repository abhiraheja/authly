@{
    Layout = "_AuthLayout";
}

<div class="text-center">
    <span class="grid place-items-center size-12 rounded-xl bg-success/10 text-success mx-auto mb-3"><i data-lucide="check-circle-2" class="size-6"></i></span>
    <h1 class="font-display text-xl font-bold">Your account has been erased</h1>
    <p class="text-muted-foreground mt-1">
        All of your data has been permanently deleted. Thank you for using our service.
    </p>
    <a asp-area="" asp-controller="Account" asp-action="Login" class="btn btn-primary mt-3">Back to sign in</a>
</div>
