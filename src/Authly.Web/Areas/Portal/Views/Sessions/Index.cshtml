@model IReadOnlyList<Session>
@{
    var currentId = (Guid)(ViewData["CurrentSessionId"] ?? Guid.Empty);
    var others = Model.Count(s => s.Id != currentId);
}

<div class="flex items-center justify-between gap-3">
    <div>
        <h1 class="font-display text-xl font-bold">Active sessions</h1>
    </div>
    @if (others > 0)
    {
        <form asp-area="Portal" asp-controller="Sessions" asp-action="RevokeOthers" method="post"
              onsubmit="return confirm('Sign out all other devices?');">
            <button type="submit" class="btn btn-danger btn-sm">Sign out other sessions</button>
        </form>
    }
</div>

<div class="card mt-4">
    <div class="overflow-x-auto scroll-thin">
        <table class="table">
            <thead>
                <tr>
                    <th>Device</th>
                    <th>IP address</th>
                    <th>Last active</th>
                    <th>Signed in</th>
                    <th class="text-right">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.OrderByDescending(x => x.LastActiveAt))
                {
                    <tr>
                        <td>
                            <div class="truncate" style="max-width:320px;">@(s.UserAgent ?? "Unknown device")</div>
                            @if (s.Id == currentId)
                            {
                                <span class="badge badge-primary">This device</span>
                            }
                        </td>
                        <td class="text-muted-foreground">@(s.IpAddress ?? "—")</td>
                        <td class="text-muted-foreground">@s.LastActiveAt.ToString("yyyy-MM-dd HH:mm") UTC</td>
                        <td class="text-muted-foreground">@s.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td class="text-right">
                            <form asp-area="Portal" asp-controller="Sessions" asp-action="Revoke" asp-route-id="@s.Id" method="post"
                                  onsubmit="return confirm('@(s.Id == currentId ? "Sign out this device?" : "Revoke this session?")');">
                                <button type="submit" class="btn btn-sm btn-danger">@(s.Id == currentId ? "Sign out" : "Revoke")</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (Model.Count == 0)
                {
                    <tr><td colspan="5" class="text-center text-muted-foreground py-4">No active sessions.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
