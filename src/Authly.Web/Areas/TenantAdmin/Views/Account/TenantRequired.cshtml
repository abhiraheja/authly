@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Select a workspace";
}

<div class="text-center">
    <span class="grid place-items-center size-12 rounded-xl bg-primary/10 text-primary mx-auto mb-3"><i data-lucide="building-2" class="size-6"></i></span>
    <h2 class="font-display text-xl font-bold mb-2">No workspace selected</h2>
    <p class="text-sm text-muted-foreground mb-3">
        The admin console is scoped to a workspace. In production it's reached through the
        workspace's own domain. For local testing, append <code>?tenant=&lt;slug&gt;</code> once
        and it will be remembered for this browser.
    </p>
    <p class="text-sm text-muted-foreground">Example: <code>/tenantadmin/account/login?tenant=acme</code></p>
</div>
