@model TemplateInput
@{
    var isEmail = Model.Channel == MessageChannel.Email;
    var preview = ViewData["Preview"] as RenderedPreview;
}

<div class="page-title-head mb-3">
    <h4 class="mb-0">Edit template — <code>@Model.Key</code></h4>
    <div class="small text-muted">@Model.Channel · @Model.Locale</div>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-body">
                <form asp-area="TenantAdmin" asp-controller="Messaging" asp-action="SaveTemplate" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Key" />
                    <input type="hidden" asp-for="Channel" />
                    <input type="hidden" asp-for="Locale" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small @(ViewData.ModelState.IsValid ? "d-none" : "")"></div>

                    @if (isEmail)
                    {
                        <div class="mb-3">
                            <label asp-for="Subject" class="form-label">Subject</label>
                            <input asp-for="Subject" class="form-control" />
                        </div>
                    }
                    <div class="mb-3">
                        <label asp-for="Body" class="form-label">Body @(isEmail ? "(HTML)" : "(text)")</label>
                        <textarea asp-for="Body" class="form-control font-monospace" rows="12"></textarea>
                        <span asp-validation-for="Body" class="text-danger small"></span>
                    </div>
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" asp-for="IsActive" id="isActive" />
                        <label class="form-check-label" for="isActive">Active</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" name="action" value="save" class="btn btn-primary">Save</button>
                        <button type="submit" name="action" value="preview" class="btn btn-soft-secondary">Preview</button>
                        <a class="btn btn-link" asp-area="TenantAdmin" asp-controller="Messaging" asp-action="Templates">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-body">
                <h6 class="mb-2">Available variables</h6>
                <p class="small text-muted">Insert with <code>{{'{{'}}variable{{'}}'}}</code>. Common ones:</p>
                <div class="small font-monospace">
                    {{app_name}} · {{user_name}} · {{action_url}} · {{otp}} · {{expiry_hours}} · {{expiry_minutes}}
                </div>
                @if (preview is not null)
                {
                    <hr />
                    <h6 class="mb-2">Preview</h6>
                    @if (preview.Subject is not null)
                    {
                        <div class="small text-muted mb-1">Subject: <strong>@preview.Subject</strong></div>
                    }
                    @if (isEmail)
                    {
                        <div class="border rounded p-2 bg-white">@Html.Raw(preview.Body)</div>
                    }
                    else
                    {
                        <div class="border rounded p-2 bg-light small">@preview.Body</div>
                    }
                }
            </div>
        </div>
    </div>
</div>
