@model IReadOnlyList<Authly.Core.Entities.Announcement>
@{
    ViewData["Title"] = "Announcements";
    var now = DateTimeOffset.UtcNow;
}

<div class="page-title-head d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0">Announcements</h4>
    <a class="btn btn-primary btn-sm" asp-area="SuperAdmin" asp-controller="Announcements" asp-action="Create">
        <i data-lucide="plus" class="me-1"></i> New announcement
    </a>
</div>

<div class="card">
    <div class="card-body">
        @if (Model.Count == 0)
        {
            <p class="text-muted mb-0">No announcements. Create one to notify all tenant admins.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr><th>Title</th><th>Severity</th><th>Status</th><th>Expires</th><th></th></tr>
                    </thead>
                    <tbody>
                    @foreach (var a in Model)
                    {
                        var visible = a.IsVisible(now);
                        <tr>
                            <td class="fw-medium">@a.Title</td>
                            <td><span class="badge bg-@a.Severity">@a.Severity</span></td>
                            <td>
                                @if (visible)
                                {
                                    <span class="badge bg-success">Visible</span>
                                }
                                else
                                {
                                    <span class="badge bg-soft-secondary">Hidden</span>
                                }
                            </td>
                            <td class="text-muted small">@(a.ExpiresAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                            <td class="text-end">
                                <a class="btn btn-soft-secondary btn-sm" asp-area="SuperAdmin" asp-controller="Announcements" asp-action="Edit" asp-route-id="@a.Id">Edit</a>
                                <form class="d-inline" asp-area="SuperAdmin" asp-controller="Announcements" asp-action="Delete" asp-route-id="@a.Id" method="post"
                                      onsubmit="return confirm('Delete this announcement?');">
                                    <button type="submit" class="btn btn-soft-danger btn-sm">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
