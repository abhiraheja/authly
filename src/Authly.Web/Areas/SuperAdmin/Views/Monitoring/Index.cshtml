@using Authly.Core.Compliance
@using Authly.Core.Entities
@using Authly.Core.Monitoring
@{
    ViewData["Title"] = "Monitoring";
    var health = (HealthReport)ViewBag.Health;
    var metrics = (InstanceMetrics)ViewBag.Metrics;
    var analytics = (IReadOnlyList<DailyLoginStat>)ViewBag.Analytics;
    var instances = (IReadOnlyList<SelfHostedInstance>)ViewBag.Instances;
    var maxDay = analytics.Count == 0 ? 1 : Math.Max(1, analytics.Max(d => d.Successes + d.Failures));
}

<div class="page-title-head mb-3">
    <h4 class="mb-0">Monitoring &amp; health</h4>
</div>

<!-- Health -->
<div class="row g-3 mb-1">
    @foreach (var dep in health.Dependencies)
    {
        <div class="col-sm-6 col-lg-3">
            <div class="card mb-0">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div class="text-muted small">@dep.Name</div>
                        <h5 class="mb-0">
                            <span class="badge bg-@(dep.Healthy ? "success" : "danger")">@(dep.Healthy ? "Healthy" : "Down")</span>
                        </h5>
                        <div class="text-muted small mt-1">@dep.LatencyMs ms@(dep.Detail is null ? "" : $" · {dep.Detail}")</div>
                    </div>
                    <i data-lucide="@(dep.Healthy ? "heart-pulse" : "alert-octagon")"></i>
                </div>
            </div>
        </div>
    }
    <div class="col-sm-6 col-lg-3">
        <div class="card mb-0">
            <div class="card-body">
                <div class="text-muted small">Version</div>
                <h5 class="mb-0">@ViewBag.Version</h5>
                <div class="text-muted small mt-1">@ViewBag.DeploymentMode</div>
            </div>
        </div>
    </div>
</div>

<!-- Aggregate metrics -->
<div class="row g-3 my-1">
    @{
        var cards = new (string Label, int Value, string Icon)[]
        {
            ("Tenants", metrics.TenantCount, "building-2"),
            ("Users", metrics.UserCount, "users"),
            ("Applications", metrics.AppCount, "app-window"),
            ("Active sessions", metrics.ActiveSessionCount, "activity"),
        };
    }
    @foreach (var c in cards)
    {
        <div class="col-6 col-lg-3">
            <div class="card mb-0">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div class="text-muted small">@c.Label</div>
                        <h4 class="mb-0">@c.Value</h4>
                    </div>
                    <span class="avatar-sm"><span class="avatar-title bg-soft-primary"><i data-lucide="@c.Icon"></i></span></span>
                </div>
            </div>
        </div>
    }
</div>

<div class="row g-3 my-1">
    <!-- Login analytics -->
    <div class="col-lg-7">
        <div class="card mb-0 h-100">
            <div class="card-header d-flex justify-content-between">
                <span>Login analytics (last 14 days)</span>
                <span class="small text-muted">success / failed</span>
            </div>
            <div class="card-body">
                <table class="table table-sm align-middle mb-0">
                    <tbody>
                    @foreach (var d in analytics)
                    {
                        var total = d.Successes + d.Failures;
                        var okPct = (int)Math.Round(100.0 * d.Successes / maxDay);
                        var failPct = (int)Math.Round(100.0 * d.Failures / maxDay);
                        <tr>
                            <td class="text-muted small" style="width:6rem;">@d.Day.ToString("MMM dd")</td>
                            <td>
                                <div class="progress" style="height:14px;background:transparent;">
                                    <div class="progress-bar bg-success" style="width:@okPct%"></div>
                                    <div class="progress-bar bg-danger" style="width:@failPct%"></div>
                                </div>
                            </td>
                            <td class="text-end small" style="width:6rem;">
                                <span class="text-success">@d.Successes</span> / <span class="text-danger">@d.Failures</span>
                            </td>
                        </tr>
                    }
                    @if (analytics.Sum(a => a.Successes + a.Failures) == 0)
                    {
                        <tr><td colspan="3" class="text-muted">No login activity in the window.</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Ops / backup / deprecation -->
    <div class="col-lg-5">
        <div class="card mb-0 h-100">
            <div class="card-header">Platform ops</div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    <dt class="col-5">Backup status</dt>
                    <dd class="col-7">@(string.IsNullOrWhiteSpace((string?)ViewBag.BackupStatus) ? "Not reported" : ViewBag.BackupStatus)</dd>
                    <dt class="col-5">Last backup</dt>
                    <dd class="col-7">@(string.IsNullOrWhiteSpace((string?)ViewBag.BackupLastAt) ? "—" : ViewBag.BackupLastAt)</dd>
                    <dt class="col-5">Deprecation</dt>
                    <dd class="col-7">@(string.IsNullOrWhiteSpace((string?)ViewBag.DeprecationNotice) ? "None" : ViewBag.DeprecationNotice)</dd>
                </dl>
                <hr />
                <a href="/hangfire" target="_blank" class="btn btn-soft-secondary btn-sm">
                    <i data-lucide="timer" class="me-1"></i> Background jobs dashboard
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Self-hosted telemetry -->
<div class="card mt-3 mb-0">
    <div class="card-header">Self-hosted instance telemetry</div>
    <div class="card-body">
        @if (instances.Count == 0)
        {
            <p class="text-muted mb-0">No self-hosted instances have registered.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr><th>Name</th><th>Version</th><th>Tenants</th><th>Users</th><th>Apps</th><th>Last seen</th></tr>
                    </thead>
                    <tbody>
                    @foreach (var i in instances)
                    {
                        <tr>
                            <td class="fw-medium">@(string.IsNullOrWhiteSpace(i.Name) ? "—" : i.Name)</td>
                            <td>@(i.Version ?? "—")</td>
                            <td>@i.TenantCount</td>
                            <td>@i.UserCount</td>
                            <td>@i.AppCount</td>
                            <td class="text-muted small">@(i.LastSeenAt?.ToString("yyyy-MM-dd HH:mm") ?? "never")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
