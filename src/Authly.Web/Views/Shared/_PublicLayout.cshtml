@{
    var active = (ViewData["NavActive"] as string) ?? "";
    string nav(string key) => active == key ? "text-foreground" : "text-muted-foreground hover:text-foreground";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Authly</title>
    <meta name="description" content="@(ViewData["Description"] ?? "Authly — open-source, self-hostable identity infrastructure: OAuth2/OIDC, passkeys, MFA, RBAC, multi-tenant, webhooks. Self-host with Docker.")" />
    <script>try { if (localStorage.getItem("authly-theme") === "dark") document.documentElement.classList.add("dark"); } catch (e) { }</script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="~/css/saarvix.css" asp-append-version="true" />
</head>
<body class="min-h-screen flex flex-col">
    <header class="h-16 flex items-center border-b border-border glass sticky top-0 z-30">
        <nav class="mx-auto max-w-7xl w-full px-4 sm:px-6 flex items-center gap-6">
            <a class="flex items-center gap-2.5 font-display font-bold" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="grid place-items-center size-8 rounded-lg bg-primary text-primary-foreground"><i data-lucide="shield-check" class="size-4"></i></span>
                Authly
            </a>

            <div class="hidden md:flex items-center gap-6 text-sm font-medium ml-2">
                <a class="@nav("features")" asp-area="" asp-controller="Home" asp-action="Features">Features</a>
                <a class="@nav("docs")" href="/docs">Docs</a>
                <a class="@nav("selfhost")" asp-area="" asp-controller="Home" asp-action="SelfHost">Self-Host</a>
                <a class="@nav("")" href="@Authly.Web.SiteInfo.GitHubUrl" target="_blank" rel="noopener">GitHub</a>
            </div>

            <div class="flex items-center gap-2 ml-auto">
                <button type="button" class="btn btn-ghost btn-icon btn-sm" aria-label="Toggle theme" onclick="(function(){var d=document.documentElement.classList.toggle('dark');try{localStorage.setItem('authly-theme',d?'dark':'light')}catch(e){}})()">
                    <i data-lucide="sun-moon" class="size-4"></i>
                </button>
                <a class="btn btn-ghost btn-sm hidden sm:inline-flex" asp-area="TenantAdmin" asp-controller="Account" asp-action="Login">Admin sign in</a>
                <a class="btn btn-primary btn-sm" asp-area="" asp-controller="Signup" asp-action="Index">Get started</a>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-1">
        @RenderBody()
    </main>

    <footer class="border-t border-border bg-muted/30">
        <div class="mx-auto max-w-7xl w-full px-4 sm:px-6 py-12">
            <div class="grid gap-8 md:grid-cols-[1.5fr_1fr_1fr_1fr]">
                <div>
                    <a class="flex items-center gap-2.5 font-display font-bold" asp-area="" asp-controller="Home" asp-action="Index">
                        <span class="grid place-items-center size-8 rounded-lg bg-primary text-primary-foreground"><i data-lucide="shield-check" class="size-4"></i></span>
                        Authly
                    </a>
                    <p class="mt-3 text-sm text-muted-foreground max-w-xs">@Authly.Web.SiteInfo.Tagline</p>
                    <p class="mt-4 text-xs text-muted-foreground">Developed by <span class="font-medium text-foreground">@Authly.Web.SiteInfo.Author</span></p>
                </div>
                <div>
                    <div class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Product</div>
                    <ul class="mt-3 space-y-2 text-sm">
                        <li><a class="text-muted-foreground hover:text-foreground" asp-area="" asp-controller="Home" asp-action="Features">Features</a></li>
                        <li><a class="text-muted-foreground hover:text-foreground" asp-area="" asp-controller="Home" asp-action="SelfHost">Self-host</a></li>
                        <li><a class="text-muted-foreground hover:text-foreground" asp-area="" asp-controller="Signup" asp-action="Index">Create a workspace</a></li>
                        <li><a class="text-muted-foreground hover:text-foreground" asp-area="TenantAdmin" asp-controller="Account" asp-action="Login">Admin sign in</a></li>
                    </ul>
                </div>
                <div>
                    <div class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Docs</div>
                    <ul class="mt-3 space-y-2 text-sm">
                        <li><a class="text-muted-foreground hover:text-foreground" href="/docs/quickstart">Quickstart</a></li>
                        <li><a class="text-muted-foreground hover:text-foreground" href="/docs/oauth">OAuth &amp; OIDC</a></li>
                        <li><a class="text-muted-foreground hover:text-foreground" href="/docs/api">Management API</a></li>
                        <li><a class="text-muted-foreground hover:text-foreground" href="/docs/webhooks">Webhooks</a></li>
                    </ul>
                </div>
                <div>
                    <div class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Open source</div>
                    <ul class="mt-3 space-y-2 text-sm">
                        <li><a class="text-muted-foreground hover:text-foreground" href="@Authly.Web.SiteInfo.GitHubUrl" target="_blank" rel="noopener">GitHub</a></li>
                        <li><a class="text-muted-foreground hover:text-foreground" href="/docs/self-host">Docker install</a></li>
                        <li><a class="text-muted-foreground hover:text-foreground" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                    </ul>
                </div>
            </div>
            <div class="mt-10 pt-6 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-muted-foreground">
                <div>&copy; @DateTime.UtcNow.Year Authly · @Authly.Web.SiteInfo.License</div>
                <div class="flex items-center gap-1.5"><i data-lucide="git-branch" class="size-3.5"></i> Built with .NET 10 · OpenIddict · PostgreSQL · Redis</div>
            </div>
        </div>
    </footer>

    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    <script src="~/js/saarvix-app.js" asp-append-version="true"></script>
    <script>lucide.createIcons();</script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
