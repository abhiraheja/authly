@model IReadOnlyList<TemplateListItem>
@{
    var synced = ViewData["Synced"] as IReadOnlyList<Authly.Core.Messaging.WhatsAppRemoteTemplate>;
    var waKeys = WhatsAppTemplateSpecs.All;
}

<div class="flex items-center justify-between gap-3">
    <div>
        <h1 class="font-display text-xl font-bold">Message templates</h1>
        <p class="text-sm text-muted-foreground mt-0.5">Customize the email and WhatsApp messages Authly sends.</p>
    </div>
    <div class="flex items-center gap-2">
        <form asp-area="TenantAdmin" asp-controller="Messaging" asp-action="SyncTemplates" method="post" class="m-0">
            <button type="submit" class="btn btn-outline btn-sm" title="Pull approved WhatsApp templates from MSG91">
                <i data-lucide="refresh-cw" class="size-4"></i> Sync from MSG91
            </button>
        </form>
        <a class="btn btn-outline btn-sm" asp-area="TenantAdmin" asp-controller="Messaging" asp-action="Index">
            <i data-lucide="arrow-left" class="size-4"></i> Back to messaging
        </a>
    </div>
</div>

@if (synced is not null)
{
    <div class="card mt-4 border-l-4 border-l-primary">
        <div class="card-header"><span class="card-title">WhatsApp templates at MSG91</span></div>
        <div class="card-body">
            @if (synced.Count == 0)
            {
                <p class="text-sm text-muted-foreground">No templates found for this number. Create one in MSG91 first, then sync again.</p>
            }
            else
            {
                <p class="text-sm text-muted-foreground mb-3">Bind an <strong>approved</strong> template to the Authly message key that should use it. The variable count must match the key's expected parameters.</p>
                <div class="overflow-x-auto scroll-thin">
                    <table class="table">
                        <thead><tr><th>Template</th><th>Language</th><th>Category</th><th>Status</th><th>Vars</th><th>Bind to key</th></tr></thead>
                        <tbody>
                        @foreach (var s in synced)
                        {
                            var approved = string.Equals(s.Status, "APPROVED", StringComparison.OrdinalIgnoreCase);
                            <tr>
                                <td class="font-medium"><code>@s.Name</code>@if (!string.IsNullOrEmpty(s.BodyText)) { <div class="text-xs text-muted-foreground max-w-md truncate" title="@s.BodyText">@s.BodyText</div> }</td>
                                <td>@s.Language</td>
                                <td><span class="badge badge-neutral">@s.Category</span></td>
                                <td>@if (approved) { <span class="badge badge-success">@s.Status</span> } else { <span class="badge badge-warning">@s.Status</span> }</td>
                                <td>@s.VariableCount</td>
                                <td>
                                    @if (approved)
                                    {
                                        <form asp-area="TenantAdmin" asp-controller="Messaging" asp-action="BindTemplate" method="post" class="flex gap-1 m-0">
                                            <input type="hidden" name="providerTemplateName" value="@s.Name" />
                                            <input type="hidden" name="providerLanguage" value="@s.Language" />
                                            <input type="hidden" name="locale" value="en" />
                                            <select name="key" class="select select-sm">
                                                @foreach (var spec in waKeys)
                                                {
                                                    <option value="@spec.Key">@spec.Key (@spec.Parameters.Count var)</option>
                                                }
                                            </select>
                                            <button type="submit" class="btn btn-primary btn-sm">Bind</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-xs text-muted-foreground">not approved</span>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

<div class="card mt-4">
    <div class="card-body">
        <div class="overflow-x-auto scroll-thin">
            <table class="table">
                <thead>
                    <tr><th>Template</th><th>Channel</th><th>Locale</th><th>Source</th><th></th></tr>
                </thead>
                <tbody>
                @foreach (var t in Model)
                {
                    <tr>
                        <td class="font-medium"><code>@t.Key</code><div class="text-xs text-muted-foreground">@t.Subject</div></td>
                        <td>@t.Channel</td>
                        <td>@t.Locale</td>
                        <td>
                            @if (t.IsOverride) { <span class="badge badge-primary">custom</span> }
                            else { <span class="badge badge-neutral">built-in</span> }
                        </td>
                        <td class="text-right">
                            <div class="flex gap-2 justify-end items-center">
                                <form asp-area="TenantAdmin" asp-controller="Messaging" asp-action="SendTest" method="post" class="flex gap-1">
                                    <input type="hidden" name="key" value="@t.Key" />
                                    <input type="hidden" name="channel" value="@t.Channel" />
                                    <input type="text" name="recipient" class="input input-sm" style="width:170px"
                                           placeholder="@(t.Channel == MessageChannel.Email ? "test@addr" : "phone")" />
                                    <button type="submit" class="btn btn-outline btn-sm" title="Send test">Test</button>
                                </form>
                                <a class="btn btn-primary btn-sm"
                                   asp-area="TenantAdmin" asp-controller="Messaging" asp-action="EditTemplate"
                                   asp-route-key="@t.Key" asp-route-channel="@t.Channel" asp-route-locale="@t.Locale">Edit</a>
                                @if (t.IsOverride && t.Id is { } id)
                                {
                                    <form asp-area="TenantAdmin" asp-controller="Messaging" asp-action="DeleteTemplate" asp-route-id="@id" method="post"
                                          onsubmit="return confirm('Reset this template to the built-in default?');">
                                        <button type="submit" class="btn btn-danger btn-sm">Reset</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
