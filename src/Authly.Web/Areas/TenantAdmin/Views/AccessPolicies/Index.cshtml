@using Authly.Modules.Abac
@model IReadOnlyList<Authly.Core.Entities.AccessPolicy>
@{
    var test = ViewBag.Test as AccessPolicyTestViewModel ?? new AccessPolicyTestViewModel();
    var result = ViewBag.TestResult as AccessDecision;
}

<div class="flex items-center justify-between gap-3">
    <h1 class="font-display text-xl font-bold">Access policies</h1>
    <a class="btn btn-primary btn-sm" asp-area="TenantAdmin" asp-controller="AccessPolicies" asp-action="Create">
        <i data-lucide="plus" class="size-4"></i> New policy
    </a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
    <div class="lg:col-span-7">
        <div class="card">
            <div class="card-header"><h6 class="card-title">Policies <span class="text-muted-foreground text-sm font-normal">(deny overrides; default deny)</span></h6></div>
            @if (Model.Count == 0)
            {
                <div class="card-body">
                    <p class="text-muted-foreground mb-0">No policies yet. Without policies, every request is denied by default.</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto scroll-thin">
                    <table class="table">
                        <thead>
                            <tr><th>Name</th><th>Effect</th><th>Action</th><th>Resource</th><th>Prio</th><th class="text-right"></th></tr>
                        </thead>
                        <tbody>
                        @foreach (var p in Model)
                        {
                            <tr class="@(p.Enabled ? "" : "opacity-50")">
                                <td class="font-medium">@p.Name</td>
                                <td><span class="badge @(p.Effect == "deny" ? "badge-danger" : "badge-success")">@p.Effect</span></td>
                                <td><code>@p.Action</code></td>
                                <td><code>@p.ResourceType</code></td>
                                <td>@p.Priority</td>
                                <td class="text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <a class="btn btn-outline btn-sm" asp-area="TenantAdmin" asp-controller="AccessPolicies" asp-action="Edit" asp-route-id="@p.Id">Edit</a>
                                        <form asp-area="TenantAdmin" asp-controller="AccessPolicies" asp-action="Delete" asp-route-id="@p.Id" method="post"
                                              onsubmit="return confirm('Delete this policy?');">
                                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="lg:col-span-5">
        <div class="card">
            <div class="card-header"><h6 class="card-title">Test a decision</h6></div>
            <div class="card-body">
                <form asp-area="TenantAdmin" asp-controller="AccessPolicies" asp-action="Test" method="post" class="space-y-2">
                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label class="label text-sm mb-1">Action</label>
                            <input name="Action" value="@test.Action" class="input input-sm" placeholder="document.read" />
                        </div>
                        <div>
                            <label class="label text-sm mb-1">Resource type</label>
                            <input name="ResourceType" value="@test.ResourceType" class="input input-sm" placeholder="document" />
                        </div>
                    </div>
                    <div>
                        <label class="label text-sm mb-1">Subject attributes</label>
                        <textarea name="SubjectJson" class="textarea font-monospace" rows="2">@test.SubjectJson</textarea>
                    </div>
                    <div>
                        <label class="label text-sm mb-1">Resource attributes</label>
                        <textarea name="ResourceJson" class="textarea font-monospace" rows="2">@test.ResourceJson</textarea>
                    </div>
                    <div>
                        <label class="label text-sm mb-1">Environment attributes</label>
                        <textarea name="EnvironmentJson" class="textarea font-monospace" rows="2">@test.EnvironmentJson</textarea>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm">Evaluate</button>
                </form>

                @if (result is not null)
                {
                    <hr class="my-4 border-border" />
                    <div class="card card-body !py-3 flex items-center gap-3 border-l-4 @(result.Allowed ? "border-l-success" : "border-l-danger") text-sm">
                        <i data-lucide="@(result.Allowed ? "check-circle-2" : "alert-circle")" class="size-4 @(result.Allowed ? "text-success" : "text-coral")"></i>
                        <div>
                            <strong>@(result.Allowed ? "ALLOW" : "DENY")</strong>
                            — @result.Reason@(result.PolicyName is null ? "" : $" · {result.PolicyName}")
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
