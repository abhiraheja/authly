@model TemplateInput
@{
    var isEmail = Model.Channel == MessageChannel.Email;
    var preview = ViewData["Preview"] as RenderedPreview;
}

<div class="flex items-center justify-between gap-3">
    <div>
        <h1 class="font-display text-xl font-bold">Edit template — <code>@Model.Key</code></h1>
        <p class="text-sm text-muted-foreground mt-0.5">@Model.Channel · @Model.Locale</p>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-4 mt-4">
    <div class="lg:col-span-7">
        <div class="card">
            <div class="card-body">
                <form asp-area="TenantAdmin" asp-controller="Messaging" asp-action="SaveTemplate" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Key" />
                    <input type="hidden" asp-for="Channel" />
                    <input type="hidden" asp-for="Locale" />

                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

                    @if (isEmail)
                    {
                        <div class="mb-3">
                            <label asp-for="Subject" class="label">Subject</label>
                            <input asp-for="Subject" class="input" />
                        </div>
                    }
                    <div class="mb-3">
                        <label asp-for="Body" class="label">Body @(isEmail ? "(HTML)" : "(text)")</label>
                        <textarea asp-for="Body" class="textarea font-mono" rows="12"></textarea>
                        <span asp-validation-for="Body" class="text-danger text-xs"></span>
                    </div>
                    <div class="flex items-center gap-2 mb-3">
                        <label class="switch"><input asp-for="IsActive" type="checkbox" id="isActive" /><span class="track"></span></label>
                        <span>Active</span>
                    </div>

                    <div class="flex gap-2">
                        <button type="submit" name="action" value="save" class="btn btn-primary">Save</button>
                        <button type="submit" name="action" value="preview" class="btn btn-outline">Preview</button>
                        <a class="btn btn-ghost" asp-area="TenantAdmin" asp-controller="Messaging" asp-action="Templates">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="lg:col-span-5">
        <div class="card">
            <div class="card-body">
                <h6 class="mb-2 font-semibold">Available variables</h6>
                <p class="text-sm text-muted-foreground">Insert with <code>{{'{{'}}variable{{'}}'}}</code>. Common ones:</p>
                <div class="text-sm font-mono">
                    {{app_name}} · {{user_name}} · {{action_url}} · {{otp}} · {{expiry_hours}} · {{expiry_minutes}}
                </div>
                @if (preview is not null)
                {
                    <hr class="my-4 border-border" />
                    <h6 class="mb-2 font-semibold">Preview</h6>
                    @if (preview.Subject is not null)
                    {
                        <div class="text-sm text-muted-foreground mb-1">Subject: <strong>@preview.Subject</strong></div>
                    }
                    @if (isEmail)
                    {
                        <div class="border border-border rounded p-2 bg-background">@Html.Raw(preview.Body)</div>
                    }
                    else
                    {
                        <div class="border border-border rounded p-2 bg-muted text-sm">@preview.Body</div>
                    }
                }
            </div>
        </div>
    </div>
</div>
