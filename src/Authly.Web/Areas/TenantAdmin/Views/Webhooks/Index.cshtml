@{
    var endpoints = ViewData["Endpoints"] as IReadOnlyList<WebhookEndpoint> ?? new List<WebhookEndpoint>();
    var deliveries = ViewData["Deliveries"] as IReadOnlyList<WebhookDelivery> ?? new List<WebhookDelivery>();

    static string StatusBadge(WebhookDeliveryStatus s) => s switch
    {
        WebhookDeliveryStatus.Success => "badge-success",
        WebhookDeliveryStatus.Failed => "badge-danger",
        _ => "badge-warning"
    };
}

<div class="flex items-center justify-between gap-3">
    <div>
        <h1 class="font-display text-xl font-bold">Webhooks</h1>
        <p class="text-sm text-muted-foreground mt-0.5">Signed event deliveries to your HTTPS endpoints.</p>
    </div>
    <a class="btn btn-sm btn-primary" asp-area="TenantAdmin" asp-controller="Webhooks" asp-action="Edit">
        <i data-lucide="plus" class="size-4"></i> Add endpoint
    </a>
</div>

<div class="card mt-4 mb-4">
    <div class="card-body">
        <h6 class="mb-3 font-semibold">Endpoints</h6>
        @if (endpoints.Count == 0)
        {
            <p class="text-muted-foreground mb-0">No webhook endpoints yet. Add one to start receiving signed event deliveries.</p>
        }
        else
        {
            <div class="overflow-x-auto scroll-thin">
                <table class="table">
                    <thead><tr><th>URL</th><th>Events</th><th>Status</th><th class="text-right">Actions</th></tr></thead>
                    <tbody>
                    @foreach (var e in endpoints)
                    {
                        <tr>
                            <td class="break-all">@e.Url</td>
                            <td><span class="text-sm text-muted-foreground">@string.Join(", ", e.Events)</span></td>
                            <td>@(e.IsActive ? "active" : "inactive")</td>
                            <td class="text-right">
                                <form class="inline" asp-area="TenantAdmin" asp-controller="Webhooks" asp-action="Test" asp-route-id="@e.Id" method="post">
                                    <button type="submit" class="btn btn-sm btn-outline">Send test</button>
                                </form>
                                <a class="btn btn-sm btn-primary" asp-area="TenantAdmin" asp-controller="Webhooks" asp-action="Edit" asp-route-id="@e.Id">Edit</a>
                                <form class="inline" asp-area="TenantAdmin" asp-controller="Webhooks" asp-action="Delete" asp-route-id="@e.Id" method="post"
                                      onsubmit="return confirm('Remove this endpoint?');">
                                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h6 class="mb-3 font-semibold">Recent deliveries</h6>
        @if (deliveries.Count == 0)
        {
            <p class="text-muted-foreground mb-0">No deliveries yet.</p>
        }
        else
        {
            <div class="overflow-x-auto scroll-thin">
                <table class="table">
                    <thead><tr><th>Event</th><th>Status</th><th>Attempts</th><th>HTTP</th><th>When</th><th class="text-right"></th></tr></thead>
                    <tbody>
                    @foreach (var d in deliveries)
                    {
                        <tr>
                            <td class="font-medium">@d.Event</td>
                            <td><span class="badge @StatusBadge(d.Status)">@d.Status.ToString().ToLowerInvariant()</span></td>
                            <td>@d.Attempts</td>
                            <td>@(d.ResponseCode?.ToString() ?? "—")</td>
                            <td class="text-sm text-muted-foreground">@d.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="text-right">
                                @if (d.Status != WebhookDeliveryStatus.Success)
                                {
                                    <form class="inline" asp-area="TenantAdmin" asp-controller="Webhooks" asp-action="Retry" asp-route-deliveryId="@d.Id" method="post">
                                        <button type="submit" class="btn btn-sm btn-primary">Retry</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
