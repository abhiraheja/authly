@model SecuritySettingsViewModel
@{
    Layout = "_AdminLayout";
}

<div>
    <h1 class="font-display text-xl font-bold">Security</h1>
</div>

<form asp-area="TenantAdmin" asp-controller="Security" asp-action="Index" method="post" class="mt-4">
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <div class="space-y-4">
            <div class="card" id="signinMethods">
                <div class="card-header"><h2 class="card-title">Sign-in methods</h2></div>
                <div class="card-body space-y-4">
                    <p class="-mt-1 text-xs text-muted-foreground">Choose which sign-in options the hosted login page offers. At least one working method must stay enabled.</p>
                    <div class="flex items-center gap-3">
                        <label class="switch"><input asp-for="AllowPasswordLogin" type="checkbox" data-signin-method /><span class="track"></span></label>
                        <label class="label !mb-0" asp-for="AllowPasswordLogin"></label>
                    </div>
                    <div class="flex items-center gap-3">
                        <label class="switch"><input asp-for="AllowMagicLinkLogin" type="checkbox" data-signin-method /><span class="track"></span></label>
                        <label class="label !mb-0" asp-for="AllowMagicLinkLogin"></label>
                    </div>
                    <div class="flex items-center gap-3">
                        <label class="switch"><input asp-for="AllowPasskeyLogin" type="checkbox" data-signin-method /><span class="track"></span></label>
                        <label class="label !mb-0" asp-for="AllowPasskeyLogin"></label>
                    </div>
                    <div class="flex items-center gap-3">
                        <label class="switch"><input asp-for="AllowSocialLogin" type="checkbox" data-signin-method disabled="@(!Model.HasSocialProvider ? "disabled" : null)" /><span class="track"></span></label>
                        <label class="label !mb-0" asp-for="AllowSocialLogin"></label>
                    </div>
                    @if (!Model.HasSocialProvider)
                    {
                        <p class="-mt-2 text-xs text-muted-foreground">Add a <a class="text-primary underline" asp-area="TenantAdmin" asp-controller="SocialProviders" asp-action="Index">social provider</a> to enable social sign-in.</p>
                    }
                    <div class="flex items-center gap-3">
                        <label class="switch"><input asp-for="AllowPhoneLogin" type="checkbox" data-signin-method disabled="@(!Model.WhatsAppOtpReady ? "disabled" : null)" /><span class="track"></span></label>
                        <label class="label !mb-0" asp-for="AllowPhoneLogin"></label>
                    </div>
                    @if (!Model.WhatsAppOtpReady)
                    {
                        <p class="-mt-2 text-xs text-muted-foreground"><a class="text-primary underline" asp-area="TenantAdmin" asp-controller="WhatsApp" asp-action="Index">Configure WhatsApp + link the OTP template</a> to enable phone sign-in.</p>
                    }
                </div>
            </div>

            <div class="card">
                <div class="card-header"><h2 class="card-title">Sign-up policy</h2></div>
                <div class="card-body space-y-4">
                    <div class="flex items-center gap-3">
                        <label class="switch"><input asp-for="AllowPasswordSignup" type="checkbox" /><span class="track"></span></label>
                        <label class="label !mb-0" asp-for="AllowPasswordSignup"></label>
                    </div>
                    <p class="-mt-2 text-xs text-muted-foreground">When off, the hosted register page is closed. Only accounts you create (dashboard, import, or API) can sign in.</p>
                    <div class="flex items-center gap-3">
                        <label class="switch"><input asp-for="AllowSocialSignup" type="checkbox" /><span class="track"></span></label>
                        <label class="label !mb-0" asp-for="AllowSocialSignup"></label>
                    </div>
                    <p class="-mt-2 text-xs text-muted-foreground">When off, social login still signs in (and links to) existing accounts, but won't create a brand-new account from a social identity.</p>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><h2 class="card-title">Phone authentication (WhatsApp)</h2></div>
                <div class="card-body space-y-4">
                    @if (!Model.WhatsAppOtpReady)
                    {
                        <div class="rounded bg-muted p-2 text-xs flex items-start gap-1">
                            <i data-lucide="info" class="size-3.5 mt-0.5 shrink-0"></i>
                            <span>
                                To enable phone sign-up, first
                                <a class="text-primary underline" asp-area="TenantAdmin" asp-controller="WhatsApp" asp-action="Index">configure WhatsApp and link the OTP template</a>.
                            </span>
                        </div>
                    }
                    <div class="flex items-center gap-3">
                        <label class="switch"><input asp-for="AllowPhoneSignup" type="checkbox" disabled="@(!Model.WhatsAppOtpReady ? "disabled" : null)" /><span class="track"></span></label>
                        <label class="label !mb-0" asp-for="AllowPhoneSignup"></label>
                    </div>
                    <p class="-mt-2 text-xs text-muted-foreground">Users sign up with a mobile number; the verification code is delivered via your linked WhatsApp OTP template. (Phone sign-in is enabled under <a class="text-primary underline" href="#signinMethods">Sign-in methods</a>.)</p>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><h2 class="card-title">Brute-force &amp; passwords</h2></div>
                <div class="card-body space-y-4">
                    <div class="flex items-center gap-3">
                        <label class="switch"><input asp-for="LockoutEnabled" type="checkbox" /><span class="track"></span></label>
                        <label class="label !mb-0" asp-for="LockoutEnabled"></label>
                    </div>
                    <div>
                        <label asp-for="LockoutThreshold" class="label"></label>
                        <input asp-for="LockoutThreshold" class="input" type="number" min="3" max="20" />
                        <p class="mt-1 text-xs text-muted-foreground">Lockout uses exponential backoff (1m, 2m, 4m … capped at 1h).</p>
                    </div>
                    <div class="flex items-center gap-3">
                        <label class="switch"><input asp-for="BreachedPasswordCheck" type="checkbox" /><span class="track"></span></label>
                        <label class="label !mb-0" asp-for="BreachedPasswordCheck"></label>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><h2 class="card-title">Bot defence (CAPTCHA)</h2></div>
                <div class="card-body space-y-4">
                    <div class="flex items-center gap-3">
                        <label class="switch"><input asp-for="CaptchaEnabled" type="checkbox" /><span class="track"></span></label>
                        <label class="label !mb-0" asp-for="CaptchaEnabled"></label>
                    </div>
                    <div>
                        <label asp-for="CaptchaProvider" class="label"></label>
                        <select asp-for="CaptchaProvider" class="select">
                            <option value="hcaptcha">hCaptcha</option>
                            <option value="turnstile">Cloudflare Turnstile</option>
                        </select>
                    </div>
                    <div>
                        <label asp-for="CaptchaSiteKey" class="label"></label>
                        <input asp-for="CaptchaSiteKey" class="input" />
                    </div>
                    <div>
                        <label asp-for="CaptchaSecret" class="label"></label>
                        <input asp-for="CaptchaSecret" class="input" type="password"
                               placeholder="@(Model.HasCaptchaSecret ? "•••••••• (leave blank to keep)" : "")" />
                        <p class="mt-1 text-xs text-muted-foreground">Stored encrypted; write-only.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="space-y-4">
            <div class="card">
                <div class="card-header"><h2 class="card-title">Block &amp; allow lists</h2></div>
                <div class="card-body space-y-4">
                    <div class="flex items-center gap-3">
                        <label class="switch"><input asp-for="BlockDisposableEmails" type="checkbox" /><span class="track"></span></label>
                        <label class="label !mb-0" asp-for="BlockDisposableEmails"></label>
                    </div>
                    <div>
                        <label asp-for="BlockedEmailDomains" class="label"></label>
                        <textarea asp-for="BlockedEmailDomains" class="textarea" rows="3" placeholder="spam.example"></textarea>
                    </div>
                    <div>
                        <label asp-for="BlockedIps" class="label"></label>
                        <textarea asp-for="BlockedIps" class="textarea" rows="3" placeholder="203.0.113.0/24"></textarea>
                    </div>
                    <div>
                        <label asp-for="BlockedCountries" class="label"></label>
                        <textarea asp-for="BlockedCountries" class="textarea" rows="2" placeholder="KP&#10;RU"></textarea>
                        <p class="mt-1 text-xs text-muted-foreground">Country enforcement requires a geo-IP source (configured at deploy time).</p>
                    </div>
                    <div>
                        <label asp-for="AllowedIps" class="label"></label>
                        <textarea asp-for="AllowedIps" class="textarea" rows="2" placeholder="198.51.100.10"></textarea>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><h2 class="card-title">Conditional access (risk-based)</h2></div>
                <div class="card-body space-y-4">
                    <div class="flex items-center gap-3">
                        <label class="switch"><input asp-for="ConditionalAccessEnabled" type="checkbox" /><span class="track"></span></label>
                        <label class="label !mb-0" asp-for="ConditionalAccessEnabled"></label>
                    </div>
                    <div>
                        <label asp-for="NewDeviceAction" class="label"></label>
                        <select asp-for="NewDeviceAction" asp-items="Html.GetEnumSelectList<Authly.Modules.Security.ConditionalAction>()" class="select"></select>
                        <p class="mt-1 text-xs text-muted-foreground">Triggers when both the IP and device are unseen among the user's past sign-ins.</p>
                    </div>
                    <div>
                        <label asp-for="UnverifiedEmailAction" class="label"></label>
                        <select asp-for="UnverifiedEmailAction" asp-items="Html.GetEnumSelectList<Authly.Modules.Security.ConditionalAction>()" class="select"></select>
                        <p class="mt-1 text-xs text-muted-foreground"><strong>Require MFA</strong> steps up to a second factor (or enrollment); <strong>Block</strong> denies the sign-in.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary mt-4">Save security settings</button>
</form>

@section Scripts {
<script>
    // Client-side guard: don't let the admin turn off the last enabled sign-in method (the server
    // enforces this too). Only enabled, non-disabled switches count.
    (function () {
        var methods = Array.prototype.slice.call(document.querySelectorAll('[data-signin-method]'));
        function effective() { return methods.filter(function (m) { return !m.disabled && m.checked; }); }
        methods.forEach(function (m) {
            m.addEventListener('change', function () {
                if (!m.checked && effective().length === 0) {
                    m.checked = true;
                    alert('At least one sign-in method must remain enabled.');
                }
            });
        });
    })();
</script>
}
