@model SignupViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Create your workspace";
}

<h4 class="text-center mb-1">Create your workspace</h4>
<p class="text-center text-muted mb-4">Spin up your own Authly tenant and become its administrator.</p>

<form asp-controller="Signup" asp-action="Index" method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small @(ViewData.ModelState.IsValid ? "d-none" : "")"></div>

    <div class="mb-3">
        <label asp-for="CompanyName" class="form-label"></label>
        <input asp-for="CompanyName" class="form-control" placeholder="Acme Inc." autofocus />
        <span asp-validation-for="CompanyName" class="text-danger small"></span>
    </div>

    <div class="row">
        <div class="col-sm-6 mb-3">
            <label asp-for="FirstName" class="form-label"></label>
            <input asp-for="FirstName" class="form-control" autocomplete="given-name" />
            <span asp-validation-for="FirstName" class="text-danger small"></span>
        </div>
        <div class="col-sm-6 mb-3">
            <label asp-for="LastName" class="form-label"></label>
            <input asp-for="LastName" class="form-control" autocomplete="family-name" />
            <span asp-validation-for="LastName" class="text-danger small"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" autocomplete="username" placeholder="you@example.com" />
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label">Password</label>
        <input asp-for="Password" class="form-control" autocomplete="new-password" placeholder="At least 8 characters" />
        <span asp-validation-for="Password" class="text-danger small"></span>
    </div>

    <div class="mb-4">
        <label asp-for="ConfirmPassword" class="form-label"></label>
        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
    </div>

    <div class="d-grid">
        <button type="submit" class="btn btn-primary">Create workspace</button>
    </div>
</form>

<p class="text-center text-muted small mt-4 mb-0">
    Already have a workspace?
    <a asp-area="TenantAdmin" asp-controller="Account" asp-action="Login">Sign in</a>
</p>
