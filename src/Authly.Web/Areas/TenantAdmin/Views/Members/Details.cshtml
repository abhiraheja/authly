@model MemberRolesViewModel

<div class="flex items-center justify-between gap-3">
    <div class="flex items-center gap-3">
        <a class="btn btn-ghost btn-icon btn-sm" asp-area="TenantAdmin" asp-controller="Members" asp-action="Index" aria-label="Back"><i data-lucide="arrow-left" class="size-4"></i></a>
        <div>
            <h1 class="font-display text-xl font-bold">@Model.Email</h1>
            @if (!string.IsNullOrEmpty(Model.Name)) { <p class="text-sm text-muted-foreground mt-0.5">@Model.Name</p> }
        </div>
        @if (Model.IsOwner) { <span class="badge badge-primary">owner</span> }
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mt-4">
    <div>
        <div class="card">
            <div class="card-header"><h2 class="card-title">Assigned roles</h2></div>
            <div class="card-body">
                @if (Model.AssignedRoles.Count == 0)
                {
                    <p class="text-sm text-muted-foreground">No roles assigned.</p>
                }
                else
                {
                    <ul class="divide-y divide-border">
                    @foreach (var role in Model.AssignedRoles)
                    {
                        <li class="flex justify-between items-center py-2 first:pt-0 last:pb-0">
                            <span class="flex items-center gap-2"><code class="text-xs text-muted-foreground">@role.Name</code>
                                @if (role.IsSystem) { <span class="badge badge-neutral">system</span> }
                            </span>
                            <form asp-area="TenantAdmin" asp-controller="Members" asp-action="Remove"
                                  asp-route-id="@Model.MembershipId" method="post">
                                <input type="hidden" name="roleId" value="@role.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                            </form>
                        </li>
                    }
                    </ul>
                }
            </div>
        </div>
    </div>

    <div>
        <div class="card">
            <div class="card-header"><h2 class="card-title">Add a role</h2></div>
            <div class="card-body">
                @if (Model.AvailableRoles.Count == 0)
                {
                    <p class="text-sm text-muted-foreground">All roles are already assigned.</p>
                }
                else
                {
                    <form asp-area="TenantAdmin" asp-controller="Members" asp-action="Assign"
                          asp-route-id="@Model.MembershipId" method="post" class="flex gap-2">
                        <select name="roleId" class="select">
                            @foreach (var role in Model.AvailableRoles)
                            {
                                <option value="@role.Id">@role.Name</option>
                            }
                        </select>
                        <button type="submit" class="btn btn-primary">Assign</button>
                    </form>
                }
            </div>
        </div>

        <div class="card mt-4 border-l-4 border-l-danger">
            <div class="card-body">
                <h2 class="text-danger font-semibold">Remove member</h2>
                <p class="text-muted-foreground text-sm mt-1">Revokes this person's access to the organization's console.</p>
                <form asp-area="TenantAdmin" asp-controller="Members" asp-action="Delete" asp-route-id="@Model.MembershipId" method="post"
                      onsubmit="return confirm('Remove this member from the organization?');" class="mt-2">
                    <button type="submit" class="btn btn-danger btn-sm">Remove member</button>
                </form>
            </div>
        </div>
    </div>
</div>
