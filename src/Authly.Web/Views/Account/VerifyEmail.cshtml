@{
    Layout = "_AuthLayout";
    var verified = ViewData["Verified"] is true;
}

<div class="text-center">
    @if (verified)
    {
        <span class="logo-mark mb-3"><i data-lucide="badge-check"></i></span>
        <h5 class="mb-2">Email verified</h5>
        <p class="text-muted small mb-4">Your email address has been confirmed. You can now sign in.</p>
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-sm">Continue to sign in</a>
    }
    else
    {
        <span class="logo-mark mb-3"><i data-lucide="alert-triangle"></i></span>
        <h5 class="mb-2">Verification failed</h5>
        <p class="text-muted small mb-4">This verification link is invalid or has expired. Sign in to request a new one.</p>
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-sm">Back to sign in</a>
    }
</div>
