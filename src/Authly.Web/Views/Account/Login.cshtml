@model UserLoginViewModel
@{
    Layout = "_AuthLayout";
    var socialOptions = ViewData["SocialOptions"] as IReadOnlyList<Authly.Modules.Social.SocialLoginOption>
        ?? new List<Authly.Modules.Social.SocialLoginOption>();
}

<h2 class="font-display text-2xl font-bold">Welcome back</h2>
<p class="text-sm text-muted-foreground mt-1 mb-6">Sign in to your account.</p>

@if (TempData["Success"] is string success)
{
    <div class="card card-body !py-2.5 mb-4 flex items-center gap-2 border-l-4 border-l-success text-sm"><i data-lucide="check-circle-2" class="size-4 text-success"></i>@success</div>
}
@if (TempData["Error"] is string error)
{
    <div class="card card-body !py-2.5 mb-4 flex items-center gap-2 border-l-4 border-l-danger text-sm"><i data-lucide="alert-circle" class="size-4 text-coral"></i>@error</div>
}

@if (socialOptions.Count > 0)
{
    <div class="space-y-2 mb-4">
        @foreach (var opt in socialOptions)
        {
            <a class="btn btn-outline w-full" asp-controller="Social" asp-action="Start"
               asp-route-provider="@opt.Provider" asp-route-returnUrl="@Model.ReturnUrl">
                Continue with @opt.DisplayName
            </a>
        }
    </div>
    <div class="my-4 flex items-center gap-3"><div class="h-px flex-1 bg-border"></div><span class="text-xs text-muted-foreground">or</span><div class="h-px flex-1 bg-border"></div></div>
}

<form asp-controller="Account" asp-action="Login" method="post" class="space-y-4">
    <input type="hidden" asp-for="ReturnUrl" />
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

    <div>
        <label asp-for="Email" class="label">Email</label>
        <input asp-for="Email" class="input" autocomplete="username" placeholder="you@example.com" />
        <span asp-validation-for="Email" class="text-danger text-xs"></span>
    </div>

    <div>
        <label asp-for="Password" class="label">Password</label>
        <input asp-for="Password" class="input" autocomplete="current-password" placeholder="••••••••" />
        <span asp-validation-for="Password" class="text-danger text-xs"></span>
    </div>

    <div class="flex justify-end">
        <a asp-controller="Account" asp-action="ForgotPassword" class="text-sm text-primary hover:underline">Forgot password?</a>
    </div>

    <partial name="_Captcha" />

    <button type="submit" class="btn btn-primary w-full">Sign in</button>
</form>

<div class="my-4 flex items-center gap-3"><div class="h-px flex-1 bg-border"></div><span class="text-xs text-muted-foreground">or</span><div class="h-px flex-1 bg-border"></div></div>

@Html.AntiForgeryToken()
<div class="space-y-2">
    <button type="button" id="passkeyBtn" class="btn btn-outline w-full">
        <i data-lucide="key-round" class="size-4"></i> Sign in with a passkey
    </button>
    <a class="btn btn-outline w-full" asp-controller="Account" asp-action="MagicLink">
        <i data-lucide="mail" class="size-4"></i> Email me a sign-in link
    </a>
</div>
<div id="passkeyError" class="text-danger text-xs text-center mt-2 hidden"></div>

<p class="text-center text-sm text-muted-foreground mt-6">
    Don't have an account? <a class="text-primary hover:underline" asp-controller="Account" asp-action="Register">Create one</a>
</p>
<p class="text-center text-sm text-muted-foreground">
    <a class="text-primary hover:underline" asp-controller="Account" asp-action="RecoverRequest">Can't access your account?</a>
</p>

@section Scripts {
<script src="~/js/authly-webauthn.js" asp-append-version="true"></script>
<script>
    document.getElementById('passkeyBtn')?.addEventListener('click', function () {
        const email = document.querySelector('[name="Email"]').value.trim();
        const err = document.getElementById('passkeyError');
        err.classList.add('hidden');
        if (!email) { err.textContent = 'Enter your email first, then use your passkey.'; err.classList.remove('hidden'); return; }
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        authlyPasskeyLogin(email, token, function (msg) { err.textContent = msg; err.classList.remove('hidden'); });
    });
</script>
}
