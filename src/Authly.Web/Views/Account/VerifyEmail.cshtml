@{
    Layout = "_AuthLayout";
    var verified = ViewData["Verified"] is true;
}

<div class="text-center">
    @if (verified)
    {
        <span class="logo-mark mb-3"><i data-lucide="badge-check"></i></span>
        <h2 class="font-display text-2xl font-bold">Email verified</h2>
        <p class="text-sm text-muted-foreground mt-1 mb-6">Your email address has been confirmed. You can now sign in.</p>
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary w-full">Continue to sign in</a>
    }
    else
    {
        <span class="logo-mark mb-3"><i data-lucide="alert-triangle"></i></span>
        <h2 class="font-display text-2xl font-bold">Verification failed</h2>
        <p class="text-sm text-muted-foreground mt-1 mb-6">This verification link is invalid or has expired. Sign in to request a new one.</p>
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline w-full">Back to sign in</a>
    }
</div>
