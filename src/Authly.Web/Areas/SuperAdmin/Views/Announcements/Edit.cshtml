@model AnnouncementViewModel
@{
    ViewData["Title"] = Model.Id is null ? "New announcement" : "Edit announcement";
}

<div class="page-title-head mb-3">
    <h4 class="mb-0">@ViewData["Title"]</h4>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 @(ViewData.ModelState.IsValid ? "d-none" : "")"></div>
                <form asp-area="SuperAdmin" asp-controller="Announcements" asp-action="Save" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Body" class="form-label"></label>
                        <textarea asp-for="Body" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Body" class="text-danger small"></span>
                    </div>
                    <div class="row">
                        <div class="col-sm-6 mb-3">
                            <label asp-for="Severity" class="form-label"></label>
                            <select asp-for="Severity" class="form-select">
                                @foreach (var s in AnnouncementViewModel.Severities)
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>
                        <div class="col-sm-6 mb-3">
                            <label asp-for="ExpiresAt" class="form-label"></label>
                            <input asp-for="ExpiresAt" type="datetime-local" class="form-control" />
                            <div class="form-text">Leave blank to show until deactivated.</div>
                        </div>
                    </div>
                    <div class="form-check form-switch mb-3">
                        <input asp-for="IsActive" class="form-check-input" role="switch" />
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <a asp-area="SuperAdmin" asp-controller="Announcements" asp-action="Index" class="btn btn-soft-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
