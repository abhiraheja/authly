@using Authly.Core.Entities
@using Authly.Core.Enums
@{
    ViewData["Title"] = "Dashboard";
    var recent = ViewBag.Recent as List<Tenant> ?? new List<Tenant>();
}

<div class="page-title-head">
    <h4>Dashboard</h4>
</div>

<div class="row g-3 mb-1">
    <div class="col-sm-6 col-xl-4">
        <div class="card stat-card">
            <div class="card-body d-flex align-items-center gap-3">
                <span class="avatar-lg"><span class="avatar-title bg-soft-primary"><i data-lucide="building-2"></i></span></span>
                <div>
                    <div class="text-muted small">Total tenants</div>
                    <div class="stat-value">@ViewBag.Total</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="card stat-card">
            <div class="card-body d-flex align-items-center gap-3">
                <span class="avatar-lg"><span class="avatar-title bg-soft-success"><i data-lucide="circle-check"></i></span></span>
                <div>
                    <div class="text-muted small">Active</div>
                    <div class="stat-value">@ViewBag.Active</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="card stat-card">
            <div class="card-body d-flex align-items-center gap-3">
                <span class="avatar-lg"><span class="avatar-title bg-soft-warning"><i data-lucide="pause-circle"></i></span></span>
                <div>
                    <div class="text-muted small">Suspended</div>
                    <div class="stat-value">@ViewBag.Suspended</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mt-3">
    <div class="card-header d-flex align-items-center justify-content-between">
        <span>Recent tenants</span>
        <a class="btn btn-sm btn-soft-primary" asp-controller="Tenants" asp-action="Index">View all</a>
    </div>
    <div class="card-body p-0">
        @if (recent.Count == 0)
        {
            <p class="text-muted text-center py-4 mb-0">No tenants yet. Create your first one.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead><tr><th>Name</th><th>Slug</th><th>Status</th><th>Created</th></tr></thead>
                    <tbody>
                    @foreach (var t in recent)
                    {
                        <tr>
                            <td class="fw-medium">@t.Name</td>
                            <td><code>@t.Slug</code></td>
                            <td><span class="badge badge-lighten-success">@t.Status</span></td>
                            <td class="text-muted">@t.CreatedAt.ToString("yyyy-MM-dd")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
