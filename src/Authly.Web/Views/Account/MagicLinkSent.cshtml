@{
    Layout = "_AuthLayout";
}

<div class="text-center">
    <span class="logo-mark mb-3"><i data-lucide="mail"></i></span>
    <h2 class="font-display text-2xl font-bold">Check your email</h2>
    <p class="text-sm text-muted-foreground mt-1 mb-6">
        If an account exists for @(ViewData["Email"] is string e ? e : "that address"),
        we've sent a sign-in link. It expires in 15 minutes and can be used once.
    </p>
    <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@(ViewData["ReturnUrl"] as string)" class="btn btn-outline w-full">Back to sign in</a>
</div>
