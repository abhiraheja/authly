@{
    Layout = "_AuthLayout";
}

<div class="text-center">
    <span class="logo-mark mb-3"><i data-lucide="life-buoy"></i></span>
    <h2 class="font-display text-2xl font-bold">Recovery on its way</h2>
    <p class="text-sm text-muted-foreground mt-1 mb-6">
        If an account exists for @(ViewData["Email"] is string e ? e : "that address"),
        we've sent a recovery link to its registered contacts. The link expires in 1 hour.
    </p>
    <a asp-controller="Account" asp-action="Login" class="btn btn-outline w-full">Back to sign in</a>
</div>
