@using Authly.Modules.Abac
@model AccessPolicyViewModel
@{
    ViewData["Title"] = Model.Id is null ? "New policy" : "Edit policy";
}

<div>
    <h1 class="font-display text-xl font-bold">@ViewData["Title"]</h1>
</div>

<div class="card max-w-3xl">
    <div class="card-body">
        <form asp-area="TenantAdmin" asp-controller="AccessPolicies" asp-action="Save" method="post" class="space-y-4">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>
            <input type="hidden" asp-for="Id" />
            <div>
                <label asp-for="Name" class="label"></label>
                <input asp-for="Name" class="input" />
                <span asp-validation-for="Name" class="text-danger text-xs"></span>
            </div>
            <div>
                <label asp-for="Description" class="label"></label>
                <input asp-for="Description" class="input" />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div>
                    <label asp-for="Effect" class="label"></label>
                    <select asp-for="Effect" asp-items="Html.GetEnumSelectList<PolicyEffect>()" class="select"></select>
                </div>
                <div>
                    <label asp-for="Action" class="label"></label>
                    <input asp-for="Action" class="input" placeholder="document.read" />
                </div>
                <div>
                    <label asp-for="ResourceType" class="label"></label>
                    <input asp-for="ResourceType" class="input" placeholder="document" />
                </div>
            </div>
            <div>
                <label asp-for="ConditionsJson" class="label"></label>
                <textarea asp-for="ConditionsJson" class="textarea font-monospace" rows="6"></textarea>
                <p class="mt-1 text-xs text-muted-foreground">
                    Array of <code>{ "attribute": "subject.department", "operator": "equals", "value": "eng" }</code>.
                    Attributes are <code>subject.*</code>, <code>resource.*</code>, <code>environment.*</code>.
                    Operators: equals, notEquals, contains, in, greaterThan, lessThan, exists. All conditions must hold.
                </p>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div>
                    <label asp-for="Priority" class="label"></label>
                    <input asp-for="Priority" type="number" class="input" />
                </div>
                <div class="sm:col-span-2 flex items-end gap-2">
                    <label class="switch"><input asp-for="Enabled" type="checkbox" role="switch" /><span class="track"></span></label>
                    <label asp-for="Enabled" class="label mb-0"></label>
                </div>
            </div>
            <div class="flex gap-2 pt-1">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-area="TenantAdmin" asp-controller="AccessPolicies" asp-action="Index" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>
