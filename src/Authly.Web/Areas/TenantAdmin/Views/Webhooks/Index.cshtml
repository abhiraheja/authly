@{
    var endpoints = ViewData["Endpoints"] as IReadOnlyList<WebhookEndpoint> ?? new List<WebhookEndpoint>();
    var deliveries = ViewData["Deliveries"] as IReadOnlyList<WebhookDelivery> ?? new List<WebhookDelivery>();

    static string StatusBadge(WebhookDeliveryStatus s) => s switch
    {
        WebhookDeliveryStatus.Success => "text-bg-success",
        WebhookDeliveryStatus.Failed => "text-bg-danger",
        _ => "text-bg-warning"
    };
}

<div class="page-title-head d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0">Webhooks</h4>
    <a class="btn btn-sm btn-primary" asp-area="TenantAdmin" asp-controller="Webhooks" asp-action="Edit">
        <i data-lucide="plus"></i> Add endpoint
    </a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <h6 class="mb-3">Endpoints</h6>
        @if (endpoints.Count == 0)
        {
            <p class="text-muted mb-0">No webhook endpoints yet. Add one to start receiving signed event deliveries.</p>
        }
        else
        {
            <table class="table table-sm align-middle mb-0">
                <thead><tr><th>URL</th><th>Events</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
                <tbody>
                @foreach (var e in endpoints)
                {
                    <tr>
                        <td class="text-break">@e.Url</td>
                        <td><span class="small text-muted">@string.Join(", ", e.Events)</span></td>
                        <td>@(e.IsActive ? "active" : "inactive")</td>
                        <td class="text-end">
                            <form class="d-inline" asp-area="TenantAdmin" asp-controller="Webhooks" asp-action="Test" asp-route-id="@e.Id" method="post">
                                <button type="submit" class="btn btn-sm btn-soft-secondary">Send test</button>
                            </form>
                            <a class="btn btn-sm btn-soft-primary" asp-area="TenantAdmin" asp-controller="Webhooks" asp-action="Edit" asp-route-id="@e.Id">Edit</a>
                            <form class="d-inline" asp-area="TenantAdmin" asp-controller="Webhooks" asp-action="Delete" asp-route-id="@e.Id" method="post"
                                  onsubmit="return confirm('Remove this endpoint?');">
                                <button type="submit" class="btn btn-sm btn-soft-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h6 class="mb-3">Recent deliveries</h6>
        @if (deliveries.Count == 0)
        {
            <p class="text-muted mb-0">No deliveries yet.</p>
        }
        else
        {
            <table class="table table-sm align-middle mb-0">
                <thead><tr><th>Event</th><th>Status</th><th>Attempts</th><th>HTTP</th><th>When</th><th class="text-end"></th></tr></thead>
                <tbody>
                @foreach (var d in deliveries)
                {
                    <tr>
                        <td class="fw-medium">@d.Event</td>
                        <td><span class="badge @StatusBadge(d.Status)">@d.Status.ToString().ToLowerInvariant()</span></td>
                        <td>@d.Attempts</td>
                        <td>@(d.ResponseCode?.ToString() ?? "—")</td>
                        <td class="small text-muted">@d.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-end">
                            @if (d.Status != WebhookDeliveryStatus.Success)
                            {
                                <form class="d-inline" asp-area="TenantAdmin" asp-controller="Webhooks" asp-action="Retry" asp-route-deliveryId="@d.Id" method="post">
                                    <button type="submit" class="btn btn-sm btn-soft-primary">Retry</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>
