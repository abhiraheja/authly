@model BrandingViewModel
@using Authly.Core.Enums
@{
    Layout = "_AdminLayout";
}

<div class="flex items-center justify-between gap-3">
    <div>
        <h1 class="font-display text-xl font-bold">Branding &amp; custom domain</h1>
    </div>
</div>

<div asp-validation-summary="ModelOnly" class="validation-summary-errors mt-4 @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

<form asp-area="TenantAdmin" asp-controller="Branding" asp-action="Index" method="post" class="mt-4">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
        <div class="lg:col-span-7 space-y-4">
            <div class="card">
                <div class="card-header"><div class="card-title">Login page appearance</div></div>
                <div class="card-body space-y-4">
                    <div>
                        <label asp-for="LogoUrl" class="label"></label>
                        <input asp-for="LogoUrl" class="input" placeholder="https://cdn.yourcompany.com/logo.svg" />
                        <span asp-validation-for="LogoUrl" class="text-danger text-xs"></span>
                        <p class="mt-1 text-xs text-muted-foreground">Shown on the hosted login/register/MFA pages. Falls back to your workspace name.</p>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="PrimaryColor" class="label"></label>
                            <div class="flex gap-2">
                                <input type="color" class="input h-10 w-16 p-1" value="@Model.PrimaryColor"
                                       oninput="document.getElementById('PrimaryColor').value = this.value" />
                                <input asp-for="PrimaryColor" id="PrimaryColor" class="input" />
                            </div>
                            <span asp-validation-for="PrimaryColor" class="text-danger text-xs"></span>
                        </div>
                        <div>
                            <label asp-for="ButtonTextColor" class="label"></label>
                            <div class="flex gap-2">
                                <input type="color" class="input h-10 w-16 p-1" value="@Model.ButtonTextColor"
                                       oninput="document.getElementById('ButtonTextColor').value = this.value" />
                                <input asp-for="ButtonTextColor" id="ButtonTextColor" class="input" />
                            </div>
                            <span asp-validation-for="ButtonTextColor" class="text-danger text-xs"></span>
                        </div>
                    </div>

                    <div>
                        <label asp-for="FontFamily" class="label"></label>
                        <input asp-for="FontFamily" class="input" placeholder="Inter, system-ui, sans-serif" />
                        <p class="mt-1 text-xs text-muted-foreground">A CSS font-family stack. Leave blank for the default.</p>
                    </div>

                    <div>
                        <label class="label">Layout</label>
                        <div class="flex flex-wrap items-center gap-4">
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" asp-for="Layout" id="layoutCentered" value="@BrandingLayout.Centered" />
                                <span>Centered card</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" asp-for="Layout" id="layoutSplit" value="@BrandingLayout.Split" />
                                <span>Split (branded panel)</span>
                            </label>
                        </div>
                    </div>

                    <div class="flex items-center gap-3">
                        <label class="switch">
                            <input asp-for="DarkMode" type="checkbox" />
                            <span class="track"></span>
                        </label>
                        <label asp-for="DarkMode" class="label !mb-0"></label>
                    </div>

                    <div>
                        <label asp-for="Tagline" class="label"></label>
                        <input asp-for="Tagline" class="input" placeholder="Welcome back to Acme" />
                        <p class="mt-1 text-xs text-muted-foreground">Shown beside the brand on the split layout.</p>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><div class="card-title">Custom domain</div></div>
                <div class="card-body">
                    <label asp-for="CustomDomain" class="label"></label>
                    <input asp-for="CustomDomain" class="input" placeholder="auth.yourcompany.com" />
                    <span asp-validation-for="CustomDomain" class="text-danger text-xs"></span>
                    <p class="mt-1 text-xs text-muted-foreground">
                        Point a CNAME for this host at the platform, then enter it here. Your end-users will see
                        login pages on your own domain. Leave blank to remove.
                    </p>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Save branding</button>
        </div>

        <div class="lg:col-span-5">
            <div class="card">
                <div class="card-header"><div class="card-title">Preview</div></div>
                <div class="card-body">
                    <div id="brandPreview" class="rounded-lg border border-border p-4 text-center">
                        <div id="previewLogoWrap" class="mb-3 inline-flex items-center gap-2 font-bold text-lg">
                            <span id="previewMark" class="grid place-items-center size-9 rounded-lg text-white"
                                  style="background:@Model.PrimaryColor;">
                                <i data-lucide="shield-check" class="size-5"></i>
                            </span>
                            <span>Your workspace</span>
                        </div>
                        <p class="text-muted-foreground text-sm mb-3">Sign in to your account.</p>
                        <button type="button" id="previewBtn" class="btn w-full"
                                style="background:@Model.PrimaryColor;color:@Model.ButtonTextColor;border:0;">Sign in</button>
                    </div>
                    <p class="mt-2 text-xs text-muted-foreground">An approximation; the live page also applies your font and layout.</p>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<script>
    const primary = document.getElementById('PrimaryColor');
    const btnText = document.getElementById('ButtonTextColor');
    const previewBtn = document.getElementById('previewBtn');
    const previewMark = document.getElementById('previewMark');
    function sync() {
        previewBtn.style.background = primary.value;
        previewBtn.style.color = btnText.value;
        previewMark.style.background = primary.value;
    }
    primary.addEventListener('input', sync);
    btnText.addEventListener('input', sync);
</script>
}
