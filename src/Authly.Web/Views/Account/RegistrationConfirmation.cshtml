@{
    Layout = "_AuthLayout";
}

<div class="text-center">
    <span class="logo-mark mb-3"><i data-lucide="mail-check"></i></span>
    <h5 class="mb-2">Check your email</h5>
    <p class="text-muted small mb-4">
        We've sent a verification link@(ViewData["Email"] is string e ? $" to {e}" : "").
        Open it to confirm your address and finish setting up your account.
    </p>
    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-sm">Back to sign in</a>
</div>
