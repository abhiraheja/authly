@model IReadOnlyList<UserListRow>
@functions {
    static string ProviderLabel(string key) => key switch
    {
        "password" => "Password",
        "google" => "Google",
        "facebook" => "Facebook",
        "github" => "GitHub",
        "microsoft" => "Microsoft",
        _ => char.ToUpperInvariant(key[0]) + key[1..]
    };
}

<div class="flex items-center justify-between gap-3">
    <div>
        <h1 class="font-display text-xl font-bold">Users</h1>
        <p class="text-sm text-muted-foreground mt-0.5">People with access to this workspace.</p>
    </div>
    <a class="btn btn-primary btn-sm" asp-area="TenantAdmin" asp-controller="Users" asp-action="Import">
        <i data-lucide="upload" class="size-4"></i> Import users
    </a>
</div>

<div class="card">
    @if (Model.Count == 0)
    {
        <div class="card-body flex flex-col items-center text-center py-12 gap-3">
            <span class="grid place-items-center size-12 rounded-xl bg-primary/10 text-primary">
                <i data-lucide="users" class="size-6"></i>
            </span>
            <p class="text-sm text-muted-foreground max-w-sm">No users in this workspace yet.</p>
            <a class="btn btn-primary btn-sm" asp-area="TenantAdmin" asp-controller="Users" asp-action="Import">
                <i data-lucide="upload" class="size-4"></i> Import users
            </a>
        </div>
    }
    else
    {
        <div class="overflow-x-auto scroll-thin">
            <table class="table">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Name</th>
                        <th>Sign-in</th>
                        <th>Status</th>
                        <th class="text-right"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model)
                {
                    var u = row.User;
                    <tr>
                        <td class="font-medium">@u.Email</td>
                        <td class="text-muted-foreground">@($"{u.FirstName} {u.LastName}".Trim() is { Length: > 0 } n ? n : "—")</td>
                        <td>
                            @if (row.Providers.Count == 0)
                            {
                                <span class="text-muted-foreground">—</span>
                            }
                            else
                            {
                                <span class="flex flex-wrap gap-1">
                                @foreach (var p in row.Providers)
                                {
                                    <span class="badge @(p == "password" ? "badge-neutral" : "badge-primary")">@ProviderLabel(p)</span>
                                }
                                </span>
                            }
                        </td>
                        <td><span class="badge badge-neutral">@u.Status</span></td>
                        <td class="text-right">
                            <a class="btn btn-outline btn-sm"
                               asp-area="TenantAdmin" asp-controller="Users" asp-action="Details" asp-route-id="@u.Id">
                                <i data-lucide="eye" class="size-4"></i> View details
                            </a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
