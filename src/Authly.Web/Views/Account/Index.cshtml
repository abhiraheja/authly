@using System.Security.Claims
@using Authly.Web.Infrastructure
@{
    Layout = "_AuthLayout";
    var email = User.FindFirstValue(ClaimTypes.Name);
    var emailVerified = User.FindFirstValue(UserClaims.EmailVerified) == "true";
}

<div class="text-center">
    <span class="logo-mark mb-3"><i data-lucide="user-round"></i></span>
    <h5 class="mb-1">You're signed in</h5>
    <p class="text-muted small mb-3">@email</p>

    @if (!emailVerified)
    {
        <div class="alert alert-warning py-2 small text-start">
            <strong>Email not verified.</strong> Check your inbox for the verification link we sent when you registered.
        </div>
    }

    <form asp-controller="Account" asp-action="Logout" method="post" class="d-grid mt-3">
        <button type="submit" class="btn btn-outline-secondary btn-sm">Sign out</button>
    </form>
</div>
