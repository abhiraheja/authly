@using Authly.Core.Entities
@using Authly.Core.Enums
@model IReadOnlyList<Tenant>
@{
    ViewData["Title"] = "Tenants";
    string Badge(TenantStatus s) => s switch
    {
        TenantStatus.Active => "badge-lighten-success",
        TenantStatus.Suspended => "badge-lighten-secondary",
        _ => "badge-lighten-danger"
    };
}

<div class="page-title-head">
    <h4>Tenants</h4>
    <a class="btn btn-primary" asp-action="Create">
        <i data-lucide="plus" class="me-1"></i> New tenant
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Count == 0)
        {
            <div class="text-center py-5">
                <span class="avatar-lg mx-auto d-inline-block mb-2"><span class="avatar-title bg-soft-primary"><i data-lucide="building-2"></i></span></span>
                <p class="text-muted mb-3">No tenants yet.</p>
                <a class="btn btn-soft-primary" asp-action="Create">Create your first tenant</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Name</th><th>Slug</th><th>Status</th><th>Created</th><th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var t in Model)
                    {
                        <tr>
                            <td class="fw-medium">@t.Name</td>
                            <td><code>@t.Slug</code></td>
                            <td><span class="badge @Badge(t.Status)">@t.Status</span></td>
                            <td class="text-muted">@t.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    @if (t.Status == TenantStatus.Active)
                                    {
                                        <form asp-action="Suspend" method="post" onsubmit="return confirm('Suspend this tenant?');">
                                            <input type="hidden" name="id" value="@t.Id" />
                                            <button class="btn btn-sm btn-soft-secondary" title="Suspend"><i data-lucide="pause"></i></button>
                                        </form>
                                    }
                                    else if (t.Status == TenantStatus.Suspended)
                                    {
                                        <form asp-action="Reactivate" method="post">
                                            <input type="hidden" name="id" value="@t.Id" />
                                            <button class="btn btn-sm btn-soft-success" title="Reactivate"><i data-lucide="play"></i></button>
                                        </form>
                                    }
                                    <form asp-action="Delete" method="post" onsubmit="return confirm('Delete this tenant? This can be undone within the grace period.');">
                                        <input type="hidden" name="id" value="@t.Id" />
                                        <button class="btn btn-sm btn-soft-danger" title="Delete"><i data-lucide="trash-2"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
