@{
    Layout = "_DocsLayout";
    ViewData["Title"] = "Documentation";
    ViewData["DocsActive"] = "index";
    ViewData["Description"] = "Authly documentation — integrate apps with OAuth/OIDC, the Management API, webhooks, the admin console and self-hosting.";
}

<p class="eyebrow">Documentation</p>
<h1 class="mt-2 font-display text-3xl font-bold tracking-tight">Build with Authly.</h1>
<p class="mt-3 text-muted-foreground">A standards-based OpenID Connect / OAuth 2.0 provider. Point any OIDC client at the discovery document and you're integrated — everything else is advertised there.</p>

<div class="card my-6">
    <div class="card-header"><span class="card-title">Your live endpoints</span></div>
    <div class="card-body space-y-3">
        <div>
            <label class="label text-xs">Discovery document</label>
            <input class="input font-mono text-xs" value="@ViewBag.Discovery" readonly onclick="this.select()" />
        </div>
        <div class="grid gap-2 sm:grid-cols-2">
            <div><label class="label text-xs">Authorization</label><input class="input font-mono text-xs" value="@ViewBag.Authorize" readonly onclick="this.select()" /></div>
            <div><label class="label text-xs">Token</label><input class="input font-mono text-xs" value="@ViewBag.Token" readonly onclick="this.select()" /></div>
            <div><label class="label text-xs">UserInfo</label><input class="input font-mono text-xs" value="@ViewBag.UserInfo" readonly onclick="this.select()" /></div>
            <div><label class="label text-xs">End session</label><input class="input font-mono text-xs" value="@ViewBag.Logout" readonly onclick="this.select()" /></div>
        </div>
    </div>
</div>

<h2 class="font-display text-xl font-bold mt-8 mb-3">Start here</h2>
<div class="grid gap-3 sm:grid-cols-2">
    @foreach (var (icon, title, desc, href) in new[]
    {
        ("rocket", "Quickstart", "Integrate an app end-to-end: register a client, run the Auth Code + PKCE flow, exchange tokens.", "/docs/quickstart"),
        ("key-round", "OAuth & OIDC", "Every endpoint, supported grants, token lifetimes, and a common-errors table.", "/docs/oauth"),
        ("server", "Management API", "REST endpoints for users, roles, applications, audit logs and ABAC evaluation.", "/docs/api"),
        ("webhook", "Webhooks & events", "Subscribe to identity events, verify HMAC signatures, and use pipeline hooks.", "/docs/webhooks"),
        ("sliders-horizontal", "Admin console", "What your team can configure per project — apps, users, MFA, branding, security.", "/docs/admin"),
        ("box", "Self-host with Docker", "Install Docker, set env vars, and run your own instance — no cloud account.", "/docs/self-host"),
    })
    {
        <a href="@href" class="card card-body transition-colors hover:border-primary/40">
            <i data-lucide="@icon" class="size-5 text-primary"></i>
            <div class="mt-2 font-semibold text-sm">@title</div>
            <p class="mt-1 text-sm text-muted-foreground">@desc</p>
        </a>
    }
</div>

<h2 class="font-display text-xl font-bold mt-10 mb-3">Concepts in 60 seconds</h2>
<div class="card overflow-hidden">
    <table class="table">
        <tbody>
            <tr><td class="font-medium w-40">Tenant / Project</td><td class="text-muted-foreground">Your workspace. Every user, app and key belongs to one tenant, isolated at the database level.</td></tr>
            <tr><td class="font-medium">Application</td><td class="text-muted-foreground">An OAuth client (web, SPA, native or machine). Has a <code>client_id</code>; confidential clients also get a <code>client_secret</code>.</td></tr>
            <tr><td class="font-medium">API key</td><td class="text-muted-foreground">A server-to-server credential for the Management API. Shown once, stored hashed.</td></tr>
            <tr><td class="font-medium">Scopes</td><td class="text-muted-foreground"><code>openid profile email offline_access roles</code> — what a token may access.</td></tr>
        </tbody>
    </table>
</div>

<div class="mt-8 card card-body !py-3 flex items-start gap-3 border-l-4 border-l-primary text-sm">
    <i data-lucide="folder-git-2" class="size-4 text-primary mt-0.5 shrink-0"></i>
    <div>In-repo guides go deeper: <code>docs/developer/Quickstart.md</code> (integration) and <code>docs/Tenant-Onboarding-Guide.md</code> (the full product journey).</div>
</div>
