@model EmailOnlyViewModel
@{
    Layout = "_AuthLayout";
}

<h2 class="font-display text-2xl font-bold">Recover account</h2>
<p class="text-sm text-muted-foreground mt-1 mb-6">
    Lost access to your account? Enter your email and we'll send a recovery link to every contact on file.
</p>

<form asp-controller="Account" asp-action="RecoverRequest" method="post" class="space-y-4">
    <div>
        <label asp-for="Email" class="label">Email</label>
        <input asp-for="Email" class="input" autocomplete="email" placeholder="you@example.com" />
        <span asp-validation-for="Email" class="text-danger text-xs"></span>
    </div>

    <button type="submit" class="btn btn-primary w-full">Recover account</button>
</form>

<p class="text-center text-sm text-muted-foreground mt-6">
    <a class="text-primary hover:underline" asp-controller="Account" asp-action="Login">Back to sign in</a>
</p>
