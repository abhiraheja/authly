@model SecurityTotpSetupViewModel

<div class="page-title-head">
    <h4>Add authenticator app</h4>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body">
                <p class="text-muted small mb-3">
                    Scan the QR code with your authenticator app, then enter the 6-digit code to confirm.
                </p>

                @if (Model.Error is not null)
                {
                    <div class="alert alert-danger py-2 small">@Model.Error</div>
                }

                <div class="text-center mb-3">
                    <div class="d-inline-block p-2 bg-white rounded border" style="max-width:200px">@Html.Raw(Model.QrSvg)</div>
                </div>

                <p class="text-center small text-muted">
                    Can't scan? Enter this key manually:<br /><code>@Model.Secret</code>
                </p>

                <form asp-area="Portal" asp-controller="Security" asp-action="Totp" method="post">
                    <input type="hidden" asp-for="FactorId" />
                    <div class="mb-3">
                        <label asp-for="FriendlyName" class="form-label"></label>
                        <input asp-for="FriendlyName" class="form-control" placeholder="e.g. My phone" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Code" class="form-label"></label>
                        <input asp-for="Code" class="form-control" inputmode="numeric" autocomplete="one-time-code"
                               maxlength="6" placeholder="123456" autofocus />
                        <span asp-validation-for="Code" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary">Confirm</button>
                    <a class="btn btn-link" asp-area="Portal" asp-controller="Security" asp-action="Index">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
