@model IReadOnlyList<Session>
@{
    var currentId = (Guid)(ViewData["CurrentSessionId"] ?? Guid.Empty);
    var others = Model.Count(s => s.Id != currentId);
}

<div class="page-title-head">
    <h4>Active sessions</h4>
    @if (others > 0)
    {
        <form asp-area="Portal" asp-controller="Sessions" asp-action="RevokeOthers" method="post"
              onsubmit="return confirm('Sign out all other devices?');">
            <button type="submit" class="btn btn-soft-danger btn-sm">Sign out other sessions</button>
        </form>
    }
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Device</th>
                    <th>IP address</th>
                    <th>Last active</th>
                    <th>Signed in</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.OrderByDescending(x => x.LastActiveAt))
                {
                    <tr>
                        <td>
                            <div class="text-truncate" style="max-width:320px;">@(s.UserAgent ?? "Unknown device")</div>
                            @if (s.Id == currentId)
                            {
                                <span class="badge bg-soft-primary">This device</span>
                            }
                        </td>
                        <td class="text-muted">@(s.IpAddress ?? "—")</td>
                        <td class="text-muted">@s.LastActiveAt.ToString("yyyy-MM-dd HH:mm") UTC</td>
                        <td class="text-muted">@s.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td class="text-end">
                            <form asp-area="Portal" asp-controller="Sessions" asp-action="Revoke" asp-route-id="@s.Id" method="post"
                                  onsubmit="return confirm('@(s.Id == currentId ? "Sign out this device?" : "Revoke this session?")');">
                                <button type="submit" class="btn btn-sm btn-soft-danger">@(s.Id == currentId ? "Sign out" : "Revoke")</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (Model.Count == 0)
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No active sessions.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
