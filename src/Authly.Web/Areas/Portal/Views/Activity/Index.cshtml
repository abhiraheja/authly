@model IReadOnlyList<LoginHistory>

<div class="page-title-head">
    <h4>Login activity</h4>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>When</th>
                    <th>Result</th>
                    <th>Method</th>
                    <th>IP address</th>
                    <th>Device</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var h in Model)
                {
                    var badge = h.Result switch
                    {
                        "success" => "bg-soft-success",
                        "blocked" => "bg-soft-danger",
                        "failed" => "bg-soft-warning",
                        _ => "badge-lighten-secondary"
                    };
                    <tr>
                        <td class="text-muted">@h.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC</td>
                        <td><span class="badge @badge">@h.Result</span></td>
                        <td class="text-muted">@(h.Method ?? "—")</td>
                        <td class="text-muted">@(h.IpAddress ?? "—")</td>
                        <td class="text-muted text-truncate" style="max-width:280px;">@(h.UserAgent ?? "—")</td>
                    </tr>
                }
                @if (Model.Count == 0)
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No login activity yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
