@{
    Layout = "_AuthLayout";
}

<div class="text-center">
    <span class="logo-mark mb-3"><i data-lucide="mail"></i></span>
    <h5 class="mb-2">Check your email</h5>
    <p class="text-muted small mb-4">
        If an account exists for @(ViewData["Email"] is string e ? e : "that address"),
        we've sent a sign-in link. It expires in 15 minutes and can be used once.
    </p>
    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-sm">Back to sign in</a>
</div>
