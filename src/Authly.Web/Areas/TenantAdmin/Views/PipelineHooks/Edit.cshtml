@model PipelineHookInput
@{
    var isNew = Model.Id is null;
    var stages = Enum.GetValues<PipelineStage>();
}

<div class="flex items-center justify-between gap-3">
    <div>
        <h1 class="font-display text-xl font-bold">@(isNew ? "Add" : "Edit") pipeline hook</h1>
    </div>
</div>

<div class="card mt-4">
    <div class="card-body">
        <form asp-area="TenantAdmin" asp-controller="PipelineHooks" asp-action="Save" method="post" class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="All" class="text-danger text-xs md:col-span-2"></div>

            <div>
                <label class="label" asp-for="Stage">Stage</label>
                <select class="select" asp-for="Stage">
                    @foreach (var s in stages)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>

            <div>
                <label class="label" asp-for="OnFailure">On failure</label>
                <select class="select" asp-for="OnFailure">
                    <option value="@HookFailureMode.Continue">continue (fail-open)</option>
                    <option value="@HookFailureMode.Block">block (fail-closed)</option>
                </select>
            </div>

            <div class="md:col-span-2">
                <label class="label" asp-for="Url">Hook URL</label>
                <input class="input" asp-for="Url" placeholder="https://example.com/hooks/pre-token" />
            </div>

            <div>
                <label class="label" asp-for="TimeoutMs">Timeout (ms)</label>
                <input class="input" asp-for="TimeoutMs" type="number" min="250" max="30000" />
            </div>

            <div>
                <label class="label" asp-for="Secret">Signing secret</label>
                <input class="input" asp-for="Secret" type="password" autocomplete="new-password"
                       placeholder="@(isNew ? "Required" : "Leave blank to keep current")" />
            </div>

            <div class="md:col-span-2">
                <div class="flex items-center gap-2">
                    <label class="switch"><input asp-for="IsActive" type="checkbox" /><span class="track"></span></label>
                    <label asp-for="IsActive">Active</label>
                </div>
            </div>

            <div class="md:col-span-2 flex gap-2">
                <button type="submit" class="btn btn-primary">Save hook</button>
                <a class="btn btn-outline" asp-area="TenantAdmin" asp-controller="PipelineHooks" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>
