<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Authly</title>
    <script>try { if (localStorage.getItem("authly-theme") === "dark") document.documentElement.classList.add("dark"); } catch (e) { }</script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="~/css/saarvix.css" asp-append-version="true" />
</head>
<body class="min-h-screen flex flex-col">
    <header class="h-16 flex items-center border-b border-border glass sticky top-0 z-20">
        <nav class="mx-auto max-w-7xl w-full px-4 sm:px-6 flex items-center gap-6">
            <a class="flex items-center gap-2.5 font-display font-bold" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="grid place-items-center size-8 rounded-lg bg-primary text-primary-foreground"><i data-lucide="shield-check" class="size-4"></i></span>
                Authly
            </a>
            <div class="flex items-center gap-1 text-sm">
                <a class="btn btn-ghost btn-sm" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                <a class="btn btn-ghost btn-sm" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-1">
        <div class="mx-auto max-w-7xl w-full px-4 sm:px-6 py-6">
            @RenderBody()
        </div>
    </main>

    <footer class="border-t border-border text-xs text-muted-foreground">
        <div class="mx-auto max-w-7xl w-full px-4 sm:px-6 py-4">
            &copy; @DateTime.UtcNow.Year Authly — <a class="text-primary hover:underline" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    <script src="~/js/saarvix-app.js" asp-append-version="true"></script>
    <script>lucide.createIcons();</script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
