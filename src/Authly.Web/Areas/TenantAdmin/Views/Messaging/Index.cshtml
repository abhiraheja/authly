@{
    var providers = ViewData["Providers"] as IReadOnlyList<MessagingProvider> ?? new List<MessagingProvider>();
    var logs = ViewData["Logs"] as IReadOnlyList<MessageLog> ?? new List<MessageLog>();
    MessagingProvider? email = providers.FirstOrDefault(p => p.Channel == MessageChannel.Email);
    MessagingProvider? whatsapp = providers.FirstOrDefault(p => p.Channel == MessageChannel.WhatsApp);
}

<div class="flex items-center justify-between gap-3">
    <div>
        <h1 class="font-display text-xl font-bold">Messaging</h1>
        <p class="text-sm text-muted-foreground mt-0.5">Email and WhatsApp delivery providers and recent activity.</p>
    </div>
    <a class="btn btn-outline btn-sm" asp-area="TenantAdmin" asp-controller="Messaging" asp-action="Templates">
        <i data-lucide="file-text" class="size-4"></i> Templates
    </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4 mb-4">
    <div class="card">
        <div class="card-body">
            <h6 class="flex items-center gap-2 font-semibold"><i data-lucide="mail" class="size-4"></i> Email provider</h6>
            @if (email is not null)
            {
                <p class="text-sm flex items-center gap-2 mb-2 mt-2">
                    <code>@email.Provider</code>
                    @if (email.IsActive) { <span class="badge badge-success">active</span> } else { <span class="badge badge-neutral">inactive</span> }
                </p>
            }
            else
            {
                <p class="text-sm text-muted-foreground mb-2 mt-2">No provider configured — emails are logged locally.</p>
            }
            <a class="btn btn-sm btn-primary" asp-area="TenantAdmin" asp-controller="Messaging" asp-action="Provider"
               asp-route-channel="email" asp-route-id="@email?.Id">@(email is null ? "Configure" : "Edit")</a>
        </div>
    </div>
    <div class="card">
        <div class="card-body">
            <h6 class="flex items-center gap-2 font-semibold"><i data-lucide="message-circle" class="size-4"></i> WhatsApp provider</h6>
            @if (whatsapp is not null)
            {
                <p class="text-sm flex items-center gap-2 mb-2 mt-2">
                    <code>@whatsapp.Provider</code>
                    @if (whatsapp.IsActive) { <span class="badge badge-success">active</span> } else { <span class="badge badge-neutral">inactive</span> }
                </p>
            }
            else
            {
                <p class="text-sm text-muted-foreground mb-2 mt-2">No provider configured — WhatsApp messages are logged locally.</p>
            }
            <a class="btn btn-sm btn-primary" asp-area="TenantAdmin" asp-controller="Messaging" asp-action="Provider"
               asp-route-channel="whatsapp" asp-route-id="@whatsapp?.Id">@(whatsapp is null ? "Configure" : "Edit")</a>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h6 class="mb-3 font-semibold">Recent deliveries</h6>
        @if (logs.Count == 0)
        {
            <p class="text-muted-foreground mb-0">No messages sent yet.</p>
        }
        else
        {
            <div class="overflow-x-auto scroll-thin">
                <table class="table">
                    <thead><tr><th>When</th><th>Channel</th><th>Recipient</th><th>Template</th><th>Status</th><th>Error</th></tr></thead>
                    <tbody>
                    @foreach (var l in logs)
                    {
                        <tr>
                            <td class="text-sm text-muted-foreground">@l.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="text-sm">@l.Channel</td>
                            <td class="text-sm">@l.Recipient</td>
                            <td class="text-sm"><code>@l.TemplateKey</code></td>
                            <td>
                                @if (l.Status == "sent") { <span class="badge badge-success">sent</span> }
                                else if (l.Status == "failed") { <span class="badge badge-danger">failed</span> }
                                else { <span class="badge badge-neutral">@l.Status</span> }
                            </td>
                            <td class="text-sm text-danger">@l.Error</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
