@model IReadOnlyList<MemberRow>

<div class="flex items-center justify-between gap-3">
    <div>
        <h1 class="font-display text-xl font-bold">Members</h1>
        <p class="text-sm text-muted-foreground mt-0.5">Employees with access to this organization's console.</p>
    </div>
    <a class="btn btn-primary btn-sm" asp-area="TenantAdmin" asp-controller="Members" asp-action="Invite">
        <i data-lucide="user-plus" class="size-4"></i> Invite member
    </a>
</div>

<div class="card">
    @if (Model.Count == 0)
    {
        <div class="card-body flex flex-col items-center text-center py-12 gap-3">
            <span class="grid place-items-center size-12 rounded-xl bg-primary/10 text-primary">
                <i data-lucide="users" class="size-6"></i>
            </span>
            <p class="text-sm text-muted-foreground max-w-sm">No members yet. Invite a teammate to get started.</p>
            <a class="btn btn-primary btn-sm" asp-area="TenantAdmin" asp-controller="Members" asp-action="Invite">
                <i data-lucide="user-plus" class="size-4"></i> Invite member
            </a>
        </div>
    }
    else
    {
        <div class="overflow-x-auto scroll-thin">
            <table class="table">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Name</th>
                        <th>Status</th>
                        <th>Roles</th>
                        <th class="text-right"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var m in Model)
                {
                    <tr>
                        <td class="font-medium">
                            @m.Email
                            @if (m.IsOwner) { <span class="badge badge-primary ms-1">owner</span> }
                        </td>
                        <td class="text-muted-foreground">@(m.Name ?? "—")</td>
                        <td>
                            @switch (m.Status)
                            {
                                case MembershipStatus.Active: <span class="badge badge-success">Active</span> break;
                                case MembershipStatus.Invited: <span class="badge badge-neutral">Invited</span> break;
                                default: <span class="badge badge-neutral">@m.Status</span> break;
                            }
                        </td>
                        <td class="text-muted-foreground">
                            @if (m.RoleNames.Count == 0) { <text>—</text> }
                            else
                            {
                                @foreach (var r in m.RoleNames)
                                {
                                    <code class="text-xs me-1">@r</code>
                                }
                            }
                        </td>
                        <td class="text-right">
                            <a class="btn btn-outline btn-sm"
                               asp-area="TenantAdmin" asp-controller="Members" asp-action="Details" asp-route-id="@m.MembershipId">
                                Manage
                            </a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
