@model Application
@{
    var clientId = TempData["NewClientId"] as string ?? Model.ClientId;
    var clientSecret = TempData["NewClientSecret"] as string;
    var apiKey = TempData["NewApiKey"] as string;
}

<div class="flex items-center justify-between gap-3 mb-3">
    <div>
        <h1 class="font-display text-xl font-bold">Your credentials</h1>
        <p class="text-sm text-muted-foreground mt-0.5">Copy these now — secrets are shown only once.</p>
    </div>
</div>

@await Html.PartialAsync("_WizardSteps")

<div class="max-w-3xl space-y-3">
    <div class="card">
        <div class="card-header"><div class="card-title">Step 2 — OAuth client credentials</div></div>
        <div class="card-body space-y-3">
            <div>
                <label class="label">Client ID</label>
                <input class="input" value="@clientId" readonly onclick="this.select()" />
            </div>
            @if (clientSecret is not null)
            {
                <div>
                    <label class="label">Client secret</label>
                    <input class="input" value="@clientSecret" readonly onclick="this.select()" />
                </div>
                <div class="card card-body !py-3 flex items-center gap-3 border-l-4 border-l-warning">
                    <i data-lucide="alert-triangle" class="size-4 text-warning"></i>
                    <span>Store this secret securely. It won't be shown again — you can rotate it later from the application page.</span>
                </div>
            }
            else
            {
                <p class="text-sm text-muted-foreground">This is a public client (PKCE) — no client secret is issued.</p>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header"><div class="card-title">Optional — backend API key</div></div>
        <div class="card-body">
            @if (apiKey is not null)
            {
                <label class="label">API key</label>
                <input class="input mb-2" value="@apiKey" readonly onclick="this.select()" />
                <div class="card card-body !py-3 flex items-center gap-3 border-l-4 border-l-warning">
                    <i data-lucide="alert-triangle" class="size-4 text-warning"></i>
                    <span>Copy now — this key won't be shown again.</span>
                </div>
            }
            else
            {
                <p class="text-sm text-muted-foreground mb-3">Need a server-to-server key for the management API? Create one now.</p>
                <form asp-area="TenantAdmin" asp-controller="Onboarding" asp-action="CreateApiKey" method="post" class="flex gap-2">
                    <input type="hidden" name="appId" value="@Model.Id" />
                    <input name="name" class="input flex-1" placeholder="Server key" />
                    <button type="submit" class="btn btn-primary">Generate API key</button>
                </form>
            }
        </div>
    </div>

    <div class="flex justify-end">
        <a asp-area="TenantAdmin" asp-controller="Onboarding" asp-action="Branding" class="btn btn-primary">
            Continue to branding <i data-lucide="arrow-right" class="size-4"></i>
        </a>
    </div>
</div>
