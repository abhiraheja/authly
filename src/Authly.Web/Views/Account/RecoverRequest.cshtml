@model EmailOnlyViewModel
@{
    Layout = "_AuthLayout";
}

<p class="text-center text-muted mb-4">
    Lost access to your account? Enter your email and we'll send a recovery link to every contact on file.
</p>

<form asp-controller="Account" asp-action="RecoverRequest" method="post">
    <div class="mb-4">
        <label asp-for="Email" class="form-label">Email</label>
        <input asp-for="Email" class="form-control" autocomplete="email" placeholder="you@example.com" />
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>

    <div class="d-grid">
        <button type="submit" class="btn btn-primary">Recover account</button>
    </div>
</form>

<p class="text-center text-muted small mt-4 mb-0">
    <a asp-controller="Account" asp-action="Login">Back to sign in</a>
</p>
