@model EditApplicationViewModel
@{
    var appId = ViewData["ApplicationId"];
}

<div class="page-title-head d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0">Edit application</h4>
    <a class="btn btn-soft-secondary btn-sm" asp-area="TenantAdmin" asp-controller="Applications" asp-action="Details" asp-route-id="@appId">Back</a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-area="TenantAdmin" asp-controller="Applications" asp-action="Edit" asp-route-id="@appId" method="post" style="max-width: 640px;">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small @(ViewData.ModelState.IsValid ? "d-none" : "")"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="My Web App" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="RedirectUris" class="form-label"></label>
                <textarea asp-for="RedirectUris" class="form-control" rows="4"
                          placeholder="https://app.example.com/callback"></textarea>
                <div class="form-text">Where Authly returns the authorization code after sign-in. Required for interactive (authorization-code) clients. One URI per line.</div>
            </div>

            <div class="mb-3">
                <label asp-for="PostLogoutRedirectUris" class="form-label"></label>
                <textarea asp-for="PostLogoutRedirectUris" class="form-control" rows="3"
                          placeholder="https://app.example.com/"></textarea>
                <div class="form-text">Where Authly returns after RP-initiated logout (<code>/connect/logout</code>). One URI per line. Optional.</div>
            </div>

            <div class="mb-4">
                <label asp-for="Scopes" class="form-label"></label>
                <input asp-for="Scopes" class="form-control" />
                <div class="form-text"><code>openid</code> and <code>offline_access</code> are added automatically for interactive clients.</div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save changes</button>
                <a class="btn btn-soft-secondary" asp-area="TenantAdmin" asp-controller="Applications" asp-action="Details" asp-route-id="@appId">Cancel</a>
            </div>
        </form>
    </div>
</div>
