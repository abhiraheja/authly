@{
    Layout = "_AuthLayout";
}

<div class="text-center">
    <span class="logo-mark mb-3"><i data-lucide="mail-check"></i></span>
    <h2 class="font-display text-2xl font-bold">Check your email</h2>
    <p class="text-sm text-muted-foreground mt-1 mb-6">
        We've sent a verification link@(ViewData["Email"] is string e ? $" to {e}" : "").
        Open it to confirm your address and finish setting up your account.
    </p>
    <a asp-controller="Account" asp-action="Login" class="btn btn-outline w-full">Back to sign in</a>
</div>
