@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Invite not valid";
}

<div class="text-center">
    <span class="inline-grid place-items-center size-12 rounded-xl bg-danger/10 text-danger mb-3">
        <i data-lucide="link-2-off" class="size-6"></i>
    </span>
    <h2 class="font-display text-2xl font-bold">This invite isn't valid</h2>
    <p class="text-muted-foreground mt-1 mb-6">The link may have expired or already been used. Ask your administrator to send a new invite.</p>
    <a class="btn btn-outline" asp-area="TenantAdmin" asp-controller="Account" asp-action="Login">Go to sign in</a>
</div>
