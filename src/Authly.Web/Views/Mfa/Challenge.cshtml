@model MfaChallengeViewModel
@{
    Layout = "_AuthLayout";
}

<p class="text-center text-muted-foreground mb-6">Enter a verification code to finish signing in.</p>

@if (Model.Error is not null)
{
    <div class="card card-body !py-2.5 mb-4 flex items-center gap-2 border-l-4 border-l-danger text-sm"><i data-lucide="alert-circle" class="size-4 text-coral"></i>@Model.Error</div>
}

@if (Model.Methods.Totp)
{
    <form asp-controller="Mfa" asp-action="VerifyTotp" method="post" class="space-y-2 mb-4">
        <label class="label">Authenticator app code</label>
        <input name="code" class="input text-center tracking-[.4em] text-lg" inputmode="numeric" autocomplete="one-time-code"
               maxlength="6" placeholder="123456" autofocus />
        <button type="submit" class="btn btn-primary w-full">Verify</button>
    </form>
}

@if (Model.Methods.EmailOtp)
{
    <div class="my-4 flex items-center gap-3"><div class="h-px flex-1 bg-border"></div><span class="text-xs text-muted-foreground">or</span><div class="h-px flex-1 bg-border"></div></div>
    @if (Model.EmailOtpSent)
    {
        <form asp-controller="Mfa" asp-action="VerifyEmail" method="post" class="space-y-2 mb-2">
            <label class="label">Emailed code</label>
            <input name="code" class="input text-center tracking-[.4em] text-lg" inputmode="numeric" autocomplete="one-time-code"
                   maxlength="6" placeholder="123456" />
            <button type="submit" class="btn btn-primary w-full">Verify emailed code</button>
        </form>
        <form asp-controller="Mfa" asp-action="SendEmail" method="post">
            <button type="submit" class="btn btn-ghost btn-sm w-full">Resend code</button>
        </form>
    }
    else
    {
        <form asp-controller="Mfa" asp-action="SendEmail" method="post">
            <button type="submit" class="btn btn-outline w-full">Email me a code</button>
        </form>
    }
}

@if (Model.Methods.BackupCodes)
{
    <div class="my-4 flex items-center gap-3"><div class="h-px flex-1 bg-border"></div><span class="text-xs text-muted-foreground">or</span><div class="h-px flex-1 bg-border"></div></div>
    <details>
        <summary class="text-sm text-muted-foreground mb-2 cursor-pointer">Use a backup code instead</summary>
        <form asp-controller="Mfa" asp-action="VerifyBackup" method="post" class="space-y-2 mt-2">
            <input name="code" class="input text-center" autocomplete="off" placeholder="xxxxx-xxxxx" />
            <button type="submit" class="btn btn-outline w-full">Verify backup code</button>
        </form>
    </details>
}

<p class="text-center text-sm text-muted-foreground mt-6 mb-0">
    <a class="text-primary hover:underline" asp-controller="Account" asp-action="Login">Cancel and sign in again</a>
</p>
