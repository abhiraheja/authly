@model ForgotPasswordViewModel
@{
    Layout = "_AuthLayout";
}

<h2 class="font-display text-2xl font-bold">Forgot password</h2>
<p class="text-sm text-muted-foreground mt-1 mb-6">Enter your email and we'll send you a reset link.</p>

<form asp-controller="Account" asp-action="ForgotPassword" method="post" class="space-y-4">
    <input type="hidden" asp-for="ReturnUrl" />
    <div>
        <label asp-for="Email" class="label">Email</label>
        <input asp-for="Email" class="input" autocomplete="email" placeholder="you@example.com" />
        <span asp-validation-for="Email" class="text-danger text-xs"></span>
    </div>

    <button type="submit" class="btn btn-primary w-full">Send reset link</button>
</form>

<p class="text-center text-sm text-muted-foreground mt-6">
    <a class="text-primary hover:underline" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Model.ReturnUrl">Back to sign in</a>
</p>
