@model IReadOnlyList<ApiKey>
@{
    var newKey = TempData["NewApiKey"] as string;
}

<div class="flex items-center justify-between gap-3">
    <h1 class="font-display text-xl font-bold">API keys</h1>
    <a class="btn btn-primary btn-sm" asp-area="TenantAdmin" asp-controller="ApiKeys" asp-action="Create">
        <i data-lucide="plus" class="size-4"></i> New API key
    </a>
</div>

@if (newKey is not null)
{
    <div class="card card-body !py-3 flex items-start gap-3 border-l-4 border-l-warning text-sm">
        <i data-lucide="alert-triangle" class="size-4 text-warning mt-0.5"></i>
        <div>
            <h6 class="font-semibold mb-1"><i data-lucide="key-round" class="size-4"></i> Copy your API key now</h6>
            <p class="text-xs text-muted-foreground mb-2">This key is shown <strong>once</strong> and cannot be retrieved again. Send it as the <code>X-API-Key</code> header.</p>
            <div><code>@newKey</code></div>
        </div>
    </div>
}

<div class="card">
    @if (Model.Count == 0)
    {
        <div class="card-body">
            <p class="text-muted-foreground mb-0">No API keys yet. Create one for programmatic access to the Management API.</p>
        </div>
    }
    else
    {
        <div class="overflow-x-auto scroll-thin">
            <table class="table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Scopes</th>
                        <th>Last used</th>
                        <th>Status</th>
                        <th class="text-right"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var key in Model)
                {
                    <tr>
                        <td class="font-medium">@key.Name</td>
                        <td><code>@string.Join(" ", key.Scopes)</code></td>
                        <td class="text-muted-foreground text-sm">@(key.LastUsedAt?.ToString("yyyy-MM-dd HH:mm") ?? "never")</td>
                        <td>
                            @if (key.Revoked) { <span class="badge badge-danger">revoked</span> }
                            else if (key.ExpiresAt is { } exp && exp <= DateTimeOffset.UtcNow) { <span class="badge badge-neutral">expired</span> }
                            else { <span class="badge badge-success">active</span> }
                        </td>
                        <td class="text-right">
                            @if (!key.Revoked)
                            {
                                <form asp-area="TenantAdmin" asp-controller="ApiKeys" asp-action="Revoke" asp-route-id="@key.Id" method="post"
                                      onsubmit="return confirm('Revoke this API key? Applications using it will stop working.');">
                                    <button type="submit" class="btn btn-danger btn-sm">Revoke</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
