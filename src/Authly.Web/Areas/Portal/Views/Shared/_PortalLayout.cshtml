@inject Authly.Web.Infrastructure.Branding.CurrentBranding Branding
@{
    var controller = (ViewContext.RouteData.Values["controller"] as string) ?? "";
    bool IsActive(string c) => string.Equals(controller, c, StringComparison.OrdinalIgnoreCase);
    var brand = await Branding.GetAsync();
    var brandName = await Branding.GetDisplayNameAsync();
    var theme = brand.DarkMode ? "dark" : "light";
    var email = User?.Identity?.Name ?? "Account";
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="@theme">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · @brandName</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="~/css/authly-theme.css" asp-append-version="true" />
    <style>
        :root, [data-bs-theme="light"], [data-bs-theme="dark"] {
            --bs-primary: @brand.PrimaryColor;
            --bs-primary-rgb: @brand.PrimaryColorRgb;
            --authly-on-primary: @brand.ButtonTextColor;
        }
        body { font-family: @Html.Raw(brand.FontFamily); }
    </style>
</head>
<body>
<div class="wrapper">
    <div class="sidenav-menu" id="sidenav">
        <a class="logo" asp-area="Portal" asp-controller="Profile" asp-action="Index">
            @if (brand.LogoUrl is not null)
            {
                <img src="@brand.LogoUrl" alt="@brandName" class="auth-logo" style="max-height:32px;" />
            }
            else
            {
                <span class="logo-mark"><i data-lucide="shield-check"></i></span>
                <span>@brandName</span>
            }
        </a>
        <ul class="side-nav">
            <li class="side-nav-title">Account</li>
            <li class="side-nav-item">
                <a class="side-nav-link @(IsActive("Profile") ? "active" : "")"
                   asp-area="Portal" asp-controller="Profile" asp-action="Index">
                    <span class="menu-icon"><i data-lucide="user-round"></i></span>
                    <span class="menu-text">Profile</span>
                </a>
            </li>
            <li class="side-nav-item">
                <a class="side-nav-link @(IsActive("Security") ? "active" : "")"
                   asp-area="Portal" asp-controller="Security" asp-action="Index">
                    <span class="menu-icon"><i data-lucide="shield-check"></i></span>
                    <span class="menu-text">Security</span>
                </a>
            </li>
            <li class="side-nav-item">
                <a class="side-nav-link @(IsActive("Sessions") ? "active" : "")"
                   asp-area="Portal" asp-controller="Sessions" asp-action="Index">
                    <span class="menu-icon"><i data-lucide="monitor-smartphone"></i></span>
                    <span class="menu-text">Active sessions</span>
                </a>
            </li>
            <li class="side-nav-item">
                <a class="side-nav-link @(IsActive("Activity") ? "active" : "")"
                   asp-area="Portal" asp-controller="Activity" asp-action="Index">
                    <span class="menu-icon"><i data-lucide="history"></i></span>
                    <span class="menu-text">Login activity</span>
                </a>
            </li>
        </ul>
    </div>

    <div class="content-area">
        <header class="app-topbar">
            <button class="btn btn-icon btn-soft-secondary d-lg-none" type="button" id="menuToggle">
                <i data-lucide="menu"></i>
            </button>
            <div class="topbar-item ms-auto">
                <div class="dropdown">
                    <button class="btn btn-soft-secondary dropdown-toggle d-flex align-items-center gap-2"
                            data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="avatar-sm"><span class="avatar-title bg-soft-primary">@email.Substring(0,1).ToUpper()</span></span>
                        <span class="d-none d-sm-inline">@email</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><h6 class="dropdown-header">Signed in</h6></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="dropdown-item text-danger">Sign out</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        <div class="page-content">
            <div class="container-fluid">
                @if (TempData["Success"] is string ok)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @ok<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] is string err)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @err<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </div>

        <footer class="footer">
            &copy; @DateTime.UtcNow.Year @brandName
        </footer>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
<script>
    lucide.createIcons();
    document.getElementById("menuToggle")?.addEventListener("click", () =>
        document.getElementById("sidenav")?.classList.toggle("show"));
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
