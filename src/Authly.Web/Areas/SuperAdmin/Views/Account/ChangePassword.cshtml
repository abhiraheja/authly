@model ChangePasswordViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Change password";
}

<p class="text-center text-muted mb-4">Set a new password to secure your account.</p>

<form asp-area="SuperAdmin" asp-controller="Account" asp-action="ChangePassword" method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small @(ViewData.ModelState.IsValid ? "d-none" : "")"></div>

    <div class="mb-3">
        <label asp-for="NewPassword" class="form-label"></label>
        <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
        <span asp-validation-for="NewPassword" class="text-danger small"></span>
    </div>

    <div class="mb-4">
        <label asp-for="ConfirmPassword" class="form-label"></label>
        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
    </div>

    <div class="d-grid">
        <button type="submit" class="btn btn-primary">Update password</button>
    </div>
</form>
