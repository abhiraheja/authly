@model Application
@{
    var secrets = ViewData["Secrets"] as IReadOnlyList<ApplicationSecret> ?? new List<ApplicationSecret>();
    var newClientId = TempData["NewClientId"] as string;
    var newSecret = TempData["NewClientSecret"] as string;
}

<div class="flex items-center justify-between gap-3">
    <h1 class="font-display text-xl font-bold">@Model.Name</h1>
    <div class="flex gap-2">
        <a class="btn btn-primary btn-sm" asp-area="TenantAdmin" asp-controller="Applications" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="btn btn-outline btn-sm" asp-area="TenantAdmin" asp-controller="Applications" asp-action="Index">Back</a>
    </div>
</div>

@if (newSecret is not null)
{
    <div class="card card-body !py-3 flex items-start gap-3 border-l-4 border-l-warning text-sm">
        <i data-lucide="alert-triangle" class="size-4 text-warning mt-0.5"></i>
        <div>
            <h6 class="font-semibold mb-1"><i data-lucide="key-round" class="size-4"></i> Copy your credentials now</h6>
            <p class="text-xs text-muted-foreground mb-2">This secret is shown <strong>once</strong> and cannot be retrieved again. Store it securely.</p>
            @if (newClientId is not null)
            {
                <div class="mb-2"><span class="text-muted-foreground text-xs block">Client ID</span><code>@newClientId</code></div>
            }
            <div><span class="text-muted-foreground text-xs block">Client secret</span><code>@newSecret</code></div>
        </div>
    </div>
}

<div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
    <div class="lg:col-span-7">
        <div class="card">
            <div class="card-header"><h6 class="card-title">Configuration</h6></div>
            <div class="card-body">
                <dl class="grid grid-cols-3 gap-y-2 gap-x-4 mb-0">
                    <dt class="text-muted-foreground">Client ID</dt>
                    <dd class="col-span-2"><code>@Model.ClientId</code></dd>

                    <dt class="text-muted-foreground">Type</dt>
                    <dd class="col-span-2"><span class="badge badge-primary">@Model.Type</span>
                        @if (Model.IsConfidential) { <span class="badge badge-neutral">confidential</span> }
                        else { <span class="badge badge-neutral">public (PKCE)</span> }
                    </dd>

                    <dt class="text-muted-foreground">Grant types</dt>
                    <dd class="col-span-2">@string.Join(", ", Model.GrantTypes)</dd>

                    <dt class="text-muted-foreground">Scopes</dt>
                    <dd class="col-span-2">@string.Join(" ", Model.AllowedScopes)</dd>

                    <dt class="text-muted-foreground">Redirect URIs</dt>
                    <dd class="col-span-2">
                        @if (Model.RedirectUris.Count == 0) { <span class="text-muted-foreground">—</span> }
                        else { foreach (var u in Model.RedirectUris) { <div><code>@u</code></div> } }
                    </dd>

                    <dt class="text-muted-foreground">Post-logout redirect URIs</dt>
                    <dd class="col-span-2">
                        @if (Model.PostLogoutRedirectUris.Count == 0) { <span class="text-muted-foreground">—</span> }
                        else { foreach (var u in Model.PostLogoutRedirectUris) { <div><code>@u</code></div> } }
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="lg:col-span-5 space-y-4">
        <div class="card">
            <div class="card-header flex items-center justify-between">
                <h6 class="card-title">Client secrets</h6>
                @if (Model.IsConfidential)
                {
                    <form asp-area="TenantAdmin" asp-controller="Applications" asp-action="RotateSecret" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-primary btn-sm">Rotate secret</button>
                    </form>
                }
            </div>
            <div class="card-body">
                @if (!Model.IsConfidential)
                {
                    <p class="text-muted-foreground text-sm mb-0">Public client — no secret. Uses PKCE.</p>
                }
                else if (secrets.Count == 0)
                {
                    <p class="text-muted-foreground text-sm mb-0">No secrets recorded.</p>
                }
                else
                {
                    <ul class="divide-y divide-border">
                    @foreach (var s in secrets)
                    {
                        <li class="flex justify-between items-center py-2">
                            <span>@(s.Label ?? "secret") <span class="text-muted-foreground text-xs">· @s.CreatedAt.ToString("yyyy-MM-dd")</span></span>
                            @if (s.Revoked) { <span class="badge badge-danger">revoked</span> }
                            else { <span class="badge badge-success">active</span> }
                        </li>
                    }
                    </ul>
                }
            </div>
        </div>

        <div class="card border-l-4 border-l-danger">
            <div class="card-body">
                <h6 class="text-danger font-semibold">Danger zone</h6>
                <p class="text-muted-foreground text-sm">Deleting an application immediately revokes its tokens and credentials.</p>
                <form asp-area="TenantAdmin" asp-controller="Applications" asp-action="Delete" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Delete this application? This cannot be undone.');">
                    <button type="submit" class="btn btn-danger btn-sm">Delete application</button>
                </form>
            </div>
        </div>
    </div>
</div>
