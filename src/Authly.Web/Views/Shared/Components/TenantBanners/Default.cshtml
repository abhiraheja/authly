@model Authly.Web.Components.TenantBannersModel

@if (Model.ShowOnboarding)
{
    <div class="card card-body !py-3 flex items-center justify-between flex-wrap gap-2 border-l-4 border-l-primary">
        <span class="flex items-center gap-2 text-sm"><i data-lucide="rocket" class="size-4 text-primary"></i> Finish setting up your workspace — create your first app and reach a test login.</span>
        <a asp-area="TenantAdmin" asp-controller="Onboarding" asp-action="Index" class="btn btn-sm btn-primary">Get started</a>
    </div>
}
