@model PortalProfileViewModel

<div class="flex items-center justify-between gap-3">
    <div>
        <h1 class="font-display text-xl font-bold">Profile</h1>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-4 mt-4">
    <div class="lg:col-span-7">
        <div class="card">
            <div class="card-header"><span class="card-title">Your details</span></div>
            <div class="card-body">
                <form asp-area="Portal" asp-controller="Profile" asp-action="Index" method="post" class="space-y-4">
                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

                    <div>
                        <label class="label">Email</label>
                        <input class="input" value="@Model.Email" disabled />
                        <p class="mt-1 text-xs text-muted-foreground">
                            @if (Model.EmailVerified)
                            {
                                <span class="text-success">Verified</span>
                            }
                            else
                            {
                                <span class="text-warning">Not verified</span>
                            }
                        </p>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="FirstName" class="label"></label>
                            <input asp-for="FirstName" class="input" />
                            <span asp-validation-for="FirstName" class="text-danger text-xs"></span>
                        </div>
                        <div>
                            <label asp-for="LastName" class="label"></label>
                            <input asp-for="LastName" class="input" />
                            <span asp-validation-for="LastName" class="text-danger text-xs"></span>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label asp-for="Timezone" class="label"></label>
                            <input asp-for="Timezone" class="input" placeholder="UTC" />
                            <span asp-validation-for="Timezone" class="text-danger text-xs"></span>
                        </div>
                        <div>
                            <label asp-for="Locale" class="label"></label>
                            <input asp-for="Locale" class="input" placeholder="en" />
                            <span asp-validation-for="Locale" class="text-danger text-xs"></span>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary">Save changes</button>
                </form>
            </div>
        </div>
    </div>

    <div class="lg:col-span-5">
        <div class="card">
            <div class="card-header"><span class="card-title">Password</span></div>
            <div class="card-body">
                <p class="text-sm text-muted-foreground mb-3">Change your password. Other signed-in devices will be signed out.</p>
                <a class="btn btn-outline" asp-area="Portal" asp-controller="Profile" asp-action="ChangePassword">
                    Change password
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
