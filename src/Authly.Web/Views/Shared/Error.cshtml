@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="mx-auto max-w-xl py-12">
    <div class="card card-body text-center">
        <h1 class="font-display text-4xl font-bold text-danger">Error</h1>
        <h2 class="font-display text-xl font-bold mt-2">An error occurred while processing your request.</h2>

        @if (Model.ShowRequestId)
        {
            <p class="mt-3 text-sm text-muted-foreground">
                <strong>Request ID:</strong> <code class="kbd">@Model.RequestId</code>
            </p>
        }

        <div class="mt-6">
            <a class="btn btn-primary" href="/">Back to home</a>
        </div>
    </div>

    <div class="card card-body mt-4 text-sm text-muted-foreground space-y-2">
        <h3 class="font-display text-lg font-bold text-foreground">Development Mode</h3>
        <p>
            Swapping to <strong>Development</strong> environment will display more detailed information about the error that occurred.
        </p>
        <p>
            <strong>The Development environment shouldn't be enabled for deployed applications.</strong>
            It can result in displaying sensitive information from exceptions to end users.
            For local debugging, enable the <strong>Development</strong> environment by setting the <strong>ASPNETCORE_ENVIRONMENT</strong> environment variable to <strong>Development</strong>
            and restarting the app.
        </p>
    </div>
</div>
