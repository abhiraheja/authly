@model PipelineHookInput
@{
    var isNew = Model.Id is null;
    var stages = Enum.GetValues<PipelineStage>();
}

<div class="page-title-head mb-3">
    <h4 class="mb-0">@(isNew ? "Add" : "Edit") pipeline hook</h4>
</div>

<div class="card">
    <div class="card-body">
        <form asp-area="TenantAdmin" asp-controller="PipelineHooks" asp-action="Save" method="post" class="row g-3">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="All" class="text-danger small"></div>

            <div class="col-md-6">
                <label class="form-label" asp-for="Stage">Stage</label>
                <select class="form-select" asp-for="Stage">
                    @foreach (var s in stages)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label" asp-for="OnFailure">On failure</label>
                <select class="form-select" asp-for="OnFailure">
                    <option value="@HookFailureMode.Continue">continue (fail-open)</option>
                    <option value="@HookFailureMode.Block">block (fail-closed)</option>
                </select>
            </div>

            <div class="col-12">
                <label class="form-label" asp-for="Url">Hook URL</label>
                <input class="form-control" asp-for="Url" placeholder="https://example.com/hooks/pre-token" />
            </div>

            <div class="col-md-6">
                <label class="form-label" asp-for="TimeoutMs">Timeout (ms)</label>
                <input class="form-control" asp-for="TimeoutMs" type="number" min="250" max="30000" />
            </div>

            <div class="col-md-6">
                <label class="form-label" asp-for="Secret">Signing secret</label>
                <input class="form-control" asp-for="Secret" type="password" autocomplete="new-password"
                       placeholder="@(isNew ? "Required" : "Leave blank to keep current")" />
            </div>

            <div class="col-12">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" asp-for="IsActive" />
                    <label class="form-check-label" asp-for="IsActive">Active</label>
                </div>
            </div>

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save hook</button>
                <a class="btn btn-soft-secondary" asp-area="TenantAdmin" asp-controller="PipelineHooks" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>
