@{
    var email = ViewData["Email"] as string;
    var phone = ViewData["Phone"] as string;
}

<div class="page-title-head">
    <h4>Email &amp; phone</h4>
</div>

<p class="text-muted small">
    Changing your email or phone is a two-step process: you confirm the new contact, and we alert your
    current email with a link to cancel if it wasn't you.
</p>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">Email address</div>
            <div class="card-body">
                <p class="mb-3">Current: <strong>@email</strong></p>
                <form asp-area="Portal" asp-controller="Contact" asp-action="ChangeEmail" method="post">
                    <div class="mb-3">
                        <label class="form-label">New email</label>
                        <input name="newEmail" type="email" class="form-control" placeholder="new@example.com" required />
                    </div>
                    <button type="submit" class="btn btn-primary">Change email</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">Phone number</div>
            <div class="card-body">
                <p class="mb-3">Current: <strong>@(string.IsNullOrEmpty(phone) ? "—" : phone)</strong></p>
                <form asp-area="Portal" asp-controller="Contact" asp-action="ChangePhone" method="post">
                    <div class="mb-3">
                        <label class="form-label">New phone</label>
                        <input name="newPhone" class="form-control" placeholder="+1 555 123 4567" required />
                    </div>
                    <button type="submit" class="btn btn-primary">Change phone</button>
                    <div class="form-text">A confirmation link is sent to the new number over WhatsApp.</div>
                </form>
            </div>
        </div>
    </div>
</div>
