@using Authly.Web.Models
@{
    Layout = "_DocsLayout";
    ViewData["Title"] = "Quickstart";
    ViewData["DocsActive"] = "quickstart";
    ViewData["Description"] = "Integrate an app with Authly: register a client, run Authorization Code + PKCE, exchange the code for tokens.";

    var tokenTabs = new CodeTabs("qs", new[]
    {
        new CodeTab("Next.js (next-auth)", "providers: [\n  {\n    id: <span class=\"tok-str\">\"authly\"</span>,\n    name: <span class=\"tok-str\">\"Authly\"</span>,\n    type: <span class=\"tok-str\">\"oidc\"</span>,\n    issuer: <span class=\"tok-str\">\"https://auth.yourco.com\"</span>,\n    clientId: process.env.AUTHLY_CLIENT_ID,\n    clientSecret: process.env.AUTHLY_CLIENT_SECRET,\n    authorization: { params: { scope: <span class=\"tok-str\">\"openid profile email offline_access\"</span> } },\n  },\n]"),
        new CodeTab("cURL", "<span class=\"tok-com\"># After receiving ?code= on your callback:</span>\ncurl -X POST https://auth.yourco.com/connect/token \\\n  -d grant_type=authorization_code \\\n  -d code=<span class=\"tok-str\">\"$CODE\"</span> \\\n  -d redirect_uri=<span class=\"tok-str\">\"https://app.yourco.com/callback\"</span> \\\n  -d client_id=<span class=\"tok-str\">\"$CLIENT_ID\"</span> \\\n  -d client_secret=<span class=\"tok-str\">\"$CLIENT_SECRET\"</span> \\\n  -d code_verifier=<span class=\"tok-str\">\"$VERIFIER\"</span>"),
    });
}

<p class="eyebrow">Quickstart</p>
<h1 class="mt-2 font-display text-3xl font-bold tracking-tight">Integrate an app.</h1>
<p class="mt-3 text-muted-foreground">If your stack has an OIDC client library (almost all do), integration is a few lines of config. Here's the whole journey, zero to first login.</p>

<h2 class="font-display text-xl font-bold mt-8 mb-2">1 · Create your first app</h2>
<ol class="list-decimal pl-5 space-y-1.5 text-sm">
    <li>Sign in to your tenant admin console and open <strong>Get started</strong>, or go to <strong>Applications → New application</strong>.</li>
    <li>Choose the client type and set your <strong>redirect URI</strong> (e.g. <code>https://app.yourco.com/callback</code>).</li>
    <li>Copy the <strong>Client ID</strong> and (for confidential clients) the <strong>Client secret</strong> — the secret is shown only once.</li>
    <li>Use the <strong>Sandbox</strong> page to run a test login and copy your exact endpoints.</li>
</ol>

<div class="mt-4 card card-body !py-3 flex items-start gap-3 border-l-4 border-l-primary text-sm">
    <i data-lucide="info" class="size-4 text-primary mt-0.5 shrink-0"></i>
    <div><strong>Choosing a client type.</strong> <strong>Web</strong> apps are confidential (issued a <code>client_secret</code>). <strong>SPA / Native</strong> apps are public — no secret, PKCE only. A browser app cannot hold a secret, so use a SPA client, not Web/confidential.</div>
</div>

<h2 class="font-display text-xl font-bold mt-8 mb-2">2 · Authorization Code + PKCE</h2>
<p class="text-sm text-muted-foreground">PKCE is required for <strong>all</strong> clients. Redirect the user to the authorize endpoint:</p>
<div class="mt-3 code-surface px-4 py-3 text-sm"><code>GET /connect/authorize
  ?response_type=code
  &amp;client_id=YOUR_CLIENT_ID
  &amp;redirect_uri=https://app.yourco.com/callback
  &amp;scope=openid profile email offline_access
  &amp;code_challenge=CHALLENGE&amp;code_challenge_method=S256
  &amp;state=RANDOM</code></div>
<p class="mt-3 text-sm text-muted-foreground">The user authenticates on Authly's branded login page (with MFA if your policy requires), then Authly redirects back to your <code>redirect_uri</code> with <code>?code=…&amp;state=…</code>.</p>

<h2 class="font-display text-xl font-bold mt-8 mb-2">3 · Exchange the code for tokens</h2>
@await Html.PartialAsync("Marketing/_CodeTabs", tokenTabs)
<p class="mt-3 text-sm text-muted-foreground">You receive <code>{ access_token, id_token, refresh_token, expires_in }</code>. Call <code>/connect/userinfo</code> with the bearer token for profile claims. Access tokens live <strong>1 hour</strong>; refresh tokens <strong>14 days</strong> (rotated on every use — reuse revokes the family).</p>

<h2 class="font-display text-xl font-bold mt-8 mb-2">Worked example — "Acme" from zero to first login</h2>
<div class="card overflow-hidden">
    <div class="timeline card-body !pl-9">
        @foreach (var step in new[]
        {
            "Open / → click \"Create your workspace\" → /signup",
            "Submit company \"Acme\" + admin email/password → tenant acme created, you land in /tenantadmin",
            "Wizard: create app \"Acme Web\" (type Web), redirect https://app.acme.com/callback, scopes openid profile email offline_access",
            "Copy Client ID + Client secret (secret shown once)",
            "Set logo + brand color, then Finish",
            "Point your OIDC client at /.well-known/openid-configuration",
            "An Acme user signs in (dev: /account/login?tenant=acme) → back to your app with a code",
            "Your app exchanges the code at /connect/token → access + id (+ refresh) tokens",
        })
        {
            <div class="timeline-item"><div class="text-sm">@step</div></div>
        }
    </div>
</div>

<h2 class="font-display text-xl font-bold mt-8 mb-2">Tenant resolution</h2>
<p class="text-sm text-muted-foreground">In production, requests resolve to a tenant by <strong>custom domain</strong> (e.g. <code>login.acme.com</code>). In local development, add <code>?tenant=acme</code> to the URL or send the <code>X-Tenant-Slug: acme</code> header. <code>/signup</code> is tenant-less by design.</p>

<div class="mt-8 flex items-center justify-between border-t border-border pt-5 text-sm">
    <a class="text-muted-foreground hover:text-foreground" href="/docs">← Overview</a>
    <a class="text-primary hover:underline" href="/docs/oauth">OAuth &amp; OIDC reference →</a>
</div>
