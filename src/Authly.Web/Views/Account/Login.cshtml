@model UserLoginViewModel
@{
    Layout = "_AuthLayout";
    var socialOptions = ViewData["SocialOptions"] as IReadOnlyList<Authly.Modules.Social.SocialLoginOption>
        ?? new List<Authly.Modules.Social.SocialLoginOption>();
}

<p class="text-center text-muted mb-4">Sign in to your account.</p>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success py-2 small">@success</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger py-2 small">@error</div>
}

@if (socialOptions.Count > 0)
{
    <div class="d-grid gap-2 mb-3">
        @foreach (var opt in socialOptions)
        {
            <a class="btn btn-outline-secondary" asp-controller="Social" asp-action="Start"
               asp-route-provider="@opt.Provider" asp-route-returnUrl="@Model.ReturnUrl">
                Continue with @opt.DisplayName
            </a>
        }
    </div>
    <div class="text-center text-muted small mb-3">or</div>
}

<form asp-controller="Account" asp-action="Login" method="post">
    <input type="hidden" asp-for="ReturnUrl" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small @(ViewData.ModelState.IsValid ? "d-none" : "")"></div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label">Email</label>
        <input asp-for="Email" class="form-control" autocomplete="username" placeholder="you@example.com" />
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>

    <div class="mb-2">
        <label asp-for="Password" class="form-label">Password</label>
        <input asp-for="Password" class="form-control" autocomplete="current-password" placeholder="••••••••" />
        <span asp-validation-for="Password" class="text-danger small"></span>
    </div>

    <div class="d-flex justify-content-end mb-4">
        <a asp-controller="Account" asp-action="ForgotPassword" class="small">Forgot password?</a>
    </div>

    <partial name="_Captcha" />

    <div class="d-grid">
        <button type="submit" class="btn btn-primary">Sign in</button>
    </div>
</form>

<div class="text-center text-muted small my-3">or</div>

@Html.AntiForgeryToken()
<div class="d-grid gap-2">
    <button type="button" id="passkeyBtn" class="btn btn-outline-secondary">
        <i data-lucide="key-round" class="me-1"></i> Sign in with a passkey
    </button>
    <a class="btn btn-outline-secondary" asp-controller="Account" asp-action="MagicLink">
        <i data-lucide="mail" class="me-1"></i> Email me a sign-in link
    </a>
</div>
<div id="passkeyError" class="text-danger small text-center mt-2 d-none"></div>

<p class="text-center text-muted small mt-4 mb-0">
    Don't have an account? <a asp-controller="Account" asp-action="Register">Create one</a>
</p>
<p class="text-center text-muted small mb-0">
    <a asp-controller="Account" asp-action="RecoverRequest">Can't access your account?</a>
</p>

@section Scripts {
<script src="~/js/authly-webauthn.js" asp-append-version="true"></script>
<script>
    document.getElementById('passkeyBtn')?.addEventListener('click', function () {
        const email = document.querySelector('[name="Email"]').value.trim();
        const err = document.getElementById('passkeyError');
        err.classList.add('d-none');
        if (!email) { err.textContent = 'Enter your email first, then use your passkey.'; err.classList.remove('d-none'); return; }
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        authlyPasskeyLogin(email, token, function (msg) { err.textContent = msg; err.classList.remove('d-none'); });
    });
</script>
}
