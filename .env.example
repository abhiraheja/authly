# Copy this file to `.env` (same directory as docker-compose.yml) and edit.
# docker compose reads `.env` automatically and substitutes ${VAR} below into the compose file.
# Anything you leave unset falls back to the dev-safe default baked into docker-compose.yml.

# --- App -------------------------------------------------------------------
# Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Development
# Host port the app is published on (container always listens on 8080).
APP_PORT=8080

# 32-byte base64 encryption key (encrypts secrets at rest). REQUIRED for production.
# Generate one: openssl rand -base64 32
ENCRYPTION_KEY=3J8mZ1qg9X0vQpYb2sR7tU4wK6nL5cD8eF1aH0iJ2kM=

# Extra trusted browser origins for SPA CORS (comma/space separated). Optional —
# registered OAuth client redirect-URI origins are already allowed automatically.
CORS_ALLOWED_ORIGINS=

# Data retention windows (days).
RETENTION_LOGIN_HISTORY_DAYS=90
RETENTION_AUDIT_DAYS=365

# Audit-log streaming to an external SIEM/webhook (optional; in-app page can override).
LOG_STREAM_ENDPOINT=
LOG_STREAM_KEY=

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_USER=authly
POSTGRES_PASSWORD=authly
POSTGRES_DB=authly
POSTGRES_PORT=5432

# --- Redis -----------------------------------------------------------------
REDIS_PORT=6379

# --- Observability ---------------------------------------------------------
# OTLP collector endpoint (env fallback; the in-app Observability page can override).
# Leave as-is to use the bundled otel-collector service.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
