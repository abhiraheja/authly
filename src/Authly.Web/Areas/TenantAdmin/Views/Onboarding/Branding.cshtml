@model OnboardingBrandingViewModel

<div class="flex items-center justify-between gap-3 mb-3">
    <div>
        <h1 class="font-display text-xl font-bold">Make it yours</h1>
        <p class="text-sm text-muted-foreground mt-0.5">A logo and brand color personalize your hosted login page. You can fine-tune later.</p>
    </div>
</div>

@await Html.PartialAsync("_WizardSteps")

<div class="max-w-3xl">
    <div class="card">
        <div class="card-header"><div class="card-title">Step 3 — Branding</div></div>
        <div class="card-body">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>
            <form asp-area="TenantAdmin" asp-controller="Onboarding" asp-action="Branding" method="post" class="space-y-4">
                <div>
                    <label asp-for="LogoUrl" class="label"></label>
                    <input asp-for="LogoUrl" class="input" placeholder="https://cdn.yourcompany.com/logo.svg" />
                    <span asp-validation-for="LogoUrl" class="text-danger text-xs"></span>
                </div>
                <div>
                    <label asp-for="PrimaryColor" class="label"></label>
                    <div class="flex gap-2">
                        <input type="color" class="input h-10 w-16 p-1" value="@Model.PrimaryColor"
                               oninput="document.getElementById('PrimaryColor').value = this.value" />
                        <input asp-for="PrimaryColor" id="PrimaryColor" class="input" />
                    </div>
                    <span asp-validation-for="PrimaryColor" class="text-danger text-xs"></span>
                </div>
                <div class="flex justify-between items-center">
                    <a asp-area="TenantAdmin" asp-controller="Onboarding" asp-action="TestLogin" class="text-sm text-muted-foreground hover:underline">Skip</a>
                    <button type="submit" class="btn btn-primary">
                        Save &amp; continue <i data-lucide="arrow-right" class="size-4"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
