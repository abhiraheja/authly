# Authly configuration — copy to `.env` next to docker-compose.yml, then edit.
# Everything here is OPTIONAL: docker-compose.yml has dev-safe defaults. But for
# any real deployment you MUST set your own ENCRYPTION_KEY and a strong DB password.

# 32-byte base64 key that encrypts secrets at rest. Generate one:
#   openssl rand -base64 32
ENCRYPTION_KEY=

# Bundled PostgreSQL password (override the dev default in production).
POSTGRES_PASSWORD=

# Host port the app is published on (container always listens on 8080).
APP_PORT=8080

# Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Production

# --- Optional ---------------------------------------------------------------
# Extra trusted browser origins for SPA CORS (comma/space separated). Registered
# OAuth client redirect-URI origins are already allowed automatically.
# CORS_ALLOWED_ORIGINS=

# Data retention windows (days).
# RETENTION_LOGIN_HISTORY_DAYS=90
# RETENTION_AUDIT_DAYS=365

# Audit-log streaming to an external SIEM/webhook (in-app page can override).
# LOG_STREAM_ENDPOINT=
# LOG_STREAM_KEY=
