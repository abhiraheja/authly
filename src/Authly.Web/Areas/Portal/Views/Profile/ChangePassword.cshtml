@model PortalChangePasswordViewModel

<div class="flex items-center justify-between gap-3">
    <div>
        <h1 class="font-display text-xl font-bold">Change password</h1>
    </div>
</div>

<div class="card max-w-2xl mt-4">
    <div class="card-body">
        <form asp-area="Portal" asp-controller="Profile" asp-action="ChangePassword" method="post" class="space-y-4">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

            @if (!Model.HasPassword)
            {
                <div class="card card-body !py-3 flex items-center gap-3 border-l-4 border-l-primary">
                    <i data-lucide="info" class="size-5 text-primary shrink-0"></i>
                    <span class="text-sm">Your account signs in with a social provider. Set a password to also sign in with email.</span>
                </div>
            }
            else
            {
                <div>
                    <label asp-for="CurrentPassword" class="label"></label>
                    <input asp-for="CurrentPassword" class="input" autocomplete="current-password" />
                    <span asp-validation-for="CurrentPassword" class="text-danger text-xs"></span>
                </div>
            }

            <div>
                <label asp-for="NewPassword" class="label"></label>
                <input asp-for="NewPassword" class="input" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="text-danger text-xs"></span>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="label"></label>
                <input asp-for="ConfirmPassword" class="input" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger text-xs"></span>
            </div>

            <input type="hidden" asp-for="HasPassword" />
            <div class="flex gap-2 pt-1">
                <button type="submit" class="btn btn-primary">Update password</button>
                <a class="btn btn-ghost" asp-area="Portal" asp-controller="Profile" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
