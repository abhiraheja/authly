@{
    var step = ViewBag.Step is int s ? s : 1;
    var labels = new[] { "Application", "Credentials", "Branding", "Test login" };
}
<div class="flex flex-wrap gap-x-6 gap-y-2 mb-4">
    @for (var i = 0; i < labels.Length; i++)
    {
        var n = i + 1;
        var stateCls = n < step ? "bg-success/15 text-success" : (n == step ? "bg-primary/10 text-primary" : "bg-muted text-muted-foreground");
        var textCls = n <= step ? "font-semibold" : "text-muted-foreground";
        <div class="flex items-center gap-2">
            <span class="grid place-items-center size-7 rounded-full @stateCls text-sm font-semibold">
                @if (n < step)
                {
                    <i data-lucide="check" class="size-4"></i>
                }
                else
                {
                    @n
                }
            </span>
            <span class="@textCls">@labels[i]</span>
        </div>
    }
</div>
