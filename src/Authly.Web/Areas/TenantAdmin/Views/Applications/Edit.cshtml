@model EditApplicationViewModel
@{
    var appId = ViewData["ApplicationId"];
}

<div class="flex items-center justify-between gap-3">
    <h1 class="font-display text-xl font-bold">Edit application</h1>
    <a class="btn btn-outline btn-sm" asp-area="TenantAdmin" asp-controller="Applications" asp-action="Details" asp-route-id="@appId">Back</a>
</div>

<div class="card max-w-2xl">
    <div class="card-body">
        <form asp-area="TenantAdmin" asp-controller="Applications" asp-action="Edit" asp-route-id="@appId" method="post" class="space-y-4">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

            <div>
                <label asp-for="Name" class="label"></label>
                <input asp-for="Name" class="input" placeholder="My Web App" />
                <span asp-validation-for="Name" class="text-danger text-xs"></span>
            </div>

            <div>
                <label asp-for="RedirectUris" class="label"></label>
                <textarea asp-for="RedirectUris" class="textarea" rows="4"
                          placeholder="https://app.example.com/callback"></textarea>
                <p class="mt-1 text-xs text-muted-foreground">Where Authly returns the authorization code after sign-in. Required for interactive (authorization-code) clients. One URI per line.</p>
            </div>

            <div>
                <label asp-for="PostLogoutRedirectUris" class="label"></label>
                <textarea asp-for="PostLogoutRedirectUris" class="textarea" rows="3"
                          placeholder="https://app.example.com/"></textarea>
                <p class="mt-1 text-xs text-muted-foreground">Where Authly returns after RP-initiated logout (<code>/connect/logout</code>). One URI per line. Optional.</p>
            </div>

            <div>
                <label asp-for="Scopes" class="label"></label>
                <input asp-for="Scopes" class="input" />
                <p class="mt-1 text-xs text-muted-foreground"><code>openid</code> and <code>offline_access</code> are added automatically for interactive clients.</p>
            </div>

            <input type="hidden" asp-for="Type" />
            @if (Model.Type != ApplicationType.Machine)
            {
                <div>
                    <label class="flex items-center gap-2">
                        <input asp-for="AllowSignup" type="checkbox" class="checkbox" />
                        <span class="label mb-0">Allow self-service sign-up</span>
                    </label>
                    <p class="mt-1 text-xs text-muted-foreground">When off, users can't self-register through this application (admins can still provision accounts). The tenant-level sign-up switch must also be on.</p>
                </div>
            }

            <div class="flex gap-2 pt-1">
                <button type="submit" class="btn btn-primary">Save changes</button>
                <a class="btn btn-outline" asp-area="TenantAdmin" asp-controller="Applications" asp-action="Details" asp-route-id="@appId">Cancel</a>
            </div>
        </form>
    </div>
</div>
