@model ResetPasswordViewModel
@{
    Layout = "_AuthLayout";
}

@if (ViewData["InvalidToken"] is true)
{
    <div class="text-center">
        <span class="logo-mark mb-3"><i data-lucide="alert-triangle"></i></span>
        <h5 class="mb-2">Invalid recovery link</h5>
        <p class="text-muted small mb-4">This link is missing or malformed. Start recovery again.</p>
        <a asp-controller="Account" asp-action="RecoverRequest" class="btn btn-outline-secondary btn-sm">Recover account</a>
    </div>
}
else
{
    <p class="text-center text-muted mb-4">Set a new password to regain access to your account.</p>

    <form asp-controller="Account" asp-action="Recover" method="post">
        <input type="hidden" asp-for="Token" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small @(ViewData.ModelState.IsValid ? "d-none" : "")"></div>

        <div class="mb-3">
            <label asp-for="NewPassword" class="form-label">New password</label>
            <input asp-for="NewPassword" class="form-control" autocomplete="new-password" placeholder="••••••••" />
            <span asp-validation-for="NewPassword" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="ConfirmPassword" class="form-label">Confirm password</label>
            <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="••••••••" />
            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
        </div>

        <div class="d-grid">
            <button type="submit" class="btn btn-primary">Set password</button>
        </div>
    </form>
}
