@model IReadOnlyList<Policy>
@{
    string StatusBadge(PolicyStatus s) => s switch
    {
        PolicyStatus.Published => "badge-success",
        PolicyStatus.Archived => "badge-info",
        _ => "badge-warning"
    };
    string ModeLabel(PolicyEnforcementMode m) => m switch
    {
        PolicyEnforcementMode.Mandatory => "Mandatory",
        PolicyEnforcementMode.SkippableUntil => "Skippable",
        _ => "Optional"
    };
    string AudienceLabel(string json)
    {
        var t = Authly.Core.Policies.PolicyTargetingJson.Parse(json);
        return t.Audience switch
        {
            "applications" => $"{t.ApplicationIds.Count} app(s)",
            "authMethods" => string.Join(", ", t.AuthMethods),
            "providers" => string.Join(", ", t.Providers),
            _ => "All users"
        };
    }
}

<div class="flex items-center justify-between gap-3">
    <div>
        <h1 class="font-display text-xl font-bold">Policies</h1>
        <p class="text-sm text-muted-foreground mt-1">
            Terms &amp; conditions, privacy, and any norms your users must accept at sign-in.
        </p>
    </div>
    <a asp-action="Edit" class="btn btn-primary"><i data-lucide="plus" class="size-4"></i> New policy</a>
</div>

<div class="card mt-4">
    <div class="overflow-x-auto scroll-thin">
        <table class="table">
            <thead>
                <tr>
                    <th>Title</th><th>Status</th><th>Enforcement</th><th>Audience</th>
                    <th>Version</th><th class="text-right">Updated</th><th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td class="font-medium">@p.Title</td>
                        <td><span class="badge @StatusBadge(p.Status)">@p.Status.ToString().ToLower()</span></td>
                        <td class="text-sm">@ModeLabel(p.EnforcementMode)</td>
                        <td class="text-sm text-muted-foreground">@AudienceLabel(p.Targeting)</td>
                        <td class="text-sm text-muted-foreground">@(p.CurrentVersionId is null ? "—" : "live")</td>
                        <td class="text-right text-sm text-muted-foreground">@p.UpdatedAt.UtcDateTime.ToString("yyyy-MM-dd")</td>
                        <td class="text-right whitespace-nowrap">
                            <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-ghost btn-sm">Edit</a>
                            @if (p.Status == PolicyStatus.Published)
                            {
                                <a asp-action="Responses" asp-route-id="@p.Id" class="btn btn-ghost btn-sm">Responses</a>
                            }
                        </td>
                    </tr>
                }
                @if (Model.Count == 0)
                {
                    <tr><td colspan="7" class="text-center text-muted-foreground py-6">No policies yet. Create your first one.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
