@model IReadOnlyList<PipelineHook>

<div class="flex items-center justify-between gap-3">
    <div>
        <h1 class="font-display text-xl font-bold">Pipeline hooks</h1>
        <p class="text-sm text-muted-foreground mt-0.5">Synchronous hooks that run during the auth flow.</p>
    </div>
    <a class="btn btn-sm btn-primary" asp-area="TenantAdmin" asp-controller="PipelineHooks" asp-action="Edit">
        <i data-lucide="plus" class="size-4"></i> Add hook
    </a>
</div>

<div class="card mt-4">
    <div class="card-body">
        <p class="text-muted-foreground text-sm">
            Pipeline hooks fire synchronously at a stage of the auth flow. Each is signed
            (<code>X-Authly-Signature</code>) and bounded by a timeout; on failure the flow either
            continues (fail-open) or blocks (fail-closed). A <code>pre_token</code> hook may return a
            JSON object of claims to inject into the issued token.
        </p>
        @if (Model.Count == 0)
        {
            <p class="text-muted-foreground mb-0">No pipeline hooks configured.</p>
        }
        else
        {
            <div class="overflow-x-auto scroll-thin">
                <table class="table">
                    <thead><tr><th>Stage</th><th>URL</th><th>Timeout</th><th>On failure</th><th>Status</th><th class="text-right"></th></tr></thead>
                    <tbody>
                    @foreach (var h in Model)
                    {
                        <tr>
                            <td class="font-medium">@h.Stage</td>
                            <td class="break-all text-sm">@h.Url</td>
                            <td>@h.TimeoutMs ms</td>
                            <td>@h.OnFailure.ToString().ToLowerInvariant()</td>
                            <td>@(h.IsActive ? "active" : "inactive")</td>
                            <td class="text-right">
                                <a class="btn btn-sm btn-primary" asp-area="TenantAdmin" asp-controller="PipelineHooks" asp-action="Edit" asp-route-id="@h.Id">Edit</a>
                                <form class="inline" asp-area="TenantAdmin" asp-controller="PipelineHooks" asp-action="Delete" asp-route-id="@h.Id" method="post"
                                      onsubmit="return confirm('Remove this hook?');">
                                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
