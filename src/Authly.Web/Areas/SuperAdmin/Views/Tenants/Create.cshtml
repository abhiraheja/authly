@model CreateTenantViewModel
@{
    ViewData["Title"] = "New tenant";
}

<div class="page-title-head">
    <h4>New tenant</h4>
    <a class="btn btn-soft-secondary" asp-action="Index"><i data-lucide="arrow-left" class="me-1"></i> Back</a>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small @(ViewData.ModelState.IsValid ? "d-none" : "")"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" placeholder="Acme Inc." />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Slug" class="form-label"></label>
                        <input asp-for="Slug" class="form-control" placeholder="acme" />
                        <div class="form-text">Leave blank to derive it from the name. Lowercase, numbers and hyphens only.</div>
                        <span asp-validation-for="Slug" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Create tenant</button>
                        <a class="btn btn-soft-secondary" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
