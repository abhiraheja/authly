@model CreateRoleViewModel

<div class="page-title-head d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0">New role</h4>
    <a class="btn btn-soft-secondary btn-sm" asp-area="TenantAdmin" asp-controller="Roles" asp-action="Index">Back</a>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body">
                <form asp-area="TenantAdmin" asp-controller="Roles" asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. billing_manager" autofocus />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                        <div class="form-text">Lower-case letters, digits and underscores.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <input asp-for="Description" class="form-control" placeholder="What this role is for" />
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">Create role</button>
                </form>
            </div>
        </div>
    </div>
</div>
