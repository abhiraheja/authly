@{
    var controller = (ViewContext.RouteData.Values["controller"] as string) ?? "";
    bool IsActive(string c) => string.Equals(controller, c, StringComparison.OrdinalIgnoreCase);
    var adminEmail = User?.Identity?.Name ?? "Admin";
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Authly Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="~/css/authly-theme.css" asp-append-version="true" />
</head>
<body>
<div class="wrapper">
    <div class="sidenav-menu" id="sidenav">
        <a class="logo" asp-area="TenantAdmin" asp-controller="Applications" asp-action="Index">
            <span class="logo-mark"><i data-lucide="shield-check"></i></span>
            <span>Authly</span>
        </a>
        <ul class="side-nav">
            <li class="side-nav-title">Workspace</li>
            <li class="side-nav-item">
                <a class="side-nav-link @(IsActive("Applications") ? "active" : "")"
                   asp-area="TenantAdmin" asp-controller="Applications" asp-action="Index">
                    <span class="menu-icon"><i data-lucide="app-window"></i></span>
                    <span class="menu-text">Applications</span>
                </a>
            </li>
            <li class="side-nav-title">Access control</li>
            <li class="side-nav-item">
                <a class="side-nav-link @(IsActive("Roles") ? "active" : "")"
                   asp-area="TenantAdmin" asp-controller="Roles" asp-action="Index">
                    <span class="menu-icon"><i data-lucide="shield"></i></span>
                    <span class="menu-text">Roles &amp; permissions</span>
                </a>
            </li>
            <li class="side-nav-item">
                <a class="side-nav-link @(IsActive("Users") ? "active" : "")"
                   asp-area="TenantAdmin" asp-controller="Users" asp-action="Index">
                    <span class="menu-icon"><i data-lucide="users"></i></span>
                    <span class="menu-text">Users</span>
                </a>
            </li>
            <li class="side-nav-item">
                <a class="side-nav-link @(IsActive("MfaPolicy") ? "active" : "")"
                   asp-area="TenantAdmin" asp-controller="MfaPolicy" asp-action="Index">
                    <span class="menu-icon"><i data-lucide="lock-keyhole"></i></span>
                    <span class="menu-text">MFA policy</span>
                </a>
            </li>
            <li class="side-nav-title">Developers</li>
            <li class="side-nav-item">
                <a class="side-nav-link @(IsActive("ApiKeys") ? "active" : "")"
                   asp-area="TenantAdmin" asp-controller="ApiKeys" asp-action="Index">
                    <span class="menu-icon"><i data-lucide="key-round"></i></span>
                    <span class="menu-text">API keys</span>
                </a>
            </li>
        </ul>
    </div>

    <div class="content-area">
        <header class="app-topbar">
            <button class="btn btn-icon btn-soft-secondary d-lg-none" type="button" id="menuToggle">
                <i data-lucide="menu"></i>
            </button>
            <div class="topbar-item ms-auto d-flex align-items-center gap-2">
                <button class="btn btn-icon btn-soft-secondary" type="button" id="themeToggle" title="Toggle theme">
                    <i data-lucide="sun-moon"></i>
                </button>
                <div class="dropdown">
                    <button class="btn btn-soft-secondary dropdown-toggle d-flex align-items-center gap-2"
                            data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="avatar-sm"><span class="avatar-title bg-soft-primary">@adminEmail.Substring(0,1).ToUpper()</span></span>
                        <span class="d-none d-sm-inline">@adminEmail</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><h6 class="dropdown-header">Signed in as tenant admin</h6></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <form asp-area="TenantAdmin" asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="dropdown-item text-danger">Sign out</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        <div class="page-content">
            <div class="container-fluid">
                @if (TempData["Success"] is string ok)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @ok<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] is string err)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @err<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </div>

        <footer class="footer">
            &copy; @DateTime.UtcNow.Year Authly — Tenant Admin
        </footer>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
<script>
    lucide.createIcons();
    const html = document.documentElement;
    const saved = localStorage.getItem("authly-theme");
    if (saved) html.setAttribute("data-bs-theme", saved);
    document.getElementById("themeToggle")?.addEventListener("click", () => {
        const next = html.getAttribute("data-bs-theme") === "dark" ? "light" : "dark";
        html.setAttribute("data-bs-theme", next);
        localStorage.setItem("authly-theme", next);
    });
    document.getElementById("menuToggle")?.addEventListener("click", () =>
        document.getElementById("sidenav")?.classList.toggle("show"));
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
