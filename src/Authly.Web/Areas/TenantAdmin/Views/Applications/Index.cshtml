@model IReadOnlyList<Application>

<div class="page-title-head d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0">Applications</h4>
    <a class="btn btn-primary btn-sm" asp-area="TenantAdmin" asp-controller="Applications" asp-action="Create">
        <i data-lucide="plus" class="me-1"></i> New application
    </a>
</div>

<div class="card">
    <div class="card-body">
        @if (Model.Count == 0)
        {
            <p class="text-muted mb-0">No applications yet. Create one to obtain OAuth client credentials.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Client ID</th>
                            <th>Created</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var app in Model)
                    {
                        <tr>
                            <td class="fw-medium">@app.Name</td>
                            <td><span class="badge bg-soft-primary">@app.Type</span></td>
                            <td><code>@app.ClientId</code></td>
                            <td class="text-muted small">@app.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td class="text-end">
                                <a class="btn btn-soft-secondary btn-sm"
                                   asp-area="TenantAdmin" asp-controller="Applications" asp-action="Details" asp-route-id="@app.Id">
                                    Manage
                                </a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
