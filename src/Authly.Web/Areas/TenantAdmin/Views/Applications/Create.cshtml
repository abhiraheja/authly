@model CreateApplicationViewModel

<div class="page-title-head mb-3">
    <h4 class="mb-0">New application</h4>
</div>

<div class="card">
    <div class="card-body">
        <form asp-area="TenantAdmin" asp-controller="Applications" asp-action="Create" method="post" style="max-width: 640px;">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small @(ViewData.ModelState.IsValid ? "d-none" : "")"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="My Web App" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Type" class="form-label"></label>
                <select asp-for="Type" asp-items="Html.GetEnumSelectList<ApplicationType>()" class="form-select"></select>
                <div class="form-text">
                    Web/Machine are confidential (issued a client secret). SPA/Native are public and use PKCE only.
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="RedirectUris" class="form-label"></label>
                <textarea asp-for="RedirectUris" class="form-control" rows="3"
                          placeholder="https://app.example.com/callback"></textarea>
                <div class="form-text">Required for interactive (authorization-code) clients. One URI per line.</div>
            </div>

            <div class="mb-4">
                <label asp-for="Scopes" class="form-label"></label>
                <input asp-for="Scopes" class="form-control" />
                <div class="form-text"><code>openid</code> and <code>offline_access</code> are added automatically for interactive clients.</div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create application</button>
                <a class="btn btn-soft-secondary" asp-area="TenantAdmin" asp-controller="Applications" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>
