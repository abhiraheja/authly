@model Role
@{
    var allPermissions = ViewData["AllPermissions"] as IReadOnlyList<Permission> ?? new List<Permission>();
    var assigned = ViewData["AssignedPermissionIds"] as HashSet<Guid> ?? new HashSet<Guid>();
    var byResource = allPermissions.GroupBy(p => p.Resource).OrderBy(g => g.Key);
}

<div class="page-title-head d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0"><code>@Model.Name</code></h4>
    <a class="btn btn-soft-secondary btn-sm" asp-area="TenantAdmin" asp-controller="Roles" asp-action="Index">Back</a>
</div>

@if (Model.IsSystem)
{
    <div class="alert alert-info py-2 small">
        <i data-lucide="info" class="me-1"></i> This is a system role. You may adjust its permissions, but it can't be renamed or deleted.
    </div>
}

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header"><h6 class="card-title mb-0">Permissions</h6></div>
            <div class="card-body">
                <form asp-area="TenantAdmin" asp-controller="Roles" asp-action="SetPermissions" asp-route-id="@Model.Id" method="post">
                    @if (allPermissions.Count == 0)
                    {
                        <p class="text-muted mb-0">No permissions defined for this tenant yet.</p>
                    }
                    else
                    {
                        foreach (var group in byResource)
                        {
                            <div class="mb-3">
                                <div class="fw-medium text-capitalize mb-1">@group.Key</div>
                                <div class="d-flex flex-wrap gap-3">
                                @foreach (var p in group.OrderBy(x => x.Action))
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="permissionIds"
                                               value="@p.Id" id="perm_@p.Id" @(assigned.Contains(p.Id) ? "checked" : "") />
                                        <label class="form-check-label" for="perm_@p.Id">@p.Action</label>
                                    </div>
                                }
                                </div>
                            </div>
                        }
                        <button type="submit" class="btn btn-primary btn-sm">Save permissions</button>
                    }
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5 text-muted">Description</dt>
                    <dd class="col-7">@(Model.Description ?? "—")</dd>
                    <dt class="col-5 text-muted">Created</dt>
                    <dd class="col-7">@Model.CreatedAt.ToString("yyyy-MM-dd")</dd>
                </dl>
            </div>
        </div>

        @if (!Model.IsSystem)
        {
            <div class="card mt-3 border-danger">
                <div class="card-body">
                    <h6 class="text-danger">Danger zone</h6>
                    <p class="text-muted small">Deleting a role removes it from all assigned users.</p>
                    <form asp-area="TenantAdmin" asp-controller="Roles" asp-action="Delete" asp-route-id="@Model.Id" method="post"
                          onsubmit="return confirm('Delete this role?');">
                        <button type="submit" class="btn btn-outline-danger btn-sm">Delete role</button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
