@{
    Layout = "_AuthLayout";
}

<div class="text-center">
    <span class="logo-mark mb-3"><i data-lucide="life-buoy"></i></span>
    <h5 class="mb-2">Recovery on its way</h5>
    <p class="text-muted small mb-4">
        If an account exists for @(ViewData["Email"] is string e ? e : "that address"),
        we've sent a recovery link to its registered contacts. The link expires in 1 hour.
    </p>
    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-sm">Back to sign in</a>
</div>
