@using Authly.Modules.Users
@{
    var result = ViewBag.Result as ImportResult;
}

<div class="flex items-center gap-3">
    <a class="btn btn-ghost btn-icon btn-sm" asp-area="TenantAdmin" asp-controller="Users" asp-action="Index" aria-label="Back"><i data-lucide="arrow-left" class="size-4"></i></a>
    <h1 class="font-display text-xl font-bold">Import users</h1>
</div>

<div class="card max-w-3xl mt-4">
    <div class="card-body space-y-4">
        <p class="text-sm text-muted-foreground">
            Paste a user export from Auth0, Firebase, or a generic JSON array. Passwords are not migrated —
            imported users set a password via "forgot password" on first sign-in. Existing emails are skipped.
        </p>
        <form asp-area="TenantAdmin" asp-controller="Users" asp-action="Import" method="post" class="space-y-4">
            <div class="max-w-64">
                <label class="label">Source format</label>
                <select name="source" class="select">
                    <option value="@ImportSource.Generic">Generic JSON array</option>
                    <option value="@ImportSource.Auth0">Auth0 export</option>
                    <option value="@ImportSource.Firebase">Firebase export</option>
                </select>
            </div>
            <div>
                <label class="label">Export JSON</label>
                <textarea name="json" class="textarea font-mono" rows="10"
                          placeholder='[{ "email": "a@x.com", "firstName": "Ada", "emailVerified": true }]'></textarea>
            </div>
            <button type="submit" class="btn btn-primary"><i data-lucide="upload" class="size-4"></i> Import</button>
        </form>

        @if (result is not null)
        {
            <hr class="border-border" />
            <h2 class="font-semibold">Result</h2>
            <ul class="text-sm space-y-1">
                <li><strong>@result.Created</strong> created</li>
                <li><strong>@result.Skipped</strong> skipped (already exist)</li>
                <li><strong>@result.Errors.Count</strong> error(s)</li>
            </ul>
            @if (result.Errors.Count > 0)
            {
                <div class="card card-body !py-3 flex items-start gap-3 border-l-4 border-l-warning">
                    <i data-lucide="alert-triangle" class="size-5 text-warning shrink-0"></i>
                    <ul class="text-xs space-y-1">
                        @foreach (var e in result.Errors.Take(20)) { <li>@e</li> }
                    </ul>
                </div>
            }
        }
    </div>
</div>
