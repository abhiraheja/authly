@model IReadOnlyList<ConsentRecord>
@{
    var email = ViewData["Email"] as string ?? "";
}

<div class="page-title-head">
    <h4>Privacy &amp; data</h4>
</div>

<p class="text-muted small">
    Exercise your data rights: download everything we hold about you, review your consent history,
    or permanently delete your account.
</p>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">Consent history</div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead><tr><th>Purpose</th><th>Status</th><th>Version</th><th class="text-end">Date</th></tr></thead>
                    <tbody>
                        @foreach (var c in Model)
                        {
                            <tr>
                                <td class="text-capitalize">@c.Purpose.Replace('_', ' ')</td>
                                <td>
                                    @if (c.Granted)
                                    {
                                        <span class="badge bg-soft-success">granted</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-soft-danger">withdrawn</span>
                                    }
                                </td>
                                <td class="text-muted small">@(c.Version ?? "—")</td>
                                <td class="text-end text-muted small">@c.CreatedAt.UtcDateTime.ToString("yyyy-MM-dd HH:mm") UTC</td>
                            </tr>
                        }
                        @if (Model.Count == 0)
                        {
                            <tr><td colspan="4" class="text-center text-muted py-4">No consent records yet.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card mb-4">
            <div class="card-header">Export your data</div>
            <div class="card-body">
                <p class="text-muted small">
                    Download a machine-readable JSON copy of your profile, sessions, login history,
                    security factors, and consents.
                </p>
                <a asp-area="Portal" asp-controller="Privacy" asp-action="Export" class="btn btn-soft-primary">
                    <i data-lucide="download" class="me-1"></i> Download export
                </a>
            </div>
        </div>

        <div class="card border-danger">
            <div class="card-header text-danger">Delete account</div>
            <div class="card-body">
                <p class="text-muted small">
                    This permanently erases your account and all associated data. It cannot be undone.
                    Type your email <strong>@email</strong> to confirm.
                </p>
                <form asp-area="Portal" asp-controller="Privacy" asp-action="Erase" method="post"
                      onsubmit="return confirm('Permanently erase your account? This cannot be undone.');">
                    <div class="mb-3">
                        <input name="confirmEmail" class="form-control" autocomplete="off" placeholder="@email" />
                    </div>
                    <button type="submit" class="btn btn-danger">Permanently delete my account</button>
                </form>
            </div>
        </div>
    </div>
</div>
