@model TemplateInput
@{
    var isEmail = Model.Channel == MessageChannel.Email;
    var preview = ViewData["Preview"] as RenderedPreview;
    var spec = isEmail ? null : WhatsAppTemplateSpecs.Find(Model.Key);
}

<div class="flex items-center justify-between gap-3">
    <div>
        <h1 class="font-display text-xl font-bold">Edit template — <code>@Model.Key</code></h1>
        <p class="text-sm text-muted-foreground mt-0.5">@Model.Channel · @Model.Locale</p>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-4 mt-4">
    <div class="lg:col-span-7">
        <div class="card">
            <div class="card-body">
                <form asp-area="TenantAdmin" asp-controller="Messaging" asp-action="SaveTemplate" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Key" />
                    <input type="hidden" asp-for="Channel" />
                    <input type="hidden" asp-for="Locale" />

                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

                    @if (isEmail)
                    {
                        <div class="mb-3">
                            <label asp-for="Subject" class="label">Subject</label>
                            <input asp-for="Subject" class="input" />
                        </div>
                    }
                    <div class="mb-3">
                        <label asp-for="Body" class="label">Body @(isEmail ? "(HTML)" : "(fallback text)")</label>
                        <textarea asp-for="Body" class="textarea font-mono" rows="@(isEmail ? 12 : 4)"></textarea>
                        <span asp-validation-for="Body" class="text-danger text-xs"></span>
                        @if (!isEmail)
                        {
                            <span class="text-xs text-muted-foreground">Used only inside WhatsApp's 24-hour reply window. Business-initiated sends (OTP, verification) use the approved template below.</span>
                        }
                    </div>

                    @if (!isEmail && spec is not null)
                    {
                        <div class="card !bg-muted/40 mb-3">
                            <div class="card-body">
                                <div class="flex items-center gap-2 mb-2">
                                    <i data-lucide="message-circle" class="size-4 text-primary"></i>
                                    <h6 class="font-semibold m-0">Approved WhatsApp template</h6>
                                </div>
                                <p class="text-sm text-muted-foreground">
                                    WhatsApp rejects free text for business-initiated messages. Create this template in your
                                    provider (MSG91 → Meta), and once it's <strong>approved</strong>, enter its name below and turn it Active.
                                </p>

                                <div class="text-sm mt-3 space-y-1">
                                    <div><span class="text-muted-foreground">Suggested name:</span> <code>@spec.SuggestedName</code></div>
                                    <div><span class="text-muted-foreground">Category:</span> <span class="badge badge-neutral">@spec.Category</span></div>
                                    <div><span class="text-muted-foreground">Language:</span> <code>@spec.Language</code></div>
                                </div>

                                <div class="mt-3">
                                    <div class="text-muted-foreground text-sm mb-1">Body to submit (with positional variables):</div>
                                    <pre class="p-3 rounded-lg bg-background border border-border text-xs whitespace-pre-wrap"><code>@spec.BodyText</code></pre>
                                </div>

                                <div class="mt-3">
                                    <div class="text-muted-foreground text-sm mb-1">Variable mapping:</div>
                                    <table class="table text-sm">
                                        <thead><tr><th>Placeholder</th><th>Filled with</th><th>Example</th></tr></thead>
                                        <tbody>
                                        @foreach (var p in spec.Parameters)
                                        {
                                            <tr>
                                                <td><code>{{@p.Position}}</code></td>
                                                <td>@p.Description <span class="text-muted-foreground">(<code>@p.Variable</code>)</span></td>
                                                <td class="text-muted-foreground">@p.Sample</td>
                                            </tr>
                                        }
                                        </tbody>
                                    </table>
                                </div>

                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-3">
                                    <div>
                                        <label asp-for="ProviderTemplateName" class="label">Approved template name</label>
                                        <input asp-for="ProviderTemplateName" class="input" placeholder="@spec.SuggestedName" />
                                        <span class="text-xs text-muted-foreground">Leave blank to keep sending free text (24-hour window only).</span>
                                    </div>
                                    <div>
                                        <label asp-for="ProviderLanguage" class="label">Template language</label>
                                        <input asp-for="ProviderLanguage" class="input" placeholder="@spec.Language" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="flex items-center gap-2 mb-3">
                        <label class="switch"><input asp-for="IsActive" type="checkbox" id="isActive" /><span class="track"></span></label>
                        <span>Active</span>
                    </div>

                    <div class="flex gap-2">
                        <button type="submit" name="action" value="save" class="btn btn-primary">Save</button>
                        <button type="submit" name="action" value="preview" class="btn btn-outline">Preview</button>
                        <a class="btn btn-ghost" asp-area="TenantAdmin" asp-controller="Messaging" asp-action="Templates">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="lg:col-span-5">
        <div class="card">
            <div class="card-body">
                <h6 class="mb-2 font-semibold">Available variables</h6>
                <p class="text-sm text-muted-foreground">Insert with <code>{{'{{'}}variable{{'}}'}}</code>. Common ones:</p>
                <div class="text-sm font-mono">
                    {{app_name}} · {{user_name}} · {{action_url}} · {{otp}} · {{expiry_hours}} · {{expiry_minutes}}
                </div>
                @if (preview is not null)
                {
                    <hr class="my-4 border-border" />
                    <h6 class="mb-2 font-semibold">Preview</h6>
                    @if (preview.Subject is not null)
                    {
                        <div class="text-sm text-muted-foreground mb-1">Subject: <strong>@preview.Subject</strong></div>
                    }
                    @if (isEmail)
                    {
                        <div class="border border-border rounded p-2 bg-background">@Html.Raw(preview.Body)</div>
                    }
                    else
                    {
                        <div class="border border-border rounded p-2 bg-muted text-sm">@preview.Body</div>
                    }
                }
            </div>
        </div>
    </div>
</div>
