@model ClaimConfigInput
@{
    var apps = ViewData["Applications"] as IReadOnlyList<Application> ?? new List<Application>();
    var configs = ViewData["Configs"] as IReadOnlyList<ClaimConfig> ?? new List<ClaimConfig>();
}

<div class="page-title-head mb-3">
    <h4 class="mb-0">Custom token claims</h4>
</div>

<div class="card mb-3">
    <div class="card-body">
        <p class="text-muted small mb-3">
            Add claims to issued tokens (§5.6). <strong>Static</strong> emits a fixed value;
            <strong>metadata</strong> maps a dotted path from the user's <code>user_metadata</code>/<code>app_metadata</code>
            (prefix with <code>app_metadata.</code> to target app metadata). For webhook-sourced claims, add a
            <a asp-area="TenantAdmin" asp-controller="PipelineHooks" asp-action="Index">pre-token pipeline hook</a>.
        </p>
        <form asp-area="TenantAdmin" asp-controller="ClaimConfigs" asp-action="Add" method="post" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label" asp-for="ClaimName">Claim name</label>
                <input class="form-control form-control-sm" asp-for="ClaimName" placeholder="department" />
            </div>
            <div class="col-md-2">
                <label class="form-label" asp-for="Type">Type</label>
                <select class="form-select form-select-sm" asp-for="Type">
                    <option value="@ClaimSourceType.Static">static</option>
                    <option value="@ClaimSourceType.Metadata">metadata</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label" asp-for="Source">Value / path</label>
                <input class="form-control form-control-sm" asp-for="Source" placeholder="engineering or org.tier" />
            </div>
            <div class="col-md-2">
                <label class="form-label" asp-for="TokenType">Token</label>
                <select class="form-select form-select-sm" asp-for="TokenType">
                    <option value="@ClaimTokenType.Access">access</option>
                    <option value="@ClaimTokenType.Id">id</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label" asp-for="ApplicationId">Application</label>
                <select class="form-select form-select-sm" asp-for="ApplicationId">
                    <option value="">All (tenant-wide)</option>
                    @foreach (var a in apps)
                    {
                        <option value="@a.Id">@a.Name</option>
                    }
                </select>
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-sm btn-primary">Add claim</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h6 class="mb-3">Configured claims</h6>
        @if (configs.Count == 0)
        {
            <p class="text-muted mb-0">No custom claims configured.</p>
        }
        else
        {
            <table class="table table-sm align-middle mb-0">
                <thead><tr><th>Claim</th><th>Type</th><th>Source</th><th>Token</th><th>Scope</th><th class="text-end"></th></tr></thead>
                <tbody>
                @foreach (var c in configs)
                {
                    var app = apps.FirstOrDefault(a => a.Id == c.ApplicationId);
                    <tr>
                        <td class="fw-medium">@c.ClaimName</td>
                        <td>@c.Type.ToString().ToLowerInvariant()</td>
                        <td class="small text-muted">@c.Source</td>
                        <td>@c.TokenType.ToString().ToLowerInvariant()</td>
                        <td>@(c.ApplicationId is null ? "tenant-wide" : app?.Name ?? "app")</td>
                        <td class="text-end">
                            <form class="d-inline" asp-area="TenantAdmin" asp-controller="ClaimConfigs" asp-action="Delete" asp-route-id="@c.Id" method="post">
                                <button type="submit" class="btn btn-sm btn-soft-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>
