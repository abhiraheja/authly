@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Select a workspace";
}

<div class="text-center">
    <span class="logo-mark mb-3"><i data-lucide="building-2"></i></span>
    <h5 class="mb-2">No workspace selected</h5>
    <p class="text-muted small mb-3">
        This sign-in page belongs to a specific workspace (tenant). In production a workspace
        is reached through its own domain. For local testing, append <code>?tenant=&lt;slug&gt;</code>
        to the URL once and it will be remembered for this browser.
    </p>
    <p class="text-muted small mb-0">Example: <code>/account/login?tenant=acme</code></p>
</div>
