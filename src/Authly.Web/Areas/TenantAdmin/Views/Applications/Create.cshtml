@model CreateApplicationViewModel

<div class="flex items-center gap-3">
    <a class="btn btn-ghost btn-icon btn-sm" asp-area="TenantAdmin" asp-controller="Applications" asp-action="Index" aria-label="Back"><i data-lucide="arrow-left" class="size-4"></i></a>
    <h1 class="font-display text-xl font-bold">New application</h1>
</div>

<div class="card max-w-2xl">
    <div class="card-body">
        <form asp-area="TenantAdmin" asp-controller="Applications" asp-action="Create" method="post" class="space-y-4">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

            <div>
                <label asp-for="Name" class="label"></label>
                <input asp-for="Name" class="input" placeholder="My Web App" />
                <span asp-validation-for="Name" class="text-danger text-xs"></span>
            </div>

            <div>
                <label asp-for="Type" class="label"></label>
                <select asp-for="Type" asp-items="Html.GetEnumSelectList<ApplicationType>()" class="select"></select>
                <p class="mt-1 text-xs text-muted-foreground">
                    Web/Machine are confidential (issued a client secret). SPA/Native are public and use PKCE only.
                </p>
            </div>

            <div>
                <label asp-for="RedirectUris" class="label"></label>
                <textarea asp-for="RedirectUris" class="textarea" rows="3" placeholder="https://app.example.com/callback"></textarea>
                <p class="mt-1 text-xs text-muted-foreground">Where Authly returns the authorization code after sign-in. Required for interactive (authorization-code) clients. One URI per line.</p>
            </div>

            <div>
                <label asp-for="PostLogoutRedirectUris" class="label"></label>
                <textarea asp-for="PostLogoutRedirectUris" class="textarea" rows="2" placeholder="https://app.example.com/"></textarea>
                <p class="mt-1 text-xs text-muted-foreground">Where Authly returns after RP-initiated logout (<code>/connect/logout</code>). One URI per line. Optional.</p>
            </div>

            <div>
                <label asp-for="Scopes" class="label"></label>
                <input asp-for="Scopes" class="input" />
                <p class="mt-1 text-xs text-muted-foreground"><code>openid</code> and <code>offline_access</code> are added automatically for interactive clients.</p>
            </div>

            <div id="signupToggle">
                <label class="flex items-center gap-2">
                    <input asp-for="AllowSignup" type="checkbox" class="checkbox" />
                    <span class="label mb-0">Allow self-service sign-up</span>
                </label>
                <p class="mt-1 text-xs text-muted-foreground">When off, users can't self-register through this application (admins can still provision accounts). The tenant-level sign-up switch must also be on. Not applicable to Machine clients.</p>
            </div>

            <div class="flex gap-2 pt-1">
                <button type="submit" class="btn btn-primary">Create application</button>
                <a class="btn btn-outline" asp-area="TenantAdmin" asp-controller="Applications" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>

@* Sign-up is only meaningful for interactive clients — hide the toggle when Machine is selected. *@
<script>
    (function () {
        var typeSel = document.querySelector('[name="Type"]');
        var toggle = document.getElementById('signupToggle');
        if (!typeSel || !toggle) return;
        function sync() {
            var text = typeSel.options[typeSel.selectedIndex].text;
            toggle.style.display = (text === 'Machine') ? 'none' : '';
        }
        typeSel.addEventListener('change', sync);
        sync();
    })();
</script>
