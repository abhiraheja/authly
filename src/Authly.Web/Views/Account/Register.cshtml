@model RegisterViewModel
@{
    Layout = "_AuthLayout";
}

<h2 class="font-display text-2xl font-bold">Create your account</h2>
<p class="text-sm text-muted-foreground mt-1 mb-6">Get started with a new account.</p>

<form asp-controller="Account" asp-action="Register" method="post" class="space-y-4">
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

    <div>
        <label asp-for="Email" class="label">Email</label>
        <input asp-for="Email" class="input" autocomplete="email" placeholder="you@example.com" />
        <span asp-validation-for="Email" class="text-danger text-xs"></span>
    </div>

    <div class="flex gap-2">
        <div class="flex-1">
            <label asp-for="FirstName" class="label">First name</label>
            <input asp-for="FirstName" class="input" autocomplete="given-name" />
        </div>
        <div class="flex-1">
            <label asp-for="LastName" class="label">Last name</label>
            <input asp-for="LastName" class="input" autocomplete="family-name" />
        </div>
    </div>

    <div>
        <label asp-for="Password" class="label">Password</label>
        <input asp-for="Password" class="input" autocomplete="new-password" placeholder="••••••••" />
        <span asp-validation-for="Password" class="text-danger text-xs"></span>
    </div>

    <div>
        <label asp-for="ConfirmPassword" class="label">Confirm password</label>
        <input asp-for="ConfirmPassword" class="input" autocomplete="new-password" placeholder="••••••••" />
        <span asp-validation-for="ConfirmPassword" class="text-danger text-xs"></span>
    </div>

    <div class="flex items-start gap-2">
        <input asp-for="AcceptTerms" type="checkbox" class="mt-1" />
        <div>
            <label asp-for="AcceptTerms" class="text-sm text-muted-foreground">
                I agree to the <a class="text-primary hover:underline" href="/legal/terms" target="_blank" rel="noopener">Terms of Service</a>
                and <a class="text-primary hover:underline" href="/legal/privacy" target="_blank" rel="noopener">Privacy Policy</a>.
            </label>
            <span asp-validation-for="AcceptTerms" class="text-danger text-xs block"></span>
        </div>
    </div>

    <partial name="_Captcha" />

    <button type="submit" class="btn btn-primary w-full">Create account</button>
</form>

<p class="text-center text-sm text-muted-foreground mt-6">
    Already have an account? <a class="text-primary hover:underline" asp-controller="Account" asp-action="Login">Sign in</a>
</p>
