@model SandboxLoginViewModel
@{
    var attempted = ViewBag.Outcome is string;
    var succeeded = ViewBag.Succeeded is true;
}

<div class="page-title-head mb-3">
    <h4 class="mb-1">Sandbox</h4>
    <p class="text-muted mb-0">Validate credentials and grab your integration endpoints. Test logins never create an admin session.</p>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">Test login</div>
            <div class="card-body">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 @(ViewData.ModelState.IsValid ? "d-none" : "")"></div>
                <form asp-area="TenantAdmin" asp-controller="Sandbox" asp-action="Index" method="post">
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" autocomplete="off" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" autocomplete="off" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary">Run test login</button>
                </form>

                @if (attempted)
                {
                    <hr />
                    @if (succeeded)
                    {
                        <div class="alert alert-success py-2"><i data-lucide="check-circle" class="me-1"></i> Authentication succeeded.</div>
                        <dl class="row mb-0 small">
                            <dt class="col-5">User ID</dt><dd class="col-7"><code>@ViewBag.UserId</code></dd>
                            <dt class="col-5">Email</dt><dd class="col-7">@ViewBag.UserEmail</dd>
                            <dt class="col-5">Email verified</dt><dd class="col-7">@ViewBag.EmailVerified</dd>
                            <dt class="col-5">Status</dt><dd class="col-7">@ViewBag.UserStatus</dd>
                            @if (ViewBag.SessionId is not null)
                            {
                                <dt class="col-5">Session</dt><dd class="col-7"><code>@ViewBag.SessionId</code></dd>
                            }
                        </dl>
                    }
                    else
                    {
                        <div class="alert alert-danger py-2 mb-0">
                            <i data-lucide="x-circle" class="me-1"></i> Outcome: <strong>@ViewBag.Outcome</strong>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">Integration endpoints</div>
            <div class="card-body">
                <p class="text-muted small">Point your OIDC client at the discovery document; it advertises the rest.</p>
                <div class="mb-2">
                    <label class="form-label small mb-1">Discovery</label>
                    <input class="form-control form-control-sm" value="@ViewBag.Discovery" readonly onclick="this.select()" />
                </div>
                <div class="mb-2">
                    <label class="form-label small mb-1">Authorization</label>
                    <input class="form-control form-control-sm" value="@ViewBag.Authorize" readonly onclick="this.select()" />
                </div>
                <div class="mb-2">
                    <label class="form-label small mb-1">Token</label>
                    <input class="form-control form-control-sm" value="@ViewBag.Token" readonly onclick="this.select()" />
                </div>
                <div class="mb-0">
                    <label class="form-label small mb-1">UserInfo</label>
                    <input class="form-control form-control-sm" value="@ViewBag.UserInfo" readonly onclick="this.select()" />
                </div>
            </div>
        </div>
    </div>
</div>
