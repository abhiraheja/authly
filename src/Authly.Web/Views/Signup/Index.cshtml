@model SignupViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Create your workspace";
}

<h2 class="font-display text-2xl font-bold text-center">Create your workspace</h2>
<p class="text-center text-muted-foreground mt-1 mb-6">Spin up your own Authly tenant and become its administrator.</p>

<form asp-controller="Signup" asp-action="Index" method="post" class="space-y-4">
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors @(ViewData.ModelState.IsValid ? "hidden" : "")"></div>

    <div>
        <label asp-for="CompanyName" class="label"></label>
        <input asp-for="CompanyName" class="input" placeholder="Acme Inc." autofocus />
        <span asp-validation-for="CompanyName" class="text-danger text-xs"></span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
            <label asp-for="FirstName" class="label"></label>
            <input asp-for="FirstName" class="input" autocomplete="given-name" />
            <span asp-validation-for="FirstName" class="text-danger text-xs"></span>
        </div>
        <div>
            <label asp-for="LastName" class="label"></label>
            <input asp-for="LastName" class="input" autocomplete="family-name" />
            <span asp-validation-for="LastName" class="text-danger text-xs"></span>
        </div>
    </div>

    <div>
        <label asp-for="Email" class="label"></label>
        <input asp-for="Email" class="input" autocomplete="username" placeholder="you@example.com" />
        <span asp-validation-for="Email" class="text-danger text-xs"></span>
    </div>

    <div>
        <label asp-for="Password" class="label">Password</label>
        <input asp-for="Password" class="input" autocomplete="new-password" placeholder="At least 8 characters" />
        <span asp-validation-for="Password" class="text-danger text-xs"></span>
    </div>

    <div>
        <label asp-for="ConfirmPassword" class="label"></label>
        <input asp-for="ConfirmPassword" class="input" autocomplete="new-password" />
        <span asp-validation-for="ConfirmPassword" class="text-danger text-xs"></span>
    </div>

    <button type="submit" class="btn btn-primary w-full">Create workspace</button>
</form>

<p class="text-center text-sm text-muted-foreground mt-6 mb-0">
    Already have a workspace?
    <a class="text-primary hover:underline" asp-area="TenantAdmin" asp-controller="Account" asp-action="Login">Sign in</a>
</p>
